# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google AdSense
NEXT_PUBLIC_ADSENSE_ID=ca-pub-4859241862365215

# Telegram Bot — request a token from @BotFather, set the chat ID via /start
TELEGRAM_BOT_TOKEN=000000000:REPLACE_WITH_YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_YOUR_CHAT_ID

# DATA_HUB IAP-funnel telemetry — SERVER-ONLY bearer token (never NEXT_PUBLIC_).
# Read only by /api/iap-telemetry, which forwards funnel events to DATA_HUB.
# If unset, the telemetry route is a silent no-op. Rotate if ever exposed.
DATAHUB_TELEMETRY_TOKEN=REPLACE_WITH_YOUR_DATAHUB_TOKEN
