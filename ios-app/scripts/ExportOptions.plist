<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Manual signing с named provisioning profile.
	  Аналогично setup для kz.calk.app — App Store profiles не требуют
	  зарегистрированных устройств в команде.

	  Перед запуском архивирования:
	  1. https://developer.apple.com/account/resources/identifiers/list
	     → создать App ID `kg.calk.ios` (Bundle ID: explicit)
	  2. https://developer.apple.com/account/resources/profiles/list
	     → создать iOS App Store provisioning profile с именем "Calk KG App Store"
	     для App ID `kg.calk.ios`, сертификат Apple Distribution
	  3. Скачать профиль (Xcode подхватит автоматически при двойном клике)
	-->
	<key>method</key>
	<string>app-store-connect</string>
	<key>destination</key>
	<string>upload</string>
	<key>signingStyle</key>
	<string>manual</string>
	<key>teamID</key>
	<string>SRKYS78RMQ</string>
	<key>provisioningProfiles</key>
	<dict>
		<key>kg.calk.ios</key>
		<string>Calk KG App Store</string>
	</dict>
	<key>signingCertificate</key>
	<string>Apple Distribution</string>
	<key>uploadSymbols</key>
	<true/>
	<key>uploadBitcode</key>
	<false/>
	<key>compileBitcode</key>
	<false/>
	<key>stripSwiftSymbols</key>
	<true/>
</dict>
</plist>
