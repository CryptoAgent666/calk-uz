2:T1475,[{"@context":"https://schema.org","@type":"WebPage","name":"Отопление","description":"Рассчитайте стоимость центрального отопления. Зависит от площади квартиры и отопительного сезона.","url":"https://calk.uz/ru/calculator/otoplenie","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/otoplenie#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/otoplenie/opengraph-image"},"dateModified":"2026-03-07"},{"@context":"https://schema.org","@type":"WebApplication","name":"Отопление","description":"Рассчитайте стоимость центрального отопления. Зависит от площади квартиры и отопительного сезона.","url":"https://calk.uz/ru/calculator/otoplenie","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/otoplenie#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Коммунальные","item":"https://calk.uz/ru/category/utilities"},{"@type":"ListItem","position":3,"name":"Отопление","item":"https://calk.uz/ru/calculator/otoplenie"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Какой самый дешёвый способ отопления?","acceptedAnswer":{"@type":"Answer","text":"Центральное отопление (~2 млн за сезон). Газовый котёл — средний (3-5 млн). Электрический — самый дорогой (5-7 млн для 60 м²)."}},{"@type":"Question","name":"Сколько стоит отопление квартиры за сезон?","acceptedAnswer":{"@type":"Answer","text":"Квартира 60 м² в Ташкенте: центральное — 1,8-2,5 млн, газ — 2,5-4,5 млн, электричество — 4-7 млн сум."}},{"@type":"Question","name":"Как снизить расходы на отопление?","acceptedAnswer":{"@type":"Answer","text":"Утепление стен (экономия 30-40%), замена окон (20-30%), утепление крыши (15-20%). Окупается за 2-3 сезона."}},{"@type":"Question","name":"Сколько газа расходует котёл?","acceptedAnswer":{"@type":"Answer","text":"Для квартиры 60 м²: 300-500 м³/мес. Для дома 100 м²: 600-1000 м³/мес. Тариф ~1 000 сум/м³."}},{"@type":"Question","name":"Когда начинается отопительный сезон?","acceptedAnswer":{"@type":"Answer","text":"С октября по март (около 180 дней). Центральное отопление включают при среднесуточной температуре ниже +8°C."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Отопление","description":"Рассчитайте стоимость центрального отопления. Зависит от площади квартиры и отопительного сезона.","url":"https://calk.uz/ru/calculator/otoplenie","datePublished":"2025-02-04","dateModified":"2026-03-07","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/otoplenie"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Отопление","description":"Пошаговое руководство по использованию калькулятора: Отопление","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Введите площадь помещения","text":"Укажите отапливаемую площадь в квадратных метрах."},{"@type":"HowToStep","position":2,"name":"Выберите тип отопления","text":"Выберите централизованное отопление или индивидуальное."},{"@type":"HowToStep","position":