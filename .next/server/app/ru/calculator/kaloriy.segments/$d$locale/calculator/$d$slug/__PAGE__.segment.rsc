2:T17b6,[{"@context":"https://schema.org","@type":"WebPage","name":"Калькулятор калорий","description":"Рассчитайте суточную норму калорий для похудения, набора или поддержания веса. Формула Миффлина-Сан Жеора.","url":"https://calk.uz/ru/calculator/kaloriy","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/kaloriy#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/kaloriy/opengraph-image"},"dateModified":"2025-07-15"},{"@context":"https://schema.org","@type":"WebApplication","name":"Калькулятор калорий","description":"Рассчитайте суточную норму калорий для похудения, набора или поддержания веса. Формула Миффлина-Сан Жеора.","url":"https://calk.uz/ru/calculator/kaloriy","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/kaloriy#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Здоровье","item":"https://calk.uz/ru/category/health"},{"@type":"ListItem","position":3,"name":"Калькулятор калорий","item":"https://calk.uz/ru/calculator/kaloriy"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько калорий нужно в день?","acceptedAnswer":{"@type":"Answer","text":"Мужчины: 2 000-2 500 ккал, женщины: 1 600-2 000 ккал. Зависит от возраста, веса, роста и уровня физической активности. Калькулятор рассчитает персональную норму."}},{"@type":"Question","name":"Сколько калорий нужно для похудения?","acceptedAnswer":{"@type":"Answer","text":"На 500-750 ккал меньше суточной нормы. Это обеспечит безопасную потерю 0,5-0,75 кг в неделю. Не рекомендуется снижать калорийность ниже 1 200 ккал для женщин и 1 500 ккал для мужчин."}},{"@type":"Question","name":"Какая формула точнее?","acceptedAnswer":{"@type":"Answer","text":"Формула Миффлина-Сан Жеора считается наиболее точной для современного человека (точность ~90%). Формула Харриса-Бенедикта завышает на 5-10%."}},{"@type":"Question","name":"Сколько калорий в плове?","acceptedAnswer":{"@type":"Answer","text":"Одна порция плова (300-400 г) содержит 700-900 ккал. Самса — 350-450 ккал, лагман — 400-600 ккал, шурпа — 300-500 ккал."}},{"@type":"Question","name":"Нужно ли учитывать климат при расчёте калорий?","acceptedAnswer":{"@type":"Answer","text":"Да, в жарком климате Узбекистана организм тратит дополнительную энергию на терморегуляцию. Летом потребность может увеличиться на 5-10%."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Калькулятор калорий","description":"Рассчитайте суточную норму калорий для похудения, набора или поддержания веса. Формула Миффлина-Сан Жеора.","url":"https://calk.uz/ru/calculator/kaloriy","datePublished":"2025-09-11","dateModified":"2025-07-15","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/kaloriy"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Калькулятор калорий","description":"Пошаговое руководство по использованию калькулятора: Калькулятор калорий","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите возраст","text":"Укажите ваш возраст в годах."},{"@type":"HowToStep","position":2,"name":"Введите рост и вес","text":"Укажите рост в сантиметрах и вес в килограммах."},{"@type":"HowToStep","position":3,"name":"Выберите пол","text":"Укажите ваш пол для точного расчёта."},{"@type":"HowToStep","position":4,"name":"Выберите уровень активности","text":"Укажите уровень физической активности (сидячий, умеренный, активный)."},{"@type":"HowToStep","position":5,"name":"Получите норму калорий","text":"Нажмите «Рассчитать» — получите суточную норму калорий для поддержания, снижения и набора веса."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
