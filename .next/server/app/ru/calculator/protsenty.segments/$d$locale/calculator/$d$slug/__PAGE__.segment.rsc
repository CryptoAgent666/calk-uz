2:T13fc,[{"@context":"https://schema.org","@type":"WebPage","name":"Калькулятор процентов","description":"Рассчитайте проценты от числа, процентное соотношение и изменение. Все операции с процентами.","url":"https://calk.uz/ru/calculator/protsenty","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/protsenty#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/protsenty/opengraph-image"},"dateModified":"2026-03-04"},{"@context":"https://schema.org","@type":"WebApplication","name":"Калькулятор процентов","description":"Рассчитайте проценты от числа, процентное соотношение и изменение. Все операции с процентами.","url":"https://calk.uz/ru/calculator/protsenty","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/protsenty#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Инструменты","item":"https://calk.uz/ru/category/tools"},{"@type":"ListItem","position":3,"name":"Калькулятор процентов","item":"https://calk.uz/ru/calculator/protsenty"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Как найти процент от числа?","acceptedAnswer":{"@type":"Answer","text":"Число × Процент / 100. Например, 25% от 800 000 сум = 800 000 × 25 / 100 = 200 000 сум."}},{"@type":"Question","name":"Как узнать процентное соотношение?","acceptedAnswer":{"@type":"Answer","text":"Часть / Целое × 100. Например, 150 000 из 600 000 = 150 000 / 600 000 × 100 = 25%."}},{"@type":"Question","name":"Как рассчитать процентное изменение?","acceptedAnswer":{"@type":"Answer","text":"(Новое − Старое) / Старое × 100%. Было 500 000, стало 650 000: рост = 30%."}},{"@type":"Question","name":"Как быстро посчитать НДС 12%?","acceptedAnswer":{"@type":"Answer","text":"Умножьте сумму на 0,12. Для 5 000 000 сум: НДС = 600 000 сум, итого с НДС = 5 600 000 сум."}},{"@type":"Question","name":"Как рассчитать реальную доходность с учётом инфляции?","acceptedAnswer":{"@type":"Answer","text":"Реальная доходность ≈ Номинальная − Инфляция. Вклад 24% − инфляция 10% = ~14% реальной доходности."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Калькулятор процентов","description":"Рассчитайте проценты от числа, процентное соотношение и изменение. Все операции с процентами.","url":"https://calk.uz/ru/calculator/protsenty","datePublished":"2025-02-02","dateModified":"2026-03-04","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/protsenty"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Калькулятор процентов","description":"Пошаговое руководство по использованию калькулятора: Калькулятор процентов","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Выберите тип расчёта","text":"Выберите: найти процент от числа, число по проценту или процентное соотношение."},{"@type":"HowToStep","position":2,"name":"Введите значения","text":"Заполните числовые поля в зависимости от выбранного типа."},{"@type":"HowToStep","position":3,"name":"Получите рез