2:T158a,[{"@context":"https://schema.org","@type":"WebPage","name":"Образовательный кредит","description":"Рассчитайте образовательный кредит для оплаты учёбы. Льготная ставка и отсрочка платежа.","url":"https://calk.uz/ru/calculator/obrazovatelnyy-kredit","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/obrazovatelnyy-kredit#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/obrazovatelnyy-kredit/opengraph-image"},"dateModified":"2025-10-15"},{"@context":"https://schema.org","@type":"WebApplication","name":"Образовательный кредит","description":"Рассчитайте образовательный кредит для оплаты учёбы. Льготная ставка и отсрочка платежа.","url":"https://calk.uz/ru/calculator/obrazovatelnyy-kredit","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/obrazovatelnyy-kredit#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Образование","item":"https://calk.uz/ru/category/education"},{"@type":"ListItem","position":3,"name":"Образовательный кредит","item":"https://calk.uz/ru/calculator/obrazovatelnyy-kredit"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Какие ставки по образовательным кредитам?","acceptedAnswer":{"@type":"Answer","text":"14-18% годовых — значительно ниже рыночных 22-33%. Ставка привязана к ставке ЦБ (14%)."}},{"@type":"Question","name":"Когда начинать погашение?","acceptedAnswer":{"@type":"Answer","text":"После окончания учёбы. Во время обучения — только проценты (1-3 млн сум/мес) или полная отсрочка у некоторых банков."}},{"@type":"Question","name":"Какие документы нужны?","acceptedAnswer":{"@type":"Answer","text":"Справка о зачислении, паспорт, поручитель с доходами, справка о доходах поручителя, договор с вузом."}},{"@type":"Question","name":"Какую сумму можно получить?","acceptedAnswer":{"@type":"Answer","text":"До 100% стоимости обучения, максимум до 200 млн сум в зависимости от банка и вуза."}},{"@type":"Question","name":"Какая переплата по кредиту?","acceptedAnswer":{"@type":"Answer","text":"При ставке 16% и сроке 7 лет — переплата составит около 50-60% от суммы кредита. Используйте калькулятор для точного расчёта."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Образовательный кредит","description":"Рассчитайте образовательный кредит для оплаты учёбы. Льготная ставка и отсрочка платежа.","url":"https://calk.uz/ru/calculator/obrazovatelnyy-kredit","datePublished":"2025-03-20","dateModified":"2025-10-15","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/obrazovatelnyy-kredit"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Образовательный кредит","description":"Пошаговое руководство по использованию калькулятора: Образовательный кредит","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите стоимость обучения","text":"Укажите годовую стоимость контракта."},{"@type":"HowToStep","position":2,"name":"Укажите срок обучения","text":"Введите количе