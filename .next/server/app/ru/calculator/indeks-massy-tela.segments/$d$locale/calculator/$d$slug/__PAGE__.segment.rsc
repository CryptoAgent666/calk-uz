2:T1438,[{"@context":"https://schema.org","@type":"WebPage","name":"Индекс массы тела","description":"Рассчитайте индекс массы тела (ИМТ). Узнайте, в норме ли ваш вес по отношению к росту.","url":"https://calk.uz/ru/calculator/indeks-massy-tela","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/indeks-massy-tela#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/indeks-massy-tela/opengraph-image"},"dateModified":"2025-06-20"},{"@context":"https://schema.org","@type":"WebApplication","name":"Индекс массы тела","description":"Рассчитайте индекс массы тела (ИМТ). Узнайте, в норме ли ваш вес по отношению к росту.","url":"https://calk.uz/ru/calculator/indeks-massy-tela","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/indeks-massy-tela#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Здоровье","item":"https://calk.uz/ru/category/health"},{"@type":"ListItem","position":3,"name":"Индекс массы тела","item":"https://calk.uz/ru/calculator/indeks-massy-tela"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Как рассчитать ИМТ?","acceptedAnswer":{"@type":"Answer","text":"ИМТ = Вес(кг) / Рост(м)². Например: 70 кг при росте 170 см → 70 / 1,70² = 24,2. Это верхняя граница нормы."}},{"@type":"Question","name":"Какой ИМТ считается нормальным?","acceptedAnswer":{"@type":"Answer","text":"18,5-24,9 по классификации ВОЗ. Ниже 18,5 — дефицит, 25-29,9 — избыточный вес, 30+ — ожирение."}},{"@type":"Question","name":"Точен ли ИМТ для спортсменов?","acceptedAnswer":{"@type":"Answer","text":"Нет, ИМТ не различает мышечную и жировую массу. Спортсменам лучше использовать измерение процента жира (норма 10-20% для мужчин, 18-28% для женщин)."}},{"@type":"Question","name":"Какой нормальный вес при росте 175 см?","acceptedAnswer":{"@type":"Answer","text":"По ВОЗ (ИМТ 18,5-24,9): 57-76 кг. Оптимальный диапазон: 63-72 кг."}},{"@type":"Question","name":"Какова ситуация с ожирением в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"Около 30% взрослого населения имеют избыточный вес, 15% — ожирение. Основные причины: калорийная кухня и малоподвижность."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Индекс массы тела","description":"Рассчитайте индекс массы тела (ИМТ). Узнайте, в норме ли ваш вес по отношению к росту.","url":"https://calk.uz/ru/calculator/indeks-massy-tela","datePublished":"2025-08-01","dateModified":"2025-06-20","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/indeks-massy-tela"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Индекс массы тела","description":"Пошаговое руководство по использованию калькулятора: Индекс массы тела","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Введите рост","text":"Укажите ваш рост в сантиметрах."},{"@type":"HowToStep","position":2,"name":"Введите вес","text":"Укажите ваш вес в килограммах."},{"@type":"HowToStep","position":3,"name":"Получите результат","text":"Нажмите «Рассчитать» — получите индекс массы тела и категорию (норма, избыток, ожирение)."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
