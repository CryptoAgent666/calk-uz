2:T15cc,[{"@context":"https://schema.org","@type":"WebPage","name":"Калькулятор беременности","description":"Рассчитайте срок беременности, предполагаемую дату родов и текущую неделю. По дате последних месячных.","url":"https://calk.uz/ru/calculator/beremennost","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/beremennost#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/beremennost/opengraph-image"},"dateModified":"2025-07-05"},{"@context":"https://schema.org","@type":"WebApplication","name":"Калькулятор беременности","description":"Рассчитайте срок беременности, предполагаемую дату родов и текущую неделю. По дате последних месячных.","url":"https://calk.uz/ru/calculator/beremennost","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/beremennost#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Здоровье","item":"https://calk.uz/ru/category/health"},{"@type":"ListItem","position":3,"name":"Калькулятор беременности","item":"https://calk.uz/ru/calculator/beremennost"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Как рассчитать дату родов?","acceptedAnswer":{"@type":"Answer","text":"Первый день последних месячных + 280 дней (40 недель). Или введите дату в калькулятор — он рассчитает автоматически с датами УЗИ."}},{"@type":"Question","name":"Сколько недель длится беременность?","acceptedAnswer":{"@type":"Answer","text":"40 недель (280 дней) от первого дня последней менструации. Нормальные роды: 37-42 неделя. Только 5% родов — точно в ПДР."}},{"@type":"Question","name":"Когда делать УЗИ?","acceptedAnswer":{"@type":"Answer","text":"Три обязательных УЗИ: 11-14 недель (1-й скрининг), 18-22 недели (2-й скрининг), 30-34 недели (3-е УЗИ). В женской консультации — бесплатно."}},{"@type":"Question","name":"Сколько стоят роды в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"В государственном роддоме — бесплатно. В частных клиниках: 5-25 млн сум в зависимости от уровня сервиса."}},{"@type":"Question","name":"Как часто нужно посещать врача?","acceptedAnswer":{"@type":"Answer","text":"До 28 нед. — 1 раз/мес, 28-36 нед. — 2 раза/мес, после 36 нед. — еженедельно. Наблюдение в женской консультации бесплатно."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Калькулятор беременности","description":"Рассчитайте срок беременности, предполагаемую дату родов и текущую неделю. По дате последних месячных.","url":"https://calk.uz/ru/calculator/beremennost","datePublished":"2025-07-25","dateModified":"2025-07-05","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/beremennost"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Калькулятор беременности","description":"Пошаговое руководство по использованию калькулятора: Калькулятор беременности","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Укажите дату","text":"Введите дату первого дня последней менструации или дату зачатия."},