2:T14b8,[{"@context":"https://schema.org","@type":"WebPage","name":"Порог НДС","description":"Проверьте, достигла ли ваша выручка порога для обязательной постановки на учёт по НДС в Узбекистане.","url":"https://calk.uz/ru/calculator/porog-nds","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/porog-nds#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/porog-nds/opengraph-image"},"dateModified":"2026-01-14"},{"@context":"https://schema.org","@type":"WebApplication","name":"Порог НДС","description":"Проверьте, достигла ли ваша выручка порога для обязательной постановки на учёт по НДС в Узбекистане.","url":"https://calk.uz/ru/calculator/porog-nds","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/porog-nds#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Налоги","item":"https://calk.uz/ru/category/tax"},{"@type":"ListItem","position":3,"name":"Порог НДС","item":"https://calk.uz/ru/calculator/porog-nds"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Какой порог для обязательной регистрации по НДС?","acceptedAnswer":{"@type":"Answer","text":"1 млрд сум (с августа 2025) за 12 последовательных месяцев."}},{"@type":"Question","name":"Можно ли зарегистрироваться добровольно?","acceptedAnswer":{"@type":"Answer","text":"Да, при любом обороте. Выгодно при работе с плательщиками НДС — они смогут принять ваш НДС к зачёту."}},{"@type":"Question","name":"Что будет при превышении порога без регистрации?","acceptedAnswer":{"@type":"Answer","text":"Штрафные санкции и доначисление НДС за весь период превышения. Штраф — от 10 до 20 БРВ (4 120 000 — 8 240 000 сум)."}},{"@type":"Question","name":"Как считается 12-месячный оборот?","acceptedAnswer":{"@type":"Answer","text":"Скользящим методом: берутся последние 12 месяцев от текущей даты, а не календарный год. Суммируются все виды реализации."}},{"@type":"Question","name":"Когда выгодна добровольная регистрация?","acceptedAnswer":{"@type":"Answer","text":"Когда клиенты — плательщики НДС (B2B). Для розничной торговли (B2C) обычно невыгодна, так как придётся повысить цены на 12%."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Порог НДС","description":"Проверьте, достигла ли ваша выручка порога для обязательной постановки на учёт по НДС в Узбекистане.","url":"https://calk.uz/ru/calculator/porog-nds","datePublished":"2025-09-08","dateModified":"2026-01-14","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/porog-nds"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Порог НДС","description":"Пошаговое руководство по использованию калькулятора: Порог НДС","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Введите выручку","text":"Укажите годовую выручку вашего бизнеса в сумах."},{"@type":"HowToStep","position":2,"name":"Выберите тип деятельности","text":"Укажите вид деятельности для определения порога НДС."},{"@type":"HowToStep","positio