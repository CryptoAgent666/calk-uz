2:T1698,[{"@context":"https://schema.org","@type":"WebPage","name":"Сложный процент","description":"Рассчитайте рост вложений со сложным процентом. Покажем, как работает капитализация и реинвестирование.","url":"https://calk.uz/ru/calculator/slozhnyy-protsent","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/slozhnyy-protsent#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/slozhnyy-protsent/opengraph-image"},"dateModified":"2026-02-22"},{"@context":"https://schema.org","@type":"WebApplication","name":"Сложный процент","description":"Рассчитайте рост вложений со сложным процентом. Покажем, как работает капитализация и реинвестирование.","url":"https://calk.uz/ru/calculator/slozhnyy-protsent","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/slozhnyy-protsent#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Депозиты","item":"https://calk.uz/ru/category/deposit"},{"@type":"ListItem","position":3,"name":"Сложный процент","item":"https://calk.uz/ru/calculator/slozhnyy-protsent"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Чем сложные проценты отличаются от простых?","acceptedAnswer":{"@type":"Answer","text":"Простые: проценты только на начальную сумму. Сложные: проценты на начальную сумму плюс ранее начисленные проценты (капитализация)."}},{"@type":"Question","name":"Как капитализация влияет на доход?","acceptedAnswer":{"@type":"Answer","text":"При 24% годовых за 5 лет: без капитализации — +120%, с ежемесячной — +226,9%. Разница на 50 млн сум — более 53 млн."}},{"@type":"Question","name":"Как часто лучше капитализировать?","acceptedAnswer":{"@type":"Answer","text":"Чем чаще, тем выгоднее. Ежемесячная капитализация при 24% даёт на 33,7% больше годовой за 5 лет."}},{"@type":"Question","name":"Облагается ли доход по вкладам налогом?","acceptedAnswer":{"@type":"Answer","text":"Да, с дохода по вкладам удерживается НДФЛ 5% для резидентов (10% для нерезидентов). Банк удерживает налог автоматически при выплате процентов."}},{"@type":"Question","name":"Какая реальная доходность вкладов?","acceptedAnswer":{"@type":"Answer","text":"Номинальная 20-26% минус инфляция ~7,3% = реальная доходность 13-19% годовых (до вычета 5% НДФЛ на проценты)."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Сложный процент","description":"Рассчитайте рост вложений со сложным процентом. Покажем, как работает капитализация и реинвестирование.","url":"https://calk.uz/ru/calculator/slozhnyy-protsent","datePublished":"2025-07-28","dateModified":"2026-02-22","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/slozhnyy-protsent"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Сложный процент","description":"Пошаговое руководство по использованию калькулятора: Сложный процент","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите начальную сумму","text":"Укажите начальную сумму инвестиции или 