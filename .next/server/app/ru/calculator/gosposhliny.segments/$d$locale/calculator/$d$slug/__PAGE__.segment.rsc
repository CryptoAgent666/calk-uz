2:T14ef,[{"@context":"https://schema.org","@type":"WebPage","name":"Госпошлины","description":"Рассчитайте размер государственной пошлины в Узбекистане. Суд, нотариус, регистрация и другие услуги.","url":"https://calk.uz/ru/calculator/gosposhliny","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/gosposhliny#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/gosposhliny/opengraph-image"},"dateModified":"2025-09-20"},{"@context":"https://schema.org","@type":"WebApplication","name":"Госпошлины","description":"Рассчитайте размер государственной пошлины в Узбекистане. Суд, нотариус, регистрация и другие услуги.","url":"https://calk.uz/ru/calculator/gosposhliny","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/gosposhliny#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Узбекистан","item":"https://calk.uz/ru/category/unique"},{"@type":"ListItem","position":3,"name":"Госпошлины","item":"https://calk.uz/ru/calculator/gosposhliny"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько стоит регистрация собственности?","acceptedAnswer":{"@type":"Answer","text":"Для физлиц зависит от площади: до 100 м² — 1,25 БРВ (515 000 сум), 101-300 м² — 2 БРВ, свыше 300 — 3 БРВ. Для юрлиц — 5 БРВ (2 060 000). Нотариальное удостоверение договора — фикс. 1 БРВ (412 000)."}},{"@type":"Question","name":"Какая госпошлина за подачу иска?","acceptedAnswer":{"@type":"Answer","text":"2% от суммы иска для физлиц, 5% для юрлиц. Минимум — 1 БРВ (412 000 сум). Трудовые споры и алименты — бесплатно."}},{"@type":"Question","name":"Кто освобождён от госпошлин?","acceptedAnswer":{"@type":"Answer","text":"Инвалиды I-II группы (суд), истцы по трудовым спорам и алиментам, участники войны. Пенсионеры — скидка 50%."}},{"@type":"Question","name":"Сколько стоит регистрация брака?","acceptedAnswer":{"@type":"Answer","text":"1 БРВ (412 000 сум) за свидетельство о браке. Расторжение через суд — 3 БРВ (1 236 000 сум)."}},{"@type":"Question","name":"Как оплатить госпошлину?","acceptedAnswer":{"@type":"Answer","text":"Через банковские терминалы, Click, Payme, Uzum или в кассе банка. Квитанция действительна 3 месяца."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Госпошлины","description":"Рассчитайте размер государственной пошлины в Узбекистане. Суд, нотариус, регистрация и другие услуги.","url":"https://calk.uz/ru/calculator/gosposhliny","datePublished":"2025-05-20","dateModified":"2025-09-20","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/gosposhliny"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Госпошлины","description":"Пошаговое руководство по использованию калькулятора: Госпошлины","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Выберите вид услуги","text":"Укажите государственную услугу (регистрация, лицензирование и др.)."},{"@type":"HowToStep","position":2,"name":"Укажите параметры","text":