2:T17f6,[{"@context":"https://schema.org","@type":"WebPage","name":"Зарплатный калькулятор","description":"Рассчитайте зарплату «на руки» или «грязными». Учитывает НДФЛ, ИНПС и все обязательные отчисления в Узбекистане.","url":"https://calk.uz/ru/calculator/zarplata","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/zarplata#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/zarplata/opengraph-image"},"dateModified":"2025-12-12"},{"@context":"https://schema.org","@type":"WebApplication","name":"Зарплатный калькулятор","description":"Рассчитайте зарплату «на руки» или «грязными». Учитывает НДФЛ, ИНПС и все обязательные отчисления в Узбекистане.","url":"https://calk.uz/ru/calculator/zarplata","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/zarplata#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Зарплата","item":"https://calk.uz/ru/category/salary"},{"@type":"ListItem","position":3,"name":"Зарплатный калькулятор","item":"https://calk.uz/ru/calculator/zarplata"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Какая минимальная зарплата в Узбекистане в 2026 году?","acceptedAnswer":{"@type":"Answer","text":"Минимальная заработная плата составляет 1 271 000 сум в месяц (размер действует с 2025 года, сохраняется в 2026 году)."}},{"@type":"Question","name":"Сколько процентов удерживается с зарплаты?","acceptedAnswer":{"@type":"Answer","text":"НДФЛ 12% + ИНПС 0,1% = 12,1% от начисленной зарплаты. Для IT Park: 7,5% + 0,1% = 7,6%."}},{"@type":"Question","name":"Как рассчитать зарплату «на руки»?","acceptedAnswer":{"@type":"Answer","text":"Зарплата на руки = Начисленная × (100% − 12% − 0,1%) = Начисленная × 0,879. Например, 10 000 000 × 0,879 = 8 790 000 сум."}},{"@type":"Question","name":"Сколько работодатель платит сверх зарплаты?","acceptedAnswer":{"@type":"Answer","text":"Социальный налог 12% от ФОТ (25% для бюджетных). При зарплате 10 млн сум доп. расходы = 1 200 000 сум."}},{"@type":"Question","name":"Как оплачивается сверхурочная работа?","acceptedAnswer":{"@type":"Answer","text":"Первые 2 часа — в 1,5-кратном размере, далее — в двойном. Работа в выходные/праздники — в двойном или с предоставлением отгула."}},{"@type":"Question","name":"Как часто должна выплачиваться зарплата?","acceptedAnswer":{"@type":"Answer","text":"Не реже двух раз в месяц. За задержку — компенсация 1/300 ставки рефинансирования ЦБ (14%) за каждый день просрочки."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Зарплатный калькулятор","description":"Рассчитайте зарплату «на руки» или «грязными». Учитывает НДФЛ, ИНПС и все обязательные отчисления в Узбекистане.","url":"https://calk.uz/ru/calculator/zarplata","datePublished":"2025-09-16","dateModified":"2025-12-12","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/zarplata"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Зарплатный калькулятор","description":"Пошаговое руководство по использованию калькулятора: Зарплатный калькулятор","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите зарплату","text":"Укажите сумму начисленной (gross) заработной платы в сумах."},{"@type":"HowToStep","position":2,"name":"Выберите тип расчёта","text":"Укажите, вводите ли вы «грязную» зарплату (до вычетов) или «чистую» (на руки)."},{"@type":"HowToStep","position":3,"name":"Укажите льготы","text":"Если у вас есть льготы по НДФЛ (инвалидность, участник войны и др.), отметьте их."},{"@type":"HowToStep","position":4,"name":"Получите результат","text":"Нажмите «Рассчитать» и получите сумму на руки, НДФЛ, ИНПС и все отчисления."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
