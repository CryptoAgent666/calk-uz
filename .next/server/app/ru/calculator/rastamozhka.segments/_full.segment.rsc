1a:T180d,[{"@context":"https://schema.org","@type":"WebPage","name":"Растаможка авто","description":"Рассчитайте стоимость растаможки автомобиля в Узбекистане. Таможенная пошлина, акциз и НДС.","url":"https://calk.uz/ru/calculator/rastamozhka","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/rastamozhka#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/rastamozhka/opengraph-image"},"dateModified":"2025-08-21"},{"@context":"https://schema.org","@type":"WebApplication","name":"Растаможка авто","description":"Рассчитайте стоимость растаможки автомобиля в Узбекистане. Таможенная пошлина, акциз и НДС.","url":"https://calk.uz/ru/calculator/rastamozhka","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/rastamozhka#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Авто","item":"https://calk.uz/ru/category/auto"},{"@type":"ListItem","position":3,"name":"Растаможка авто","item":"https://calk.uz/ru/calculator/rastamozhka"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Из чего состоят таможенные платежи?","acceptedAnswer":{"@type":"Answer","text":"Таможенная пошлина (0-30%), НДС (12% от стоимости+пошлина), акциз (для подакцизных товаров), сбор за таможенное оформление (по тарифной сетке)."}},{"@type":"Question","name":"Сколько товаров можно ввезти без пошлины?","acceptedAnswer":{"@type":"Answer","text":"С 1 мая 2025: самолётом — до $1 000 и 50 кг; поездом/по воде — до $500; на авто/пешком — до $300; курьерской почтой — до $200/мес; посылки — до $100. Требуется минимальное пребывание за рубежом: 2 дня (авто), 3 дня (самолёт)."}},{"@type":"Question","name":"Как определить размер таможенной пошлины?","acceptedAnswer":{"@type":"Answer","text":"По коду ТН ВЭД товара. Ставки публикуются Государственным таможенным комитетом. Средние ставки: 0-5% на оборудование, 10-20% на потребительские товары, до 30% на подакцизные."}},{"@type":"Question","name":"Какой курс валюты используется для расчёта пошлин?","acceptedAnswer":{"@type":"Answer","text":"Официальный курс ЦБ на дату подачи таможенной декларации."}},{"@type":"Question","name":"Есть ли льготы по таможенным платежам?","acceptedAnswer":{"@type":"Answer","text":"Да: технологическое оборудование (не производимое в РУз), товары для СЭЗ, инвестиционные проекты. Льготы устанавливаются отдельными постановлениями."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Растаможка авто","description":"Рассчитайте стоимость растаможки автомобиля в Узбекистане. Таможенная пошлина, акциз и НДС.","url":"https://calk.uz/ru/calculator/rastamozhka","datePublished":"2025-03-20","dateModified":"2025-08-21","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/rastamozhka"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Растаможка авто","description":"Пошаговое руководство по использованию калькулятора: Растаможка авто","totalTime":"PT3M","step":[{"@type":"HowToStep","position":1,"name":"Выберите тип автомобиля","text":"Укажите, ввозите вы легковой автомобиль, грузовой или мотоцикл."},{"@type":"HowToStep","position":2,"name":"Укажите объём двигателя","text":"Введите объём двигателя в кубических сантиметрах."},{"@type":"HowToStep","position":3,"name":"Выберите год выпуска","text":"Укажите год выпуска транспортного средства."},{"@type":"HowToStep","position":4,"name":"Введите стоимость","text":"Укажите таможенную стоимость автомобиля в долларах или сумах."},{"@type":"HowToStep","position":5,"name":"Получите расчёт пошлин","text":"Нажмите «Рассчитать» — получите акциз, таможенную пошлину, НДС и общую сумму."}]}]11:["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1a"}}],"$L1b","$L1c"]}]
