2:T17e3,[{"@context":"https://schema.org","@type":"WebPage","name":"Калькулятор депозита","description":"Рассчитайте доход по банковскому вкладу в Узбекистане. Учитывает срок, ставку и капитализацию процентов.","url":"https://calk.uz/ru/calculator/depozit","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/depozit#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/depozit/opengraph-image"},"dateModified":"2026-02-26"},{"@context":"https://schema.org","@type":"WebApplication","name":"Калькулятор депозита","description":"Рассчитайте доход по банковскому вкладу в Узбекистане. Учитывает срок, ставку и капитализацию процентов.","url":"https://calk.uz/ru/calculator/depozit","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/depozit#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Депозиты","item":"https://calk.uz/ru/category/deposit"},{"@type":"ListItem","position":3,"name":"Калькулятор депозита","item":"https://calk.uz/ru/calculator/depozit"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Какие ставки по вкладам в сумах в 2026 году?","acceptedAnswer":{"@type":"Answer","text":"От 20% до 26% годовых в зависимости от банка и срока. Наиболее выгодные ставки — по срочным вкладам на 12-24 месяца."}},{"@type":"Question","name":"Облагаются ли проценты по вкладам налогом?","acceptedAnswer":{"@type":"Answer","text":"Да, проценты по депозитам облагаются НДФЛ по ставке 5% для резидентов (10% для нерезидентов). Банк удерживает налог автоматически при выплате процентов."}},{"@type":"Question","name":"Какая сумма гарантирована по вкладам?","acceptedAnswer":{"@type":"Answer","text":"До 200 000 000 сум на одного вкладчика в одном банке. Гарантируется Фондом гарантирования вкладов."}},{"@type":"Question","name":"Что такое капитализация процентов?","acceptedAnswer":{"@type":"Answer","text":"Начисление процентов на ранее начисленные проценты. При ежемесячной капитализации эффективная ставка выше номинальной (24% → 26,82%)."}},{"@type":"Question","name":"Какие ставки по валютным вкладам?","acceptedAnswer":{"@type":"Answer","text":"От 4% до 7% годовых в долларах/евро. Ниже, чем в сумах, но без валютного риска."}},{"@type":"Question","name":"Как выбрать лучший вклад?","acceptedAnswer":{"@type":"Answer","text":"Сравните ставки, учтите капитализацию, проверьте условия досрочного снятия и пополнения. Распределите средства между банками в пределах гарантии."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Калькулятор депозита","description":"Рассчитайте доход по банковскому вкладу в Узбекистане. Учитывает срок, ставку и капитализацию процентов.","url":"https://calk.uz/ru/calculator/depozit","datePublished":"2025-09-10","dateModified":"2026-02-26","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/depozit"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Калькулятор депозита","description":"Пошаговое руководство по использованию калькулятора: Калькулятор депозита","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите сумму вклада","text":"Укажите сумму, которую хотите разместить на депозит."},{"@type":"HowToStep","position":2,"name":"Укажите процентную ставку","text":"Введите годовую процентную ставку банка по вкладу."},{"@type":"HowToStep","position":3,"name":"Выберите срок вклада","text":"Укажите срок размещения депозита в месяцах."},{"@type":"HowToStep","position":4,"name":"Получите доходность","text":"Нажмите «Рассчитать» — узнайте сумму начисленных процентов и итоговую сумму."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
