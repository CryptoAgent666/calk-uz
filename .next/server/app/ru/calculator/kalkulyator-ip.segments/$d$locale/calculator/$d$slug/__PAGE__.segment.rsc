2:T1658,[{"@context":"https://schema.org","@type":"WebPage","name":"Калькулятор для ИП","description":"Рассчитайте налоги и отчисления для индивидуального предпринимателя в Узбекистане.","url":"https://calk.uz/ru/calculator/kalkulyator-ip","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/kalkulyator-ip#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/kalkulyator-ip/opengraph-image"},"dateModified":"2025-09-04"},{"@context":"https://schema.org","@type":"WebApplication","name":"Калькулятор для ИП","description":"Рассчитайте налоги и отчисления для индивидуального предпринимателя в Узбекистане.","url":"https://calk.uz/ru/calculator/kalkulyator-ip","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/kalkulyator-ip#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Бизнес","item":"https://calk.uz/ru/category/business"},{"@type":"ListItem","position":3,"name":"Калькулятор для ИП","item":"https://calk.uz/ru/calculator/kalkulyator-ip"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько налогов платит ИП в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"Налог с оборота 1% (при обороте до 1 млрд сум) или 4% (свыше 1 млрд) + социальный налог 412 000 сум/мес + ИНПС 0,1%."}},{"@type":"Question","name":"Чем ИП отличается от самозанятого?","acceptedAnswer":{"@type":"Answer","text":"ИП: 1% налог (до 1 млрд оборота), может нанимать до 10 работников. Самозанятый (с 2026): 1% налог, без работников, оборот до 1 млрд/год."}},{"@type":"Question","name":"Нужна ли ИП касса?","acceptedAnswer":{"@type":"Answer","text":"Да, ИП обязаны использовать ККТ или виртуальную кассу при приёме наличных и карточных платежей."}},{"@type":"Question","name":"Какой порог для уплаты НДС?","acceptedAnswer":{"@type":"Answer","text":"1 млрд сум за 12 месяцев. Ниже этого порога ИП не платит НДС."}},{"@type":"Question","name":"Как зарегистрировать ИП?","acceptedAnswer":{"@type":"Answer","text":"Через my.gov.uz или налоговую. Бесплатно, 1-3 дня. Нужен паспорт, ИНН выдаётся автоматически."}},{"@type":"Question","name":"Сколько работников может нанять ИП?","acceptedAnswer":{"@type":"Answer","text":"До 10 человек (с 2025 года — до 25 для отдельных видов деятельности)."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Калькулятор для ИП","description":"Рассчитайте налоги и отчисления для индивидуального предпринимателя в Узбекистане.","url":"https://calk.uz/ru/calculator/kalkulyator-ip","datePublished":"2025-04-03","dateModified":"2025-09-04","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/kalkulyator-ip"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Калькулятор для ИП","description":"Пошаговое руководство по использованию калькулятора: Калькулятор для ИП","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите выручку","text":"Укажите ожидаемую годовую или месячную выручку ИП."},{"@type":"HowT