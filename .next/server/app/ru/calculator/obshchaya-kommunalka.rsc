1b:T160b,[{"@context":"https://schema.org","@type":"WebPage","name":"Общая коммуналка","description":"Рассчитайте общую сумму коммунальных платежей за месяц. Все услуги ЖКХ в одном калькуляторе.","url":"https://calk.uz/ru/calculator/obshchaya-kommunalka","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/obshchaya-kommunalka#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/obshchaya-kommunalka/opengraph-image"},"dateModified":"2026-02-02"},{"@context":"https://schema.org","@type":"WebApplication","name":"Общая коммуналка","description":"Рассчитайте общую сумму коммунальных платежей за месяц. Все услуги ЖКХ в одном калькуляторе.","url":"https://calk.uz/ru/calculator/obshchaya-kommunalka","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/obshchaya-kommunalka#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Коммунальные","item":"https://calk.uz/ru/category/utilities"},{"@type":"ListItem","position":3,"name":"Общая коммуналка","item":"https://calk.uz/ru/calculator/obshchaya-kommunalka"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько в среднем стоят коммунальные услуги в Ташкенте?","acceptedAnswer":{"@type":"Answer","text":"2-комнатная квартира: 400 000-800 000 сум летом, 600 000-1 200 000 сум зимой. Частный дом: до 3 000 000 сум зимой."}},{"@type":"Question","name":"Какая услуга самая дорогая?","acceptedAnswer":{"@type":"Answer","text":"Зимой — газ (отопление), до 40% всех расходов. Летом — электроэнергия (кондиционер), 30-40%."}},{"@type":"Question","name":"Как снизить коммунальные платежи?","acceptedAnswer":{"@type":"Answer","text":"Счётчики (экономия до 50% на воде), утепление (30-50% на газе), LED-лампы (80% на свете), контроль потребления через приложения."}},{"@type":"Question","name":"Когда нужно оплачивать коммунальные услуги?","acceptedAnswer":{"@type":"Answer","text":"До 10-го числа месяца, следующего за расчётным. За просрочку — пеня."}},{"@type":"Question","name":"Как оплатить коммунальные услуги?","acceptedAnswer":{"@type":"Answer","text":"Через мобильные приложения (Click, Payme, Uzum), банковские терминалы, кассы. Самый удобный способ — автоплатёж в мобильном приложении."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Общая коммуналка","description":"Рассчитайте общую сумму коммунальных платежей за месяц. Все услуги ЖКХ в одном калькуляторе.","url":"https://calk.uz/ru/calculator/obshchaya-kommunalka","datePublished":"2025-03-13","dateModified":"2026-02-02","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/obshchaya-kommunalka"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Общая коммуналка","description":"Пошаговое руководство по использованию калькулятора: Общая коммуналка","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите показания счётчиков","text":"Укажите потребление электричества (кВт·ч), газа (м³) и воды (м³)."},{"@type":"HowToStep","position":2,"name":"Укажите площадь жилья","text":"Введите площадь квартиры для расчёта отопления и вывоза мусора."},{"@type":"HowToStep","position":3,"name":"Выберите тарифы","text":"Выберите применимые тарифы (бытовой, льготный)."},{"@type":"HowToStep","position":4,"name":"Получите общую сумму","text":"Нажмите «Рассчитать» — узнайте общую сумму коммунальных платежей за месяц."}]}]12:["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1b"}}],"$L1c","$L1d"]}]
