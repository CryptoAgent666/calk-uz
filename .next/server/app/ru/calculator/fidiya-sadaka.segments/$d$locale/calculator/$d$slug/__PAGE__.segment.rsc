2:T1394,[{"@context":"https://schema.org","@type":"WebPage","name":"Фидия садака","description":"Рассчитайте размер фидия садака — компенсации за пропущенные дни поста в Рамадан.","url":"https://calk.uz/ru/calculator/fidiya-sadaka","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/fidiya-sadaka#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/fidiya-sadaka/opengraph-image"},"dateModified":"2025-05-15"},{"@context":"https://schema.org","@type":"WebApplication","name":"Фидия садака","description":"Рассчитайте размер фидия садака — компенсации за пропущенные дни поста в Рамадан.","url":"https://calk.uz/ru/calculator/fidiya-sadaka","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/fidiya-sadaka#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Религия","item":"https://calk.uz/ru/category/religion"},{"@type":"ListItem","position":3,"name":"Фидия садака","item":"https://calk.uz/ru/calculator/fidiya-sadaka"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько фидия-садака за один день?","acceptedAnswer":{"@type":"Answer","text":"30 000-50 000 сум — стоимость одного полноценного приёма пищи. Зависит от региона Узбекистана."}},{"@type":"Question","name":"Кто обязан платить фидию?","acceptedAnswer":{"@type":"Answer","text":"Те, кто постоянно не может поститься: хронические больные (диабет, онкология), пожилые. Временно больные — восполняют пост (казо)."}},{"@type":"Question","name":"Сколько за весь Рамадан?","acceptedAnswer":{"@type":"Answer","text":"30 дней × ~40 000 сум = ~1 200 000 сум. Минимальный расчёт по рису: ~337 500 сум."}},{"@type":"Question","name":"Чем фидия отличается от каффары?","acceptedAnswer":{"@type":"Answer","text":"Фидия — за невозможность поста. Каффара — за намеренное нарушение (60 дней поста или кормление 60 бедных)."}},{"@type":"Question","name":"Куда передать фидию в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"Через мечети, ифтар-хайрия, фонд Вакф (vaqf.uz) или напрямую нуждающимся."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Фидия садака","description":"Рассчитайте размер фидия садака — компенсации за пропущенные дни поста в Рамадан.","url":"https://calk.uz/ru/calculator/fidiya-sadaka","datePublished":"2025-01-20","dateModified":"2025-05-15","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/fidiya-sadaka"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Фидия садака","description":"Пошаговое руководство по использованию калькулятора: Фидия садака","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Укажите количество дней","text":"Введите число пропущенных дней поста."},{"@type":"HowToStep","position":2,"name":"Выберите продукт","text":"Укажите продукт для расчёта фидия-садака."},{"@type":"HowToStep","position":3,"name":"Получите расчёт","text":"Нажмите «Рассчитать» — узнайте общую сумму фидия-садака."}]}]0:{"rsc":["$","$1