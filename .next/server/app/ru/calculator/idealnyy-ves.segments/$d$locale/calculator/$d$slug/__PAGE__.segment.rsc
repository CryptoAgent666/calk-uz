2:T1441,[{"@context":"https://schema.org","@type":"WebPage","name":"Идеальный вес","description":"Рассчитайте идеальный вес по нескольким формулам. Учитывает рост, возраст и тип телосложения.","url":"https://calk.uz/ru/calculator/idealnyy-ves","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/idealnyy-ves#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/idealnyy-ves/opengraph-image"},"dateModified":"2025-06-10"},{"@context":"https://schema.org","@type":"WebApplication","name":"Идеальный вес","description":"Рассчитайте идеальный вес по нескольким формулам. Учитывает рост, возраст и тип телосложения.","url":"https://calk.uz/ru/calculator/idealnyy-ves","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/idealnyy-ves#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Здоровье","item":"https://calk.uz/ru/category/health"},{"@type":"ListItem","position":3,"name":"Идеальный вес","item":"https://calk.uz/ru/calculator/idealnyy-ves"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Как рассчитать идеальный вес?","acceptedAnswer":{"@type":"Answer","text":"По формулам Брока, Лоренца, Девайна или через ИМТ 18,5-24,9. Калькулятор использует все методы и показывает средний результат."}},{"@type":"Question","name":"Какой вес нормальный для роста 170 см?","acceptedAnswer":{"@type":"Answer","text":"Мужчина: 59-72 кг (оптимум 63-68 кг). Женщина: 53-68 кг (оптимум 56-62 кг). По ИМТ 18,5-24,9."}},{"@type":"Question","name":"Одинаков ли идеальный вес для мужчин и женщин?","acceptedAnswer":{"@type":"Answer","text":"Нет, при одинаковом росте мужчина весит на 5-10 кг больше за счёт мышечной массы и костной структуры."}},{"@type":"Question","name":"Какая формула самая точная?","acceptedAnswer":{"@type":"Answer","text":"Формула ВОЗ (ИМТ) — наиболее универсальна. Для более точного результата используйте среднее всех формул."}},{"@type":"Question","name":"Каков средний рост в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"Мужчины — около 172 см, женщины — около 160 см. Идеальный вес: мужчины 63-72 кг, женщины 52-60 кг."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Идеальный вес","description":"Рассчитайте идеальный вес по нескольким формулам. Учитывает рост, возраст и тип телосложения.","url":"https://calk.uz/ru/calculator/idealnyy-ves","datePublished":"2025-03-12","dateModified":"2025-06-10","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/idealnyy-ves"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Идеальный вес","description":"Пошаговое руководство по использованию калькулятора: Идеальный вес","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Введите рост","text":"Укажите ваш рост в сантиметрах."},{"@type":"HowToStep","position":2,"name":"Выберите пол и возраст","text":"Укажите пол и возраст для точного расчёта."},{"@type":"HowToStep","position":3,"name":"Получите результат