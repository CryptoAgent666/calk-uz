2:T1592,[{"@context":"https://schema.org","@type":"WebPage","name":"Калькулятор закята","description":"Рассчитайте размер закята — обязательного ежегодного пожертвования в исламе. 2.5% от нисаба.","url":"https://calk.uz/ru/calculator/zakat","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/zakat#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/zakat/opengraph-image"},"dateModified":"2025-09-10"},{"@context":"https://schema.org","@type":"WebApplication","name":"Калькулятор закята","description":"Рассчитайте размер закята — обязательного ежегодного пожертвования в исламе. 2.5% от нисаба.","url":"https://calk.uz/ru/calculator/zakat","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/zakat#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Религия","item":"https://calk.uz/ru/category/religion"},{"@type":"ListItem","position":3,"name":"Калькулятор закята","item":"https://calk.uz/ru/calculator/zakat"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько составляет закят?","acceptedAnswer":{"@type":"Answer","text":"2,5% от имущества, превышающего нисаб (стоимость 85 г золота ≈ 70 млн сум), которым владели полный лунный год."}},{"@type":"Question","name":"Что такое нисаб и как его определить?","acceptedAnswer":{"@type":"Answer","text":"Нисаб — минимальный порог: стоимость 85 г золота (~$5 500 или ~70 млн сум в 2025–2026 году). Если ваши активы ниже, закят не обязателен."}},{"@type":"Question","name":"С какого имущества платится закят?","acceptedAnswer":{"@type":"Answer","text":"Деньги (включая электронные кошельки), вклады, золото/серебро, товарные запасы, акции. Не включается жильё, транспорт и личные вещи."}},{"@type":"Question","name":"Куда в Узбекистане можно передать закят?","acceptedAnswer":{"@type":"Answer","text":"Через мечети, фонд Вакф (vaqf.uz), благотворительные организации или напрямую нуждающимся из 8 категорий получателей."}},{"@type":"Question","name":"Когда лучше всего выплачивать закят?","acceptedAnswer":{"@type":"Answer","text":"Рекомендуется в Рамадан (награда умножается), но обязательного срока нет — главное выплатить после истечения хавля (лунного года владения)."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Калькулятор закята","description":"Рассчитайте размер закята — обязательного ежегодного пожертвования в исламе. 2.5% от нисаба.","url":"https://calk.uz/ru/calculator/zakat","datePublished":"2025-05-06","dateModified":"2025-09-10","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/zakat"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Калькулятор закята","description":"Пошаговое руководство по использованию калькулятора: Калькулятор закята","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите имущество","text":"Укажите общую стоимость имущества, подлежащего закяту (деньги, золото, товар)."},{"@type":"HowToStep","position":2,"name":"Укажите долги","text":"Введите сумму текущих долгов для вычета из базы закята."},{"@type":"HowToStep","position":3,"name":"Получите расчёт закята","text":"Нажмите «Рассчитать» — узнайте, достигнут ли нисаб и сумму закята (2,5%)."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
