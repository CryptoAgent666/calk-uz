20:["$","$L45",null,{"formats":"$undefined","locale":"ru","messages":{"site_name":"Calk.UZ","site_tagline":"Онлайн калькуляторы для Узбекистана","site_description":"Удобные и точные онлайн-калькуляторы для налогов, зарплат, кредитов, вкладов и других финансовых расчётов в Узбекистане","nav_home":"Главная","nav_tax":"Налоги","nav_salary":"Зарплата","nav_credit":"Кредиты","nav_deposit":"Вклады","nav_currency":"Валюта","nav_auto":"Авто","nav_utilities":"Коммунальные услуги","nav_realestate":"Недвижимость","nav_business":"Бизнес","nav_health":"Здоровье","nav_education":"Образование","nav_religion":"Религия","nav_tools":"Инструменты","nav_about":"О нас","nav_contact":"Контакты","hero_title":"Онлайн-калькуляторы для Узбекистана","hero_subtitle":"Быстрые и точные расчёты","hero_description":"Рассчитайте налоги, зарплату, кредиты, вклады и многое другое с помощью наших бесплатных калькуляторов, адаптированных для Узбекистана","hero_search_placeholder":"Найти калькулятор...","calculator_open":"Открыть калькулятор","calculator_calculate":"Рассчитать","calculator_clear":"Очистить","calculator_result":"Результат","calculator_details":"Подробности расчёта","category_all":"Все калькуляторы","category_tax":"Налоги","category_salary":"Зарплата","category_credit":"Кредиты","category_deposit":"Вклады","category_currency":"Валюта","category_auto":"Авто","category_utilities":"Коммунальные услуги","category_realestate":"Недвижимость","category_business":"Бизнес","category_health":"Здоровье","category_education":"Образование","category_religion":"Религия","category_tools":"Инструменты","category_unique":"Уникальные","common_sum":"Сумма","common_currency":"Валюта","common_percent":"Процент","common_months":"Месяцы","common_years":"Годы","common_per_month":"в месяц","common_per_year":"в год","common_total":"Итого","common_loading":"Загрузка...","footer_description":"Calk.UZ — бесплатные онлайн-калькуляторы для жителей Узбекистана. Точные расчёты по актуальным ставкам и тарифам.","footer_quick_links":"Быстрые ссылки","footer_categories":"Категории","footer_legal":"Правовая информация","footer_privacy":"Политика конфиденциальности","footer_terms":"Условия использования","footer_disclaimer":"Результаты расчётов носят информационный характер и не являются юридической или финансовой консультацией.","footer_not_government":"Calk.UZ не является государственным сервисом и не связан с государственными органами Республики Узбекистан.","disclaimer_not_government_title":"Важная информация","disclaimer_not_government_text":"Calk.UZ — независимый информационный проект, созданный частными разработчиками. Приложение НЕ является государственным сервисом и НЕ связано с государственными органами Республики Узбекистан. Все расчёты носят справочный характер, основаны на открытых данных из официальных источников (cbu.uz, lex.uz, stat.uz) и не являются финансовой или юридической консультацией. Для принятия финансовых решений рекомендуем обращаться к квалифицированным специалистам.","footer_copyright":"© {year} Calk.UZ. Все права защищены.","theme_light":"Светлая","theme_dark":"Тёмная","theme_system":"Системная","language_ru":"Русский","language_uz":"O'zbek","breadcrumb_home":"Главная","error_404_title":"Страница не найдена","error_404_description":"Запрашиваемая страница не существует или была перемещена.","error_404_back":"Вернуться на главную","related_calculators":"Похожие калькуляторы","no_results_title":"Калькуляторы не найдены","no_results_description":"Попробуйте изменить запрос или фильтр","about_title":"О сайте Calk.UZ","about_description":"Calk.UZ — бесплатные онлайн-калькуляторы для жителей Узбекистана","about_mission":"Наша миссия — сделать финансовые расчёты простыми и доступными для каждого жителя Узбекистана.","about_features_title":"Наши преимущества","about_feature_calculators":"78 бесплатных калькуляторов","about_feature_bilingual":"Двуязычный интерфейс (русский и узбекский)","about_feature_accurate":"Актуальные ставки и тарифы Узбекистана","about_feature_mobile":"Оптимизация для мобильных устройств","about_feature_dark":"Тёмная тема для комфортной работы","about_feature_free":"Полностью бесплатно, без регистрации","contact_title":"Контакты","contact_description":"Свяжитесь с командой Calk.UZ — мы отвечаем на вопросы, принимаем предложения и исправляем ошибки","contact_email":"Электронная почта","contact_telegram":"Telegram","contact_feedback":"Если вы нашли ошибку в расчётах, хотите предложить новый калькулятор или у вас есть вопросы по работе сайта — напишите нам. Мы обычно отвечаем в течение 24 часов.","contact_when_title":"По каким вопросам можно обращаться","contact_when_error":"Обнаружили неточность в расчётах или устаревшие данные","contact_when_suggest":"Хотите предложить новый калькулятор или функцию","contact_when_question":"Есть вопросы по использованию калькуляторов","contact_when_cooperation":"Предложения по сотрудничеству или партнёрству","contact_faq_title":"Частые вопросы","contact_faq_accuracy_q":"Насколько точны результаты калькуляторов?","contact_faq_accuracy_a":"Все калькуляторы основаны на действующем законодательстве Узбекистана. Ставки обновляются ежеквартально. Однако результаты носят информационный характер — для официальных расчётов обращайтесь к специалистам.","contact_faq_update_q":"Как часто обновляются данные?","contact_faq_update_a":"Ставки и тарифы обновляются ежеквартально или при вступлении в силу новых нормативных актов. Мы мониторим lex.uz, cbu.uz, stat.uz и другие официальные источники.","contact_faq_new_q":"Можно ли предложить новый калькулятор?","contact_faq_new_a":"Да! Мы регулярно добавляем новые калькуляторы по запросам пользователей. Напишите нам на info@calk.uz или в Telegram @calkuz_bot с описанием нужного калькулятора.","contact_response_time":"Обычно отвечаем в течение 24 часов","privacy_title":"Политика конфиденциальности","terms_title":"Условия использования","more_dropdown":"Ещё","mobile_menu_title":"Навигация","calculator_count_badge":"78 бесплатных калькуляторов","results_count":"Найдено {count} калькуляторов","no_results":"Ничего не найдено","no_results_hint":"Попробуйте изменить запрос или выбрать другую категорию","related_title":"Похожие калькуляторы","calculator_about":"О калькуляторе","coming_soon":"Калькулятор скоро будет готов","coming_soon_hint":"Мы работаем над этим калькулятором. Скоро он будет доступен.","back_to_home":"Вернуться на главную","article_heading":"Как пользоваться калькулятором","faq_heading":"Часто задаваемые вопросы","see_also":"Смотрите также","category_page_title":"{category} — онлайн калькуляторы | Calk.UZ","category_page_description":"Бесплатные онлайн калькуляторы в категории «{category}» для жителей Узбекистана. Точные расчёты по актуальным ставкам.","category_calculators_count":"{count} калькуляторов","category_open_calculator":"Открыть","all_categories":"Все категории","methodology_title":"Методология расчётов","methodology_description":"Узнайте, как мы обеспечиваем точность расчётов на Calk.UZ","methodology_intro_title":"Как мы обеспечиваем точность","methodology_intro_p1":"Все калькуляторы на Calk.UZ разработаны на основе действующего законодательства Республики Узбекистан. Формулы расчётов основаны на нормах Налогового кодекса, Трудового кодекса, постановлений Кабинета Министров и нормативных актов Центрального банка.","methodology_intro_p2":"Мы регулярно отслеживаем изменения в законодательстве и обновляем ставки, тарифы и формулы расчётов, чтобы обеспечить актуальность и точность результатов.","methodology_formulas_title":"Как формируются формулы","methodology_formulas_p1":"Налоговые калькуляторы основаны на статьях Налогового кодекса Республики Узбекистан (в частности, главы по НДФЛ, НДС, налогу на прибыль, единому налоговому платежу). Ставки и пороги обновляются в соответствии с ежегодными постановлениями Президента и Кабинета Министров.","methodology_formulas_p2":"Кредитные и депозитные калькуляторы используют стандартные финансовые формулы (аннуитетный и дифференцированный расчёт), а процентные ставки ориентированы на данные Центрального банка Республики Узбекистан.","methodology_formulas_p3":"Калькуляторы коммунальных услуг используют тарифы, утверждённые соответствующими регуляторными органами. Зарплатные калькуляторы учитывают все обязательные отчисления согласно Трудовому кодексу.","methodology_rates_title":"Как обновляются ставки","methodology_rates_p1":"Ставки и тарифы обновляются ежеквартально или при вступлении в силу новых нормативных актов. Мы мониторим следующие источники:","methodology_rates_source_lex":"lex.uz — Национальная база данных законодательства","methodology_rates_source_cbu":"cbu.uz — Центральный банк Республики Узбекистан","methodology_rates_source_gazeta":"gazeta.uz — Новости и аналитика законодательных изменений","methodology_verification_title":"Верификация данных","methodology_verification_p1":"Каждый калькулятор проходит проверку: результаты сверяются с примерами из официальных источников, методических пособий и разъяснений государственных органов. При обнаружении расхождений формула корректируется.","methodology_verification_date":"Последняя проверка данных: март 2026","methodology_contact_title":"Нашли ошибку?","methodology_contact_p1":"Если вы обнаружили неточность в расчётах или устаревшие данные, пожалуйста, сообщите нам по адресу info@calk.uz или через Telegram @calkuz_bot. Мы оперативно проверим и исправим информацию.","about_mission_p1":"Calk.UZ создан для того, чтобы каждый житель Узбекистана мог быстро и точно рассчитать налоги, зарплату, кредитные платежи, коммунальные услуги и другие финансовые показатели. Мы понимаем, что финансовая грамотность начинается с доступа к надёжным инструментам расчёта, и наша цель — предоставить такие инструменты бесплатно, без регистрации и ограничений.","about_mission_p2":"Наша команда постоянно работает над расширением функционала и повышением точности калькуляторов. Мы следим за изменениями в законодательстве Узбекистана, обновляем ставки и тарифы, а также добавляем новые калькуляторы по запросам пользователей. Calk.UZ — это не просто набор калькуляторов, а полноценная платформа финансовых расчётов для Узбекистана.","about_methodology_title":"Как мы обеспечиваем точность","about_methodology_p1":"Все формулы расчётов на Calk.UZ основаны на действующем законодательстве Республики Узбекистан: Налоговом кодексе, Трудовом кодексе, постановлениях Кабинета Министров и нормативных актах регуляторных органов. Ставки и тарифы обновляются ежеквартально.","about_methodology_p2":"Результаты расчётов сверяются с официальными источниками и методическими материалами. При изменении законодательства калькуляторы обновляются в кратчайшие сроки.","about_editorial_title":"Редакционная политика","about_editorial_p1":"Контент сайта проверяется специалистами в области финансов, знакомыми с налоговой и банковской системой Узбекистана. Каждый калькулятор проходит многоэтапную проверку перед публикацией.","about_sources_title":"Источники данных","about_source_lex":"lex.uz — Национальная база данных законодательства Республики Узбекистан","about_source_cbu":"cbu.uz — Центральный банк: курсы валют, ставка рефинансирования","about_source_stat":"stat.uz — Государственный комитет статистики: экономические показатели","about_source_mf":"imv.uz — Министерство экономики и финансов: бюджетные данные и нормативы","about_team_title":"Кто стоит за проектом","about_team_p1":"Calk.UZ создан и поддерживается командой разработчиков и финансовых специалистов, имеющих опыт работы с налоговой и банковской системой Узбекистана. Мы объединяем технические знания и понимание местного законодательства, чтобы создавать точные и удобные инструменты расчёта.","about_team_p2":"Проект развивается с 2025 года и постоянно расширяется благодаря обратной связи от пользователей — бухгалтеров, предпринимателей и обычных граждан.","about_audience_title":"Для кого создан Calk.UZ","about_audience_accountants":"Бухгалтеры и финансисты — для оперативной проверки расчётов по налогам и зарплатам","about_audience_entrepreneurs":"Предприниматели и ИП — для планирования налоговой нагрузки и кредитных платежей","about_audience_citizens":"Обычные граждане — для расчёта коммунальных платежей, кредитов, вкладов и конвертации валют","about_audience_students":"Студенты — для изучения финансовых расчётов на практических примерах Узбекистана","about_stats_title":"Calk.UZ в цифрах","about_stats_calculators":"78 калькуляторов","about_stats_categories":"14 категорий","about_stats_updates":"Обновляется ежеквартально","about_stats_languages":"2 языка интерфейса","home_intro_title":"Финансовые калькуляторы для Узбекистана","home_intro_p1":"Calk.UZ — крупнейшая платформа бесплатных финансовых калькуляторов для жителей Узбекистана. Все 78 калькуляторов работают на основе действующего законодательства: Налогового кодекса, Трудового кодекса, ставок Центрального банка и утверждённых тарифов. Результаты обновляются ежеквартально.","home_intro_p2":"Рассчитайте НДФЛ, НДС, зарплату, кредитные платежи, коммунальные услуги, стоимость растаможки автомобиля и многое другое — бесплатно, без регистрации, на русском и узбекском языках. Данные берутся из официальных источников: lex.uz, cbu.uz, stat.uz.","cookie_message":"Этот сайт использует файлы cookie для аналитики и улучшения работы.","cookie_accept":"Принять","cookie_decline":"Отклонить","last_updated":"Последнее обновление","sources_title":"Источники","reviewed_by":"Проверено редакцией Calk.UZ","article_h3_how_it_works":"Как работает калькулятор","article_h3_formula":"Формула расчёта","article_h3_example":"Пример расчёта","article_h3_considerations":"Что учитывать","article_h3_tips":"Полезные советы","article_tables_heading":"Справочные данные и тарифы","footer_data_verified":"Данные проверены по официальным источникам","footer_methodology":"Методология","howto_heading":"Как пользоваться","howto_step":"Шаг","howto_time":"Время расчёта","howto_minutes":"мин."},"now":"$undefined","timeZone":"UTC","children":["$L46","$L47","$L48","$L49","$L4a","$L4b","$L4c","$L4d","$L4e"]}]
