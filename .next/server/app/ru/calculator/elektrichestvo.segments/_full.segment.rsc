1a:T1623,[{"@context":"https://schema.org","@type":"WebPage","name":"Электроэнергия","description":"Рассчитайте стоимость электроэнергии по тарифам Узбекистана. Учитывает 6 ступеней потребления.","url":"https://calk.uz/ru/calculator/elektrichestvo","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/elektrichestvo#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/elektrichestvo/opengraph-image"},"dateModified":"2026-03-29"},{"@context":"https://schema.org","@type":"WebApplication","name":"Электроэнергия","description":"Рассчитайте стоимость электроэнергии по тарифам Узбекистана. Учитывает 6 ступеней потребления.","url":"https://calk.uz/ru/calculator/elektrichestvo","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/elektrichestvo#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Коммунальные","item":"https://calk.uz/ru/category/utilities"},{"@type":"ListItem","position":3,"name":"Электроэнергия","item":"https://calk.uz/ru/calculator/elektrichestvo"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько стоит электроэнергия в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"По 6-ступенчатой шкале: от 600 сум/кВт·ч (до 200 кВт·ч) до 2 000 сум/кВт·ч (свыше 10 000 кВт·ч). Чем больше потребление, тем дороже."}},{"@type":"Question","name":"Как рассчитать стоимость электроэнергии?","acceptedAnswer":{"@type":"Answer","text":"Потребление разбивается по ступеням: первые 200 кВт·ч по 600 сум, следующие 300 по 800 сум и т.д. Наш калькулятор сделает это автоматически."}},{"@type":"Question","name":"Какое среднее потребление электроэнергии в квартире?","acceptedAnswer":{"@type":"Answer","text":"Для 2-комнатной квартиры: 200-400 кВт·ч летом, 300-600 кВт·ч зимой (с электрообогревом). Средний счёт: 150 000 - 500 000 сум."}},{"@type":"Question","name":"Почему тарифы ступенчатые?","acceptedAnswer":{"@type":"Answer","text":"Для стимулирования энергосбережения. Базовое потребление (до 200 кВт·ч) оплачивается по низкому тарифу, избыточное — по повышенному."}},{"@type":"Question","name":"Как снизить расходы на электроэнергию?","acceptedAnswer":{"@type":"Answer","text":"LED-лампы (экономия 80%), таймеры, утепление, солнечные панели. Стремитесь удержать потребление в пределах 500 кВт·ч для тарифов 1-2 ступеней."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Электроэнергия","description":"Рассчитайте стоимость электроэнергии по тарифам Узбекистана. Учитывает 6 ступеней потребления.","url":"https://calk.uz/ru/calculator/elektrichestvo","datePublished":"2025-07-23","dateModified":"2026-03-29","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/elektrichestvo"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Электроэнергия","description":"Пошаговое руководство по использованию калькулятора: Электроэнергия","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Введите потребление","text":"Укажите количество потреблённых киловатт-часов (кВт·ч) за месяц."},{"@type":"HowToStep","position":2,"name":"Выберите тариф","text":"Выберите тип тарифа (бытовой, льготный, с газовой плитой / электроплитой)."},{"@type":"HowToStep","position":3,"name":"Получите сумму оплаты","text":"Нажмите «Рассчитать» и узнайте сумму к оплате за электричество."}]}]11:["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1a"}}],"$L1b","$L1c"]}]
