2:T1623,[{"@context":"https://schema.org","@type":"WebPage","name":"Транспортный налог","description":"Рассчитайте транспортный налог на автомобиль в Узбекистане. Зависит от объёма двигателя и года выпуска.","url":"https://calk.uz/ru/calculator/transportnyy-nalog","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/transportnyy-nalog#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/transportnyy-nalog/opengraph-image"},"dateModified":"2026-02-26"},{"@context":"https://schema.org","@type":"WebApplication","name":"Транспортный налог","description":"Рассчитайте транспортный налог на автомобиль в Узбекистане. Зависит от объёма двигателя и года выпуска.","url":"https://calk.uz/ru/calculator/transportnyy-nalog","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/transportnyy-nalog#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Налоги","item":"https://calk.uz/ru/category/tax"},{"@type":"ListItem","position":3,"name":"Транспортный налог","item":"https://calk.uz/ru/calculator/transportnyy-nalog"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько стоит транспортный налог?","acceptedAnswer":{"@type":"Answer","text":"Легковые авто: 1,5-7,5 БРВ (618 000 − 3 090 000 сум) в зависимости от объёма двигателя. Мотоциклы — 0,5 БРВ (206 000)."}},{"@type":"Question","name":"Облагаются ли электромобили?","acceptedAnswer":{"@type":"Answer","text":"Да, с 2026 года электромобили облагаются транспортным налогом — действовавшее освобождение истекло 31.12.2025 и не было продлено. Гибриды — 50% от базовой ставки."}},{"@type":"Question","name":"Когда нужно платить?","acceptedAnswer":{"@type":"Answer","text":"Равными долями до 15 апреля и 15 октября текущего года. Оплата через my.soliq.uz, Click, Payme или банковские терминалы."}},{"@type":"Question","name":"Как определяется объём двигателя для налога?","acceptedAnswer":{"@type":"Answer","text":"По данным техпаспорта (свидетельства о регистрации). Турбированные двигатели учитываются по фактическому объёму, а не по мощности."}},{"@type":"Question","name":"Нужно ли платить налог при продаже авто?","acceptedAnswer":{"@type":"Answer","text":"Продавец платит за текущий год. Покупатель — пропорционально оставшимся месяцам."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Транспортный налог","description":"Рассчитайте транспортный налог на автомобиль в Узбекистане. Зависит от объёма двигателя и года выпуска.","url":"https://calk.uz/ru/calculator/transportnyy-nalog","datePublished":"2025-01-19","dateModified":"2026-02-26","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/transportnyy-nalog"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Транспортный налог","description":"Пошаговое руководство по использованию калькулятора: Транспортный налог","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Выберите тип ТС","text":"Укажите тип транспортного средства."},{"@type":"HowToStep","position":2,"name":"Введите объём двигателя","text":"Укажите объём двигателя в кубических сантиметрах."},{"@type":"HowToStep","position":3,"name":"Выберите год выпуска","text":"Укажите год выпуска автомобиля."},{"@type":"HowToStep","position":4,"name":"Получите расчёт налога","text":"Нажмите «Рассчитать» — узнайте годовой транспортный налог."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
