2:T146d,[{"@context":"https://schema.org","@type":"WebPage","name":"Газ","description":"Рассчитайте стоимость природного газа для дома. Зимние и летние тарифы Узбекистана.","url":"https://calk.uz/ru/calculator/gaz","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/gaz#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/gaz/opengraph-image"},"dateModified":"2026-02-04"},{"@context":"https://schema.org","@type":"WebApplication","name":"Газ","description":"Рассчитайте стоимость природного газа для дома. Зимние и летние тарифы Узбекистана.","url":"https://calk.uz/ru/calculator/gaz","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/gaz#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Коммунальные","item":"https://calk.uz/ru/category/utilities"},{"@type":"ListItem","position":3,"name":"Газ","item":"https://calk.uz/ru/calculator/gaz"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько стоит газ в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"Базовая ставка — 1 000 сум/м³ в пределах социальной нормы (до 100 м³/мес летом, до 500 м³/мес зимой). При превышении нормы — повышенный тариф."}},{"@type":"Question","name":"Сколько газа потребляет частный дом?","acceptedAnswer":{"@type":"Answer","text":"С газовым отоплением: 2 000-4 000 м³/год. Без отопления (только плита): 300-800 м³/год. Основное потребление — зимой."}},{"@type":"Question","name":"Как рассчитывается оплата за газ?","acceptedAnswer":{"@type":"Answer","text":"По системе социальных норм: в пределах месячной нормы (100 м³ летом / 500 м³ зимой) — базовая ставка 1 000 сум/м³; сверх нормы — повышенный тариф."}},{"@type":"Question","name":"Сколько платить за газ зимой?","acceptedAnswer":{"@type":"Answer","text":"Для дома с отоплением: 300-500 м³/мес × 2 000-2 500 сум = 600 000-1 250 000 сум/мес зимой. Летом: 20-50 м³ × 1 000 сум = 20 000-50 000 сум."}},{"@type":"Question","name":"Как сэкономить на газе?","acceptedAnswer":{"@type":"Answer","text":"Утепление стен и окон (30-50% экономия), программируемый термостат, регулярное обслуживание котла, конденсационный котёл (КПД 95%)."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Газ","description":"Рассчитайте стоимость природного газа для дома. Зимние и летние тарифы Узбекистана.","url":"https://calk.uz/ru/calculator/gaz","datePublished":"2025-03-23","dateModified":"2026-02-04","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/gaz"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Газ","description":"Пошаговое руководство по использованию калькулятора: Газ","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Введите потребление газа","text":"Укажите объём потреблённого газа в кубометрах (м³) за месяц."},{"@type":"HowToStep","position":2,"name":"Выберите тариф","text":"Выберите тип тарифа (бытовой, с отоплением / без отопления)."},{"@type":"HowToStep","position"