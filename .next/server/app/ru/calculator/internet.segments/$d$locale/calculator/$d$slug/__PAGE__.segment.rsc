2:T13dd,[{"@context":"https://schema.org","@type":"WebPage","name":"Интернет","description":"Сравните тарифы интернет-провайдеров Узбекистана. Найдите оптимальный тариф по скорости и цене.","url":"https://calk.uz/ru/calculator/internet","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/internet#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/internet/opengraph-image"},"dateModified":"2025-09-05"},{"@context":"https://schema.org","@type":"WebApplication","name":"Интернет","description":"Сравните тарифы интернет-провайдеров Узбекистана. Найдите оптимальный тариф по скорости и цене.","url":"https://calk.uz/ru/calculator/internet","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/internet#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Коммунальные","item":"https://calk.uz/ru/category/utilities"},{"@type":"ListItem","position":3,"name":"Интернет","item":"https://calk.uz/ru/calculator/internet"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько стоит домашний интернет?","acceptedAnswer":{"@type":"Answer","text":"От 79 000 сум (30 Мбит/с) до 449 000 сум (1 Гбит/с) в месяц. Uztelecom GPON: от 89 000 (50 Мбит/с)."}},{"@type":"Question","name":"Какой интернет самый быстрый?","acceptedAnswer":{"@type":"Answer","text":"GPON-оптика (Uztelecom, TuronTelecom): до 1 Гбит/с. 5G (пилот в Ташкенте): до 1 Гбит/с. Мобильный 4G: до 150 Мбит/с."}},{"@type":"Question","name":"Какую скорость выбрать?","acceptedAnswer":{"@type":"Answer","text":"Соцсети: 30 Мбит/с (~80 000 сум). Стриминг 4K: 100+ Мбит/с (~150 000). Работа из дома: 50-100 Мбит/с. Геймерам: 100+ Мбит/с."}},{"@type":"Question","name":"Есть ли 5G в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"Да, 5G запущен в пилотном режиме в центре Ташкента. Коммерческие тарифы от 200 000 сум/мес. Массовое покрытие ожидается в 2026 году."}},{"@type":"Question","name":"Как оплатить интернет?","acceptedAnswer":{"@type":"Answer","text":"Через Click, Payme, Uzum, банковские терминалы, в офисах провайдеров или настроить автоплатёж."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Интернет","description":"Сравните тарифы интернет-провайдеров Узбекистана. Найдите оптимальный тариф по скорости и цене.","url":"https://calk.uz/ru/calculator/internet","datePublished":"2025-09-24","dateModified":"2025-09-05","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/internet"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Интернет","description":"Пошаговое руководство по использованию калькулятора: Интернет","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Выберите провайдера","text":"Выберите интернет-провайдера из списка (Uztelecom, Turon и др.)."},{"@type":"HowToStep","position":2,"name":"Укажите параметры","text":"Выберите желаемую скорость интернета и объём трафика."},{"@type":"HowToStep","position":3,"name":"Получите расчёт","te