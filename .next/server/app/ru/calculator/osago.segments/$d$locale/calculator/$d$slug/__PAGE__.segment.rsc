2:T14e1,[{"@context":"https://schema.org","@type":"WebPage","name":"ОСАГО калькулятор","description":"Рассчитайте стоимость полиса ОСАГО в Узбекистане. Учитывает регион, стаж и мощность двигателя.","url":"https://calk.uz/ru/calculator/osago","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/osago#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/osago/opengraph-image"},"dateModified":"2026-01-14"},{"@context":"https://schema.org","@type":"WebApplication","name":"ОСАГО калькулятор","description":"Рассчитайте стоимость полиса ОСАГО в Узбекистане. Учитывает регион, стаж и мощность двигателя.","url":"https://calk.uz/ru/calculator/osago","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/osago#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Авто","item":"https://calk.uz/ru/category/auto"},{"@type":"ListItem","position":3,"name":"ОСАГО калькулятор","item":"https://calk.uz/ru/calculator/osago"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько стоит ОСАГО в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"От 65 000 сум (базовый тариф). С учётом коэффициентов: в Ташкенте для опытного водителя — около 94 000 сум/год, для новичка — до 199 000 сум/год."}},{"@type":"Question","name":"Какой штраф за езду без ОСАГО?","acceptedAnswer":{"@type":"Answer","text":"От 5 до 10 БРВ (2 060 000 − 4 120 000 сум при БРВ 412 000 сум)."}},{"@type":"Question","name":"Какая максимальная выплата по ОСАГО?","acceptedAnswer":{"@type":"Answer","text":"За вред здоровью — до 52 млн сум. За вред имуществу — до 28 млн сум (общий лимит 80 млн)."}},{"@type":"Question","name":"Что такое коэффициент бонус-малус?","acceptedAnswer":{"@type":"Answer","text":"Скидка за безаварийную езду: от 0,5 (5+ лет без ДТП — 50% скидка) до 2,5 (частые ДТП — надбавка 150%)."}},{"@type":"Question","name":"Можно ли оформить ОСАГО онлайн?","acceptedAnswer":{"@type":"Answer","text":"Да, полис ОСАГО можно приобрести онлайн через сайты страховых компаний."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"ОСАГО калькулятор","description":"Рассчитайте стоимость полиса ОСАГО в Узбекистане. Учитывает регион, стаж и мощность двигателя.","url":"https://calk.uz/ru/calculator/osago","datePublished":"2025-09-13","dateModified":"2026-01-14","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/osago"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: ОСАГО калькулятор","description":"Пошаговое руководство по использованию калькулятора: ОСАГО калькулятор","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Выберите тип ТС","text":"Укажите тип транспортного средства (легковой, грузовой, автобус)."},{"@type":"HowToStep","position":2,"name":"Укажите регион регистрации","text":"Выберите область регистрации автомобиля в Узбекистане."},{"@type":"HowToStep","position":3,"name":"Введите данные водителей","text":"Укажите возраст и стаж вод