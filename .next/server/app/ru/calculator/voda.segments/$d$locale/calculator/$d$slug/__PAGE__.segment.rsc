2:T1394,[{"@context":"https://schema.org","@type":"WebPage","name":"Вода","description":"Рассчитайте стоимость холодной и горячей воды по тарифам Узбекистана. Водоотведение включено.","url":"https://calk.uz/ru/calculator/voda","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/voda#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/voda/opengraph-image"},"dateModified":"2026-03-15"},{"@context":"https://schema.org","@type":"WebApplication","name":"Вода","description":"Рассчитайте стоимость холодной и горячей воды по тарифам Узбекистана. Водоотведение включено.","url":"https://calk.uz/ru/calculator/voda","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/voda#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Коммунальные","item":"https://calk.uz/ru/category/utilities"},{"@type":"ListItem","position":3,"name":"Вода","item":"https://calk.uz/ru/calculator/voda"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько стоит вода в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"Холодная вода: 3 000-5 000 сум/м³. Водоотведение: дополнительно 1 500-3 000 сум/м³. Итого: 4 500-8 000 сум/м³."}},{"@type":"Question","name":"Выгоднее ли платить по счётчику?","acceptedAnswer":{"@type":"Answer","text":"Да, обычно в 1,5-2 раза выгоднее. Семья из 4 человек: по нормативу ~144 000 сум/мес, по счётчику ~72 000 сум."}},{"@type":"Question","name":"Какой норматив потребления воды без счётчика?","acceptedAnswer":{"@type":"Answer","text":"150-200 литров в сутки на человека (4,5-6 м³ в месяц)."}},{"@type":"Question","name":"Как передать показания счётчика воды?","acceptedAnswer":{"@type":"Answer","text":"Через мобильное приложение водоканала или в абонентском отделе. Показания передаются ежемесячно."}},{"@type":"Question","name":"Сколько стоит установка водомера?","acceptedAnswer":{"@type":"Answer","text":"200 000-500 000 сум с установкой. Поверка каждые 4-6 лет. Окупается за 3-6 месяцев."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Вода","description":"Рассчитайте стоимость холодной и горячей воды по тарифам Узбекистана. Водоотведение включено.","url":"https://calk.uz/ru/calculator/voda","datePublished":"2025-05-15","dateModified":"2026-03-15","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/voda"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Вода","description":"Пошаговое руководство по использованию калькулятора: Вода","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Введите потребление воды","text":"Укажите объём потреблённой воды в кубометрах (м³) за месяц."},{"@type":"HowToStep","position":2,"name":"Выберите тип водоснабжения","text":"Выберите холодное, горячее водоснабжение или оба."},{"@type":"HowToStep","position":3,"name":"Получите сумму оплаты","text":"Нажмите «Рассчитать» — узнайте стоимость водоснабжения и водоотведения."}]}]0:{"rsc":["$","$1","c",{"children"