2:T1987,[{"@context":"https://schema.org","@type":"WebPage","name":"Кредитный калькулятор","description":"Рассчитайте ежемесячный платёж по кредиту, переплату и полную стоимость. Аннуитетный и дифференцированный графики.","url":"https://calk.uz/ru/calculator/kredit","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/kredit#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/kredit/opengraph-image"},"dateModified":"2026-03-16"},{"@context":"https://schema.org","@type":"WebApplication","name":"Кредитный калькулятор","description":"Рассчитайте ежемесячный платёж по кредиту, переплату и полную стоимость. Аннуитетный и дифференцированный графики.","url":"https://calk.uz/ru/calculator/kredit","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/kredit#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Кредиты","item":"https://calk.uz/ru/category/credit"},{"@type":"ListItem","position":3,"name":"Кредитный калькулятор","item":"https://calk.uz/ru/calculator/kredit"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Какая средняя ставка по кредитам в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"Ключевая ставка ЦБ — 14%. Потребительские кредиты: 22-33% годовых. Ипотека: 17-22% (субсидированная) / 23-31% (коммерческая). Автокредит: 22-33%."}},{"@type":"Question","name":"Что такое аннуитетный и дифференцированный платёж?","acceptedAnswer":{"@type":"Answer","text":"Аннуитет — одинаковая сумма каждый месяц. Дифференцированный — убывающий платёж, больше в начале, меньше в конце. Дифференцированный выгоднее по переплате."}},{"@type":"Question","name":"Можно ли досрочно погасить кредит?","acceptedAnswer":{"@type":"Answer","text":"Да, с 2020 года досрочное погашение разрешено без штрафов. Проценты пересчитываются за фактический срок."}},{"@type":"Question","name":"Какой максимальный размер платежа по кредиту?","acceptedAnswer":{"@type":"Answer","text":"Банки ограничивают ежемесячный платёж 50% от чистого дохода заёмщика."}},{"@type":"Question","name":"Какие документы нужны для получения кредита?","acceptedAnswer":{"@type":"Answer","text":"Паспорт, справка о доходах (с работы или my.soliq.uz), кредитная история. Для залоговых кредитов — документы на имущество."}},{"@type":"Question","name":"Как уменьшить переплату по кредиту?","acceptedAnswer":{"@type":"Answer","text":"Выбирайте дифференцированную схему, сокращайте срок кредита, делайте частичные досрочные погашения, рассмотрите рефинансирование при снижении ставок."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Кредитный калькулятор","description":"Рассчитайте ежемесячный платёж по кредиту, переплату и полную стоимость. Аннуитетный и дифференцированный графики.","url":"https://calk.uz/ru/calculator/kredit","datePublished":"2025-05-09","dateModified":"2026-03-16","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/kredit"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Кредитный калькулятор","description":"Пошаговое руководство по использованию калькулятора: Кредитный калькулятор","totalTime":"PT3M","step":[{"@type":"HowToStep","position":1,"name":"Введите сумму кредита","text":"Укажите желаемую сумму кредита в узбекских сумах."},{"@type":"HowToStep","position":2,"name":"Укажите процентную ставку","text":"Введите годовую процентную ставку банка."},{"@type":"HowToStep","position":3,"name":"Выберите срок кредита","text":"Укажите срок кредитования в месяцах или годах."},{"@type":"HowToStep","position":4,"name":"Выберите тип платежей","text":"Выберите аннуитетный (равными частями) или дифференцированный (убывающий) тип."},{"@type":"HowToStep","position":5,"name":"Получите график платежей","text":"Нажмите «Рассчитать» и получите ежемесячный платёж, переплату и полный график."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
