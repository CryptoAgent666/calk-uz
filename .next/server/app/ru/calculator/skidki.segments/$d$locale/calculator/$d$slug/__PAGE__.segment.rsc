2:T146d,[{"@context":"https://schema.org","@type":"WebPage","name":"Калькулятор скидок","description":"Рассчитайте цену со скидкой и сумму экономии. Поддерживает несколько последовательных скидок.","url":"https://calk.uz/ru/calculator/skidki","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/skidki#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/skidki/opengraph-image"},"dateModified":"2025-08-15"},{"@context":"https://schema.org","@type":"WebApplication","name":"Калькулятор скидок","description":"Рассчитайте цену со скидкой и сумму экономии. Поддерживает несколько последовательных скидок.","url":"https://calk.uz/ru/calculator/skidki","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/skidki#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Инструменты","item":"https://calk.uz/ru/category/tools"},{"@type":"ListItem","position":3,"name":"Калькулятор скидок","item":"https://calk.uz/ru/calculator/skidki"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Как рассчитать скидку?","acceptedAnswer":{"@type":"Answer","text":"Цена × (100 − Скидка%) / 100. Например, товар 2 000 000 сум со скидкой 15%: 2 000 000 × 0,85 = 1 700 000 сум."}},{"@type":"Question","name":"Как работает двойная скидка?","acceptedAnswer":{"@type":"Answer","text":"Вторая скидка применяется к уже сниженной цене. 20% + 10% = не 30%, а 28% реальная скидка. Проверяйте итог калькулятором."}},{"@type":"Question","name":"Как узнать процент скидки?","acceptedAnswer":{"@type":"Answer","text":"(Исходная − Новая) / Исходная × 100. Было 500 000 сум, стало 350 000: (500 000 − 350 000) / 500 000 × 100 = 30%."}},{"@type":"Question","name":"Когда в Узбекистане самые большие скидки?","acceptedAnswer":{"@type":"Answer","text":"Чёрная пятница (ноябрь, до 50%), новогодние распродажи (декабрь-январь, до 70%), летние распродажи (июль-август, до 50%)."}},{"@type":"Question","name":"Можно ли торговаться на базаре с калькулятором?","acceptedAnswer":{"@type":"Answer","text":"Да, на базарах Чорсу и Алайском торг уместен. Калькулятор поможет быстро проверить предложенную скидку и итоговую цену."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Калькулятор скидок","description":"Рассчитайте цену со скидкой и сумму экономии. Поддерживает несколько последовательных скидок.","url":"https://calk.uz/ru/calculator/skidki","datePublished":"2025-05-17","dateModified":"2025-08-15","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/skidki"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Калькулятор скидок","description":"Пошаговое руководство по использованию калькулятора: Калькулятор скидок","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Введите первоначальную цену","text":"Укажите цену товара до скидки."},{"@type":"HowToStep","position":2,"name":"Укажите размер скидки","text":"Введите процент скидки."},{"@type":"HowToStep","position"