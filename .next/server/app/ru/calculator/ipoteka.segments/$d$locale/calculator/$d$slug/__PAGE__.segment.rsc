2:T1840,[{"@context":"https://schema.org","@type":"WebPage","name":"Ипотечный калькулятор","description":"Рассчитайте ипотеку в Узбекистане. Первоначальный взнос, ежемесячный платёж, переплата и график платежей.","url":"https://calk.uz/ru/calculator/ipoteka","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/ipoteka#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/ipoteka/opengraph-image"},"dateModified":"2026-03-02"},{"@context":"https://schema.org","@type":"WebApplication","name":"Ипотечный калькулятор","description":"Рассчитайте ипотеку в Узбекистане. Первоначальный взнос, ежемесячный платёж, переплата и график платежей.","url":"https://calk.uz/ru/calculator/ipoteka","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/ipoteka#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Кредиты","item":"https://calk.uz/ru/category/credit"},{"@type":"ListItem","position":3,"name":"Ипотечный калькулятор","item":"https://calk.uz/ru/calculator/ipoteka"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Какая ставка по ипотеке в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"Коммерческая ипотека: 23-31%. Субсидированная: 17-22% (формула ставка ЦБ + 6% ≈ 20%). Льготные категории (молодые семьи, многодетные, бюджетные работники): 7-14%."}},{"@type":"Question","name":"Какой первоначальный взнос нужен для ипотеки?","acceptedAnswer":{"@type":"Answer","text":"От 15% до 30% стоимости жилья в зависимости от банка и программы."}},{"@type":"Question","name":"На какой максимальный срок дают ипотеку?","acceptedAnswer":{"@type":"Answer","text":"До 20 лет. Наиболее распространённые сроки: 10-15 лет."}},{"@type":"Question","name":"Какие документы нужны для ипотеки?","acceptedAnswer":{"@type":"Answer","text":"Паспорт, справка о доходах, кредитная история, документы на приобретаемое жильё, оценка недвижимости, страховка объекта."}},{"@type":"Question","name":"Какие есть льготные ипотечные программы?","acceptedAnswer":{"@type":"Answer","text":"«Ёш оила» для молодых семей, «Обод кишлок» для сельской местности, программы для бюджетных работников — ставки от 7% годовых."}},{"@type":"Question","name":"Сколько стоит квадратный метр жилья в Ташкенте?","acceptedAnswer":{"@type":"Answer","text":"От 8 до 15 млн сум/м² в зависимости от района. Центр и популярные районы — дороже, пригороды — дешевле."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Ипотечный калькулятор","description":"Рассчитайте ипотеку в Узбекистане. Первоначальный взнос, ежемесячный платёж, переплата и график платежей.","url":"https://calk.uz/ru/calculator/ipoteka","datePublished":"2025-03-16","dateModified":"2026-03-02","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/ipoteka"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Ипотечный калькулятор","description":"Пошаговое руководство по использованию калькулятора: Ипотечный калькулятор","totalTime":"PT3M","step":[{"@type":"HowToStep","position":1,"name":"Введите стоимость жилья","text":"Укажите полную стоимость квартиры или дома в сумах."},{"@type":"HowToStep","position":2,"name":"Укажите первоначальный взнос","text":"Введите сумму или процент первоначального взноса."},{"@type":"HowToStep","position":3,"name":"Установите процентную ставку","text":"Введите годовую ставку ипотечного кредита."},{"@type":"HowToStep","position":4,"name":"Выберите срок ипотеки","text":"Укажите срок кредитования (обычно 10–20 лет)."},{"@type":"HowToStep","position":5,"name":"Получите расчёт","text":"Нажмите «Рассчитать» и узнайте ежемесячный платёж, общую переплату и сумму кредита."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
