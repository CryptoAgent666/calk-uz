2:T19ec,[{"@context":"https://schema.org","@type":"WebPage","name":"Калькулятор НДФЛ","description":"Рассчитайте налог на доходы физических лиц в Узбекистане. Учитывает ставку 12% и льготы для резидентов IT Park.","url":"https://calk.uz/ru/calculator/ndfl","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/ndfl#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/ndfl/opengraph-image"},"dateModified":"2025-10-09"},{"@context":"https://schema.org","@type":"WebApplication","name":"Калькулятор НДФЛ","description":"Рассчитайте налог на доходы физических лиц в Узбекистане. Учитывает ставку 12% и льготы для резидентов IT Park.","url":"https://calk.uz/ru/calculator/ndfl","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/ndfl#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Налоги","item":"https://calk.uz/ru/category/tax"},{"@type":"ListItem","position":3,"name":"Калькулятор НДФЛ","item":"https://calk.uz/ru/calculator/ndfl"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Какая ставка НДФЛ в Узбекистане в 2026 году?","acceptedAnswer":{"@type":"Answer","text":"Стандартная ставка НДФЛ составляет 12% для резидентов и 20% для нерезидентов. Для резидентов IT Park — льготная ставка 7,5%."}},{"@type":"Question","name":"Как рассчитать НДФЛ с зарплаты?","acceptedAnswer":{"@type":"Answer","text":"Умножьте начисленную зарплату на 0,12. Например, при зарплате 10 000 000 сум НДФЛ составит 1 200 000 сум. Также удерживается ИНПС 0,1% (10 000 сум)."}},{"@type":"Question","name":"Какие доходы не облагаются НДФЛ?","acceptedAnswer":{"@type":"Answer","text":"Не облагаются: алименты, пенсии, стипендии, материальная помощь до 4,22 БРВ в год (1 738 640 сум), компенсации при увольнении, страховые выплаты."}},{"@type":"Question","name":"Когда подавать декларацию по НДФЛ?","acceptedAnswer":{"@type":"Answer","text":"До 1 апреля года, следующего за отчётным. Декларация обязательна при доходах из нескольких источников, от аренды или из-за рубежа. Подаётся через my.soliq.uz."}},{"@type":"Question","name":"Какой размер имущественного вычета при покупке жилья?","acceptedAnswer":{"@type":"Answer","text":"Вычет составляет до 500 БРВ (206 000 000 сум с августа 2025 года). Предоставляется один раз в жизни при покупке жилья на территории Узбекистана."}},{"@type":"Question","name":"Чем отличается НДФЛ для сотрудников IT Park?","acceptedAnswer":{"@type":"Answer","text":"Резиденты IT Park платят НДФЛ по ставке 7,5% вместо 12%. При зарплате 10 млн сум экономия составляет 450 000 сум в месяц."}},{"@type":"Question","name":"Какой штраф за неуплату НДФЛ?","acceptedAnswer":{"@type":"Answer","text":"За несвоевременную уплату начисляется пеня в размере 1/300 ставки рефинансирования ЦБ за каждый день просрочки (при ставке 14% — 0,047%/день, 17,0% годовых)."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Калькулятор НДФЛ","description":"Рассчитайте налог на доходы физических лиц в Узбекистане. Учитывает ставку 12% и льготы для резидентов IT Park.","url":"https://calk.uz/ru/calculator/ndfl","datePublished":"2025-05-16","dateModified":"2025-10-09","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/ndfl"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Калькулятор НДФЛ","description":"Пошаговое руководство по использованию калькулятора: Калькулятор НДФЛ","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите доход","text":"Укажите сумму дохода за период в узбекских сумах."},{"@type":"HowToStep","position":2,"name":"Выберите вычеты","text":"Отметьте применимые налоговые вычеты и льготы (IT Park, инвалидность и др.)."},{"@type":"HowToStep","position":3,"name":"Нажмите «Рассчитать»","text":"Калькулятор применит ставку НДФЛ 12% и учтёт указанные вычеты."},{"@type":"HowToStep","position":4,"name":"Изучите результат","text":"Получите сумму НДФЛ к уплате, эффективную ставку и чистый доход после налога."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
