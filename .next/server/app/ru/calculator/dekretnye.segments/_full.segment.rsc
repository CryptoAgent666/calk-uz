1a:T143e,[{"@context":"https://schema.org","@type":"WebPage","name":"Декретные","description":"Рассчитайте декретные выплаты и пособие по беременности и родам. Учитывает стаж и средний заработок.","url":"https://calk.uz/ru/calculator/dekretnye","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/dekretnye#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/dekretnye/opengraph-image"},"dateModified":"2026-02-03"},{"@context":"https://schema.org","@type":"WebApplication","name":"Декретные","description":"Рассчитайте декретные выплаты и пособие по беременности и родам. Учитывает стаж и средний заработок.","url":"https://calk.uz/ru/calculator/dekretnye","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/dekretnye#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Зарплата","item":"https://calk.uz/ru/category/salary"},{"@type":"ListItem","position":3,"name":"Декретные","item":"https://calk.uz/ru/calculator/dekretnye"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько длится декретный отпуск?","acceptedAnswer":{"@type":"Answer","text":"126 дней (70 до + 56 после родов). При осложнениях: 140 дней (70 + 70). С 2026 года пособие выплачивает ГССФ напрямую."}},{"@type":"Question","name":"Какое пособие по уходу за ребёнком?","acceptedAnswer":{"@type":"Answer","text":"60% от МРОТ до 2 лет. Минимум — 50% МЗП (635 500 сум)."}},{"@type":"Question","name":"Какое единовременное пособие при рождении?","acceptedAnswer":{"@type":"Answer","text":"Единой государственной ставки нет — выплата устанавливается работодателем (коллективный договор / внутренние акты)."}},{"@type":"Question","name":"Облагается ли декретное пособие налогом?","acceptedAnswer":{"@type":"Answer","text":"Нет, пособие по беременности и родам не облагается НДФЛ и социальным налогом."}},{"@type":"Question","name":"Может ли отец взять отпуск по уходу?","acceptedAnswer":{"@type":"Answer","text":"Да, отпуск по уходу за ребёнком может взять отец, бабушка, дедушка или другой родственник."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Декретные","description":"Рассчитайте декретные выплаты и пособие по беременности и родам. Учитывает стаж и средний заработок.","url":"https://calk.uz/ru/calculator/dekretnye","datePublished":"2025-09-05","dateModified":"2026-02-03","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/dekretnye"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Декретные","description":"Пошаговое руководство по использованию калькулятора: Декретные","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите среднюю зарплату","text":"Укажите среднемесячную зарплату за последние 6 месяцев."},{"@type":"HowToStep","position":2,"name":"Укажите срок декрета","text":"Выберите продолжительность декретного отпуска (126 или 140 дней)."},{"@type":"HowToStep","position":3,"name":"Получите расчёт","text":"Нажмите «Рассчитать» — узнайте размер пособия по беременности и родам."}]}]11:["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1a"}}],"$L1b","$L1c"]}]
