2:T14ba,[{"@context":"https://schema.org","@type":"WebPage","name":"Калькулятор БЖУ","description":"Рассчитайте суточную норму белков, жиров и углеводов. Оптимальный баланс БЖУ для ваших целей.","url":"https://calk.uz/ru/calculator/bzhu","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/bzhu#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/bzhu/opengraph-image"},"dateModified":"2025-08-10"},{"@context":"https://schema.org","@type":"WebApplication","name":"Калькулятор БЖУ","description":"Рассчитайте суточную норму белков, жиров и углеводов. Оптимальный баланс БЖУ для ваших целей.","url":"https://calk.uz/ru/calculator/bzhu","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/bzhu#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Здоровье","item":"https://calk.uz/ru/category/health"},{"@type":"ListItem","position":3,"name":"Калькулятор БЖУ","item":"https://calk.uz/ru/calculator/bzhu"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Какое соотношение БЖУ оптимально?","acceptedAnswer":{"@type":"Answer","text":"Поддержание: белки 30%, жиры 25%, углеводы 45%. Похудение: белки 35-40%, углеводы 30-35%. Набор массы: углеводы 50-55%."}},{"@type":"Question","name":"Сколько белка нужно в день?","acceptedAnswer":{"@type":"Answer","text":"1,5-2 г/кг при активном образе жизни. Для человека 80 кг: 120-160 г. При тренировках: до 2,2 г/кг (176 г)."}},{"@type":"Question","name":"Как рассчитать КБЖУ?","acceptedAnswer":{"@type":"Answer","text":"Определите суточные калории (калькулятор калорий), затем распределите: белки (×4 ккал/г), жиры (×9 ккал/г), углеводы (×4 ккал/г)."}},{"@type":"Question","name":"Сколько КБЖУ в плове?","acceptedAnswer":{"@type":"Answer","text":"Порция плова (~400 г): ~800 ккал, 40 г белка, 35 г жиров, 90 г углеводов."}},{"@type":"Question","name":"Можно ли похудеть не считая КБЖУ?","acceptedAnswer":{"@type":"Answer","text":"Можно, но контроль КБЖУ повышает эффективность на 30-50% по данным исследований. Точный расчёт предотвращает потерю мышц."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Калькулятор БЖУ","description":"Рассчитайте суточную норму белков, жиров и углеводов. Оптимальный баланс БЖУ для ваших целей.","url":"https://calk.uz/ru/calculator/bzhu","datePublished":"2025-09-15","dateModified":"2025-08-10","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/bzhu"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Калькулятор БЖУ","description":"Пошаговое руководство по использованию калькулятора: Калькулятор БЖУ","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите личные данные","text":"Укажите возраст, пол, рост и вес."},{"@type":"HowToStep","position":2,"name":"Выберите цель","text":"Укажите цель: похудение, поддержание веса или набор массы."},{"@type":"HowToStep","position":3,"name":"Укажите уровень активности","text":"Выберите уровень физической а