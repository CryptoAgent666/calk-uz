1a:T145b,[{"@context":"https://schema.org","@type":"WebPage","name":"Фитр садака","description":"Рассчитайте размер фитр садака (закят аль-фитр). Обязательная милостыня перед праздником Ид аль-Фитр.","url":"https://calk.uz/ru/calculator/fitr-sadaka","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/fitr-sadaka#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/fitr-sadaka/opengraph-image"},"dateModified":"2025-05-20"},{"@context":"https://schema.org","@type":"WebApplication","name":"Фитр садака","description":"Рассчитайте размер фитр садака (закят аль-фитр). Обязательная милостыня перед праздником Ид аль-Фитр.","url":"https://calk.uz/ru/calculator/fitr-sadaka","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/fitr-sadaka#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Религия","item":"https://calk.uz/ru/category/religion"},{"@type":"ListItem","position":3,"name":"Фитр садака","item":"https://calk.uz/ru/calculator/fitr-sadaka"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько фитр-садака в 2026 году?","acceptedAnswer":{"@type":"Answer","text":"Минимум ~45 000 сум (пшеница) до ~65 000 сум (рис) на человека. Семья из 5 человек: 225 000-325 000 сум."}},{"@type":"Question","name":"Кто должен платить?","acceptedAnswer":{"@type":"Answer","text":"Каждый мусульманин за себя и иждивенцев (дети, пожилые родители). Глава семьи платит за всех."}},{"@type":"Question","name":"Когда нужно выплатить?","acceptedAnswer":{"@type":"Answer","text":"До утренней праздничной молитвы Ид аль-Фитр. Рекомендуется в последние дни Рамадана."}},{"@type":"Question","name":"Куда передать фитр-садака?","acceptedAnswer":{"@type":"Answer","text":"Напрямую нуждающимся, через мечеть, фонд Вакф (vaqf.uz) или благотворительные организации."}},{"@type":"Question","name":"Как определяется размер фитр-садака?","acceptedAnswer":{"@type":"Answer","text":"Стоимость 1 са (~3,5 кг) основного продукта: пшеница, рис или ячмень. Управление мусульман Узбекистана публикует размеры ежегодно."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Фитр садака","description":"Рассчитайте размер фитр садака (закят аль-фитр). Обязательная милостыня перед праздником Ид аль-Фитр.","url":"https://calk.uz/ru/calculator/fitr-sadaka","datePublished":"2025-08-01","dateModified":"2025-05-20","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/fitr-sadaka"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Фитр садака","description":"Пошаговое руководство по использованию калькулятора: Фитр садака","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Выберите продукт","text":"Укажите продукт для расчёта фитр-садака (пшеница, рис, мука и др.)."},{"@type":"HowToStep","position":2,"name":"Укажите количество членов семьи","text":"Введите число человек, за которых выплачивается садака."},{"@type":"HowToStep","position":3,"name":"Получите 