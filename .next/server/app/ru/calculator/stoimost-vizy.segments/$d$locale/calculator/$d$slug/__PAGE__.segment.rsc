2:T17c0,[{"@context":"https://schema.org","@type":"WebPage","name":"Стоимость визы","description":"Рассчитайте стоимость визы для граждан Узбекистана. Консульский сбор, страховка и сервисный сбор.","url":"https://calk.uz/ru/calculator/stoimost-vizy","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/stoimost-vizy#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/stoimost-vizy/opengraph-image"},"dateModified":"2025-10-16"},{"@context":"https://schema.org","@type":"WebApplication","name":"Стоимость визы","description":"Рассчитайте стоимость визы для граждан Узбекистана. Консульский сбор, страховка и сервисный сбор.","url":"https://calk.uz/ru/calculator/stoimost-vizy","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/stoimost-vizy#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Узбекистан","item":"https://calk.uz/ru/category/unique"},{"@type":"ListItem","position":3,"name":"Стоимость визы","item":"https://calk.uz/ru/calculator/stoimost-vizy"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько стоит Шенгенская виза?","acceptedAnswer":{"@type":"Answer","text":"Консульский сбор €80 (~1 050 000 сум) + сервисный сбор визового центра €20-30 (~260 000-395 000 сум) + фото, перевод документов и страховка. Итого: 1 740 000-2 800 000 сум на человека."}},{"@type":"Question","name":"В какие страны не нужна виза?","acceptedAnswer":{"@type":"Answer","text":"Россия, Казахстан, Кыргызстан, Таджикистан, Грузия, Турция (до 30 дней), Малайзия (до 30 дней), Южная Корея (до 30 дней), Индонезия, Сингапур и ряд стран СНГ. Полный список — на сайте МИД mfa.uz."}},{"@type":"Question","name":"Из чего складывается стоимость визы?","acceptedAnswer":{"@type":"Answer","text":"Консульский сбор (основная часть, €40-185) + сервисный сбор визового центра (€20-30) + фото (30 000-50 000 сум) + перевод документов (200 000-500 000 сум) + медицинская страховка (200 000-800 000 сум)."}},{"@type":"Question","name":"Где подать документы на визу в Ташкенте?","acceptedAnswer":{"@type":"Answer","text":"В визовых центрах: VFS Global (ТЦ Compass, Шенгенские страны), TLS Contact (ул. Бабура, Франция). Посольства также принимают документы напрямую для некоторых категорий виз."}},{"@type":"Question","name":"Сколько стоит виза для ребёнка?","acceptedAnswer":{"@type":"Answer","text":"Шенген: дети до 6 лет — бесплатно, 6-12 лет — €40 (~525 000 сум). США (B1/B2): одинаково $185 для всех возрастов. Сервисный сбор и страховка оплачиваются независимо от возраста."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Стоимость визы","description":"Рассчитайте стоимость визы для граждан Узбекистана. Консульский сбор, страховка и сервисный сбор.","url":"https://calk.uz/ru/calculator/stoimost-vizy","datePublished":"2025-07-26","dateModified":"2025-10-16","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/stoimost-vizy"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Стоимость визы","description":"Пошаговое руководство по использованию калькулятора: Стоимость визы","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Выберите страну","text":"Укажите страну, для которой оформляется виза."},{"@type":"HowToStep","position":2,"name":"Выберите тип визы","text":"Укажите тип: туристическая, рабочая, студенческая, транзитная."},{"@type":"HowToStep","position":3,"name":"Укажите срочность","text":"Выберите обычный или ускоренный срок оформления."},{"@type":"HowToStep","position":4,"name":"Получите расчёт","text":"Нажмите «Рассчитать» — узнайте консульский сбор и общие расходы на визу."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
