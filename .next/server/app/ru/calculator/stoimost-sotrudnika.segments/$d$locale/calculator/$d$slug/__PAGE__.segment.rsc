2:T1628,[{"@context":"https://schema.org","@type":"WebPage","name":"Стоимость сотрудника","description":"Рассчитайте полную стоимость содержания сотрудника для работодателя. Зарплата, налоги и соцвзносы.","url":"https://calk.uz/ru/calculator/stoimost-sotrudnika","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/stoimost-sotrudnika#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/stoimost-sotrudnika/opengraph-image"},"dateModified":"2026-01-20"},{"@context":"https://schema.org","@type":"WebApplication","name":"Стоимость сотрудника","description":"Рассчитайте полную стоимость содержания сотрудника для работодателя. Зарплата, налоги и соцвзносы.","url":"https://calk.uz/ru/calculator/stoimost-sotrudnika","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/stoimost-sotrudnika#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Бизнес","item":"https://calk.uz/ru/category/business"},{"@type":"ListItem","position":3,"name":"Стоимость сотрудника","item":"https://calk.uz/ru/calculator/stoimost-sotrudnika"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько работодатель платит сверх зарплаты в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"Социальный налог 12% от начисленной зарплаты (25% для бюджетных). Полная стоимость = зарплата на руки × 1,274."}},{"@type":"Question","name":"Как рассчитать полную стоимость сотрудника?","acceptedAnswer":{"@type":"Answer","text":"Гросс = Нетто / 0,879. Полная стоимость = Гросс × 1,12. Для IT Park: Гросс = Нетто / 0,924, Полная стоимость = Гросс × 1,12."}},{"@type":"Question","name":"Какие ещё расходы несёт работодатель?","acceptedAnswer":{"@type":"Answer","text":"Больничные (первые 10 дней), отпускные, компенсация при увольнении, страхование, охрана труда. Дополнительно 10-20% к ФОТ."}},{"@type":"Question","name":"Выгоднее ли нанимать через IT Park?","acceptedAnswer":{"@type":"Answer","text":"Да, экономия ~620 000 сум/мес на сотрудника с зарплатой 10 млн «на руки» (около 5% общих расходов)."}},{"@type":"Question","name":"Какой социальный налог для бюджетных организаций?","acceptedAnswer":{"@type":"Answer","text":"25% от ФОТ вместо стандартных 12%. Полная стоимость = Гросс × 1,25."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Стоимость сотрудника","description":"Рассчитайте полную стоимость содержания сотрудника для работодателя. Зарплата, налоги и соцвзносы.","url":"https://calk.uz/ru/calculator/stoimost-sotrudnika","datePublished":"2025-05-17","dateModified":"2026-01-20","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/stoimost-sotrudnika"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Стоимость сотрудника","description":"Пошаговое руководство по использованию калькулятора: Стоимость сотрудника","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите зарплату сотрудника","text":"Укажите начисленную заработную плату 