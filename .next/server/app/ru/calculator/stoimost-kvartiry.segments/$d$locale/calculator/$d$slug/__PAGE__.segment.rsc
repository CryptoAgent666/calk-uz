2:T1653,[{"@context":"https://schema.org","@type":"WebPage","name":"Стоимость квартиры","description":"Оцените стоимость квартиры в Ташкенте и других городах. Учитывает район, площадь и состояние.","url":"https://calk.uz/ru/calculator/stoimost-kvartiry","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/stoimost-kvartiry#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/stoimost-kvartiry/opengraph-image"},"dateModified":"2025-12-26"},{"@context":"https://schema.org","@type":"WebApplication","name":"Стоимость квартиры","description":"Оцените стоимость квартиры в Ташкенте и других городах. Учитывает район, площадь и состояние.","url":"https://calk.uz/ru/calculator/stoimost-kvartiry","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/stoimost-kvartiry#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Недвижимость","item":"https://calk.uz/ru/category/realestate"},{"@type":"ListItem","position":3,"name":"Стоимость квартиры","item":"https://calk.uz/ru/calculator/stoimost-kvartiry"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько стоит квартира в Ташкенте?","acceptedAnswer":{"@type":"Answer","text":"2-комнатная (60 м²): 480-900 млн сум в зависимости от района. Юнусабад: ~720 млн, Сергели: ~480 млн, Мирабад: ~900 млн."}},{"@type":"Question","name":"Какой район Ташкента самый дорогой?","acceptedAnswer":{"@type":"Answer","text":"Мирабадский район (13-16 млн сум/м²) и Мирзо-Улугбекский (12-15 млн). Самые доступные: Сергели и Бектемир (7-10 млн)."}},{"@type":"Question","name":"Сколько стоит квадратный метр жилья в регионах?","acceptedAnswer":{"@type":"Answer","text":"Самарканд: 5-8 млн, Бухара: 4-7 млн, Наманган: 3-6 млн, Андижан/Нукус: 3-5 млн сум/м²."}},{"@type":"Question","name":"Какие дополнительные расходы при покупке квартиры?","acceptedAnswer":{"@type":"Answer","text":"Нотариус — фикс. 1 БРВ (412 000 сум), госпошлина за регистрацию — 1,25-3 БРВ по площади (до 100 м² — 1,25 БРВ), оценка (до 500 000 сум), риелтор (1-2%). Суммарно: 1-3% от стоимости."}},{"@type":"Question","name":"Выгоднее покупать новостройку или вторичку?","acceptedAnswer":{"@type":"Answer","text":"Новостройки дороже на 20-30%, но не требуют ремонта. Вторичка дешевле, но может потребовать вложений в ремонт (3-8 млн/м²)."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Стоимость квартиры","description":"Оцените стоимость квартиры в Ташкенте и других городах. Учитывает район, площадь и состояние.","url":"https://calk.uz/ru/calculator/stoimost-kvartiry","datePublished":"2025-07-11","dateModified":"2025-12-26","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/stoimost-kvartiry"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Стоимость квартиры","description":"Пошаговое руководство по использованию калькулятора: Стоимость квартиры","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Выберите город и район","text":"Укажите город и район, где хотите приобрести квартиру."},{"@type":"HowToStep","position":2,"name":"Укажите площадь","text":"Введите площадь квартиры в квадратных метрах."},{"@type":"HowToStep","position":3,"name":"Выберите тип жилья","text":"Укажите: новостройка или вторичное жильё."},{"@type":"HowToStep","position":4,"name":"Получите оценку стоимости","text":"Нажмите «Рассчитать» — узнайте примерную стоимость квартиры."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
