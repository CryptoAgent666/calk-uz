2:T15b5,[{"@context":"https://schema.org","@type":"WebPage","name":"Пени по налогам","description":"Рассчитайте пени за просрочку уплаты налогов. На основе ставки рефинансирования ЦБ Узбекистана.","url":"https://calk.uz/ru/calculator/peni-po-nalogam","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/peni-po-nalogam#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/peni-po-nalogam/opengraph-image"},"dateModified":"2026-04-01"},{"@context":"https://schema.org","@type":"WebApplication","name":"Пени по налогам","description":"Рассчитайте пени за просрочку уплаты налогов. На основе ставки рефинансирования ЦБ Узбекистана.","url":"https://calk.uz/ru/calculator/peni-po-nalogam","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/peni-po-nalogam#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Налоги","item":"https://calk.uz/ru/category/tax"},{"@type":"ListItem","position":3,"name":"Пени по налогам","item":"https://calk.uz/ru/calculator/peni-po-nalogam"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Какая пеня за просрочку уплаты налогов?","acceptedAnswer":{"@type":"Answer","text":"1/300 ставки рефинансирования ЦБ от суммы задолженности за каждый день просрочки. При ставке ЦБ 14%: 0,047%/день (17,0% годовых)."}},{"@type":"Question","name":"Как рассчитать пеню?","acceptedAnswer":{"@type":"Answer","text":"Сумма долга × (ставка ЦБ / 300) × количество дней. При ставке 14%: 10 млн × 0,000467 × 30 = 140 000 сум."}},{"@type":"Question","name":"Какие штрафы за налоговые нарушения?","acceptedAnswer":{"@type":"Answer","text":"Непредставление декларации: 1-3 БРВ. Занижение базы: 20% недоплаты. Деятельность без регистрации: 10-30 БРВ."}},{"@type":"Question","name":"Можно ли уменьшить пеню?","acceptedAnswer":{"@type":"Answer","text":"Пеня начисляется автоматически и не уменьшается. Но штраф за занижение базы можно избежать, подав уточнённую декларацию до налоговой проверки."}},{"@type":"Question","name":"С какого дня начинается пеня?","acceptedAnswer":{"@type":"Answer","text":"Со следующего дня после установленного срока уплаты налога. Заканчивается в день фактической оплаты."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Пени по налогам","description":"Рассчитайте пени за просрочку уплаты налогов. На основе ставки рефинансирования ЦБ Узбекистана.","url":"https://calk.uz/ru/calculator/peni-po-nalogam","datePublished":"2025-09-20","dateModified":"2026-04-01","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/peni-po-nalogam"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Пени по налогам","description":"Пошаговое руководство по использованию калькулятора: Пени по налогам","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите сумму задолженности","text":"Укажите сумму неуплаченного налога в сумах."},{"@type":"HowToStep","position":2,"name":"Укажите даты","text":"Введите дату крайнего срока уплаты и текущую дату."},{"@type":"HowToStep","position":3,"name":"Выберите вид налога","text":"Выберите вид налога, по которому образовалась задолженность."},{"@type":"HowToStep","position":4,"name":"Получите расчёт пени","text":"Нажмите «Рассчитать» — узнайте сумму пени и штрафа за просрочку."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
