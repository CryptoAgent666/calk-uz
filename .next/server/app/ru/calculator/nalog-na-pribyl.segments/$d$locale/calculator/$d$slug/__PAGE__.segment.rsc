2:T1698,[{"@context":"https://schema.org","@type":"WebPage","name":"Налог на прибыль","description":"Рассчитайте налог на прибыль предприятия. Ставка 15% с учётом вычетов и льгот для бизнеса в Узбекистане.","url":"https://calk.uz/ru/calculator/nalog-na-pribyl","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/nalog-na-pribyl#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/nalog-na-pribyl/opengraph-image"},"dateModified":"2026-01-25"},{"@context":"https://schema.org","@type":"WebApplication","name":"Налог на прибыль","description":"Рассчитайте налог на прибыль предприятия. Ставка 15% с учётом вычетов и льгот для бизнеса в Узбекистане.","url":"https://calk.uz/ru/calculator/nalog-na-pribyl","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/nalog-na-pribyl#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Налоги","item":"https://calk.uz/ru/category/tax"},{"@type":"ListItem","position":3,"name":"Налог на прибыль","item":"https://calk.uz/ru/calculator/nalog-na-pribyl"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Какая ставка налога на прибыль?","acceptedAnswer":{"@type":"Answer","text":"15% для обычных юрлиц (в т.ч. e-commerce с 2026), 20% для банков, страховых и мобильных операторов, 0% для высокотехнологичных производств (ZRU-1104). На упрощённой — 4% от оборота (юрлица), 1% (ИП до 1 млрд)."}},{"@type":"Question","name":"Можно ли перенести убытки?","acceptedAnswer":{"@type":"Answer","text":"Да, убытки переносятся на будущие периоды без ограничения по сроку (прежний 5-летний лимит отменён), уменьшая прибыль будущих лет."}},{"@type":"Question","name":"Какие льготы по налогу на прибыль?","acceptedAnswer":{"@type":"Answer","text":"СЭЗ (до 10 лет освобождение), IT Park (1% от выручки), инвесторы в социальные проекты — пониженные ставки."}},{"@type":"Question","name":"Когда подавать декларацию?","acceptedAnswer":{"@type":"Answer","text":"До 1 апреля года, следующего за отчётным. Авансовые платежи — ежеквартально до 25-го числа первого месяца квартала."}},{"@type":"Question","name":"Какой налог на дивиденды?","acceptedAnswer":{"@type":"Answer","text":"НДФЛ 5% с дивидендов, выплачиваемых учредителям — физическим лицам. Для юридических лиц-учредителей — 5%."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Налог на прибыль","description":"Рассчитайте налог на прибыль предприятия. Ставка 15% с учётом вычетов и льгот для бизнеса в Узбекистане.","url":"https://calk.uz/ru/calculator/nalog-na-pribyl","datePublished":"2025-08-03","dateModified":"2026-01-25","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/nalog-na-pribyl"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Налог на прибыль","description":"Пошаговое руководство по использованию калькулятора: Налог на прибыль","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите доходы предприятия","text":"Укажите совокупный доход юридического лица за период."},{"@type":"HowToStep","position":2,"name":"Укажите вычитаемые расходы","text":"Введите сумму расходов, подлежащих вычету."},{"@type":"HowToStep","position":3,"name":"Выберите налоговый режим","text":"Укажите систему налогообложения (общая, упрощённая, IT Park)."},{"@type":"HowToStep","position":4,"name":"Получите расчёт","text":"Нажмите «Рассчитать» — получите сумму налога на прибыль и эффективную ставку."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
