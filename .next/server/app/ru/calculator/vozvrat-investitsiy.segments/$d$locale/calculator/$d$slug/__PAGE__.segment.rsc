2:T155f,[{"@context":"https://schema.org","@type":"WebPage","name":"Возврат инвестиций","description":"Рассчитайте рентабельность инвестиций (ROI). Оцените эффективность вложений в бизнес-проект.","url":"https://calk.uz/ru/calculator/vozvrat-investitsiy","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/vozvrat-investitsiy#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/vozvrat-investitsiy/opengraph-image"},"dateModified":"2025-07-20"},{"@context":"https://schema.org","@type":"WebApplication","name":"Возврат инвестиций","description":"Рассчитайте рентабельность инвестиций (ROI). Оцените эффективность вложений в бизнес-проект.","url":"https://calk.uz/ru/calculator/vozvrat-investitsiy","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/vozvrat-investitsiy#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Бизнес","item":"https://calk.uz/ru/category/business"},{"@type":"ListItem","position":3,"name":"Возврат инвестиций","item":"https://calk.uz/ru/calculator/vozvrat-investitsiy"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Что такое ROI?","acceptedAnswer":{"@type":"Answer","text":"Return on Investment — показатель доходности инвестиций в процентах. Показывает, сколько вы заработали на каждый вложенный сум."}},{"@type":"Question","name":"Как рассчитать ROI?","acceptedAnswer":{"@type":"Answer","text":"(Прибыль − Инвестиции) / Инвестиции × 100%. Например, вложили 100 млн, заработали 130 млн: ROI = 30%."}},{"@type":"Question","name":"Какой ROI считается хорошим в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"Выше инфляции (~10%) и ставки по вкладам (~24%). ROI >30% — отличный результат для бизнеса."}},{"@type":"Question","name":"Чем ROI отличается от прибыли?","acceptedAnswer":{"@type":"Answer","text":"Прибыль — абсолютная сумма (в сумах). ROI — относительный показатель (в %). ROI позволяет сравнивать инвестиции разного масштаба."}},{"@type":"Question","name":"Какова доходность депозитов в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"В сумах: 22-25% годовых. В долларах: 5-8%. Реальная доходность (за вычетом инфляции ~10%): 12-15% в сумах."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Возврат инвестиций","description":"Рассчитайте рентабельность инвестиций (ROI). Оцените эффективность вложений в бизнес-проект.","url":"https://calk.uz/ru/calculator/vozvrat-investitsiy","datePublished":"2025-03-18","dateModified":"2025-07-20","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/vozvrat-investitsiy"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Возврат инвестиций","description":"Пошаговое руководство по использованию калькулятора: Возврат инвестиций","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите сумму инвестиции","text":"Укажите начальную сумму вложений."},{"@type":"HowToStep","position":2,"name":"Укажите полученный доход","text":"