2:T15a2,[{"@context":"https://schema.org","@type":"WebPage","name":"Стоимость обучения","description":"Рассчитайте стоимость обучения в вузах Узбекистана. Контракт, стипендия и дополнительные расходы.","url":"https://calk.uz/ru/calculator/stoimost-obucheniya","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/stoimost-obucheniya#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/stoimost-obucheniya/opengraph-image"},"dateModified":"2025-09-15"},{"@context":"https://schema.org","@type":"WebApplication","name":"Стоимость обучения","description":"Рассчитайте стоимость обучения в вузах Узбекистана. Контракт, стипендия и дополнительные расходы.","url":"https://calk.uz/ru/calculator/stoimost-obucheniya","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/stoimost-obucheniya#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Образование","item":"https://calk.uz/ru/category/education"},{"@type":"ListItem","position":3,"name":"Стоимость обучения","item":"https://calk.uz/ru/calculator/stoimost-obucheniya"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько стоит обучение в вузе?","acceptedAnswer":{"@type":"Answer","text":"Государственные: 12-30 млн/год. Медвузы: 25-45 млн. Частные: 15-50 млн. Филиалы зарубежных: 25-80 млн. Бюджет — бесплатно."}},{"@type":"Question","name":"Есть ли образовательные кредиты?","acceptedAnswer":{"@type":"Answer","text":"Да, банки (Ipoteka bank, Kapitalbank) предлагают кредиты по ставке 14-18% на срок до 7 лет с отсрочкой до окончания учёбы."}},{"@type":"Question","name":"Какие дополнительные расходы?","acceptedAnswer":{"@type":"Answer","text":"Учебники: 1-3 млн/год, общежитие: 1-3 млн, питание: 3-5 млн, транспорт: 0,5-1,2 млн. Итого: 5-12 млн/год для иногородних."}},{"@type":"Question","name":"Сколько бюджетных мест?","acceptedAnswer":{"@type":"Answer","text":"Около 20-25% всех мест. Распределяются по результатам DTM. Также есть именные стипендии и гранты."}},{"@type":"Question","name":"Какие вузы самые дорогие?","acceptedAnswer":{"@type":"Answer","text":"Филиалы зарубежных: Westminster (от 45 млн), INHA (от 35 млн). Из отечественных: медвузы — до 45 млн сум/год."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Стоимость обучения","description":"Рассчитайте стоимость обучения в вузах Узбекистана. Контракт, стипендия и дополнительные расходы.","url":"https://calk.uz/ru/calculator/stoimost-obucheniya","datePublished":"2025-09-25","dateModified":"2025-09-15","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/stoimost-obucheniya"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Стоимость обучения","description":"Пошаговое руководство по использованию калькулятора: Стоимость обучения","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Выберите университет","text":"Выберите вуз из списка университетов Узбекистана."},{"@type":"HowToStep","position":2,"name":"Укажите специальность","text":"Выберите направление обучения и форму (очная, заочная)."},{"@type":"HowToStep","position":3,"name":"Выберите курс","text":"Укажите текущий или планируемый курс обучения."},{"@type":"HowToStep","position":4,"name":"Получите стоимость","text":"Нажмите «Рассчитать» — узнайте стоимость контракта за год."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
