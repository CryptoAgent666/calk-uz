2:T1541,[{"@context":"https://schema.org","@type":"WebPage","name":"Базовая расчётная величина","description":"Переведите суммы из БРВ в сумы и обратно. Актуальное значение базовой расчётной величины Узбекистана.","url":"https://calk.uz/ru/calculator/brv","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/brv#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/brv/opengraph-image"},"dateModified":"2026-02-23"},{"@context":"https://schema.org","@type":"WebApplication","name":"Базовая расчётная величина","description":"Переведите суммы из БРВ в сумы и обратно. Актуальное значение базовой расчётной величины Узбекистана.","url":"https://calk.uz/ru/calculator/brv","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/brv#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Узбекистан","item":"https://calk.uz/ru/category/unique"},{"@type":"ListItem","position":3,"name":"Базовая расчётная величина","item":"https://calk.uz/ru/calculator/brv"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Сколько составляет 1 БРВ в 2026 году?","acceptedAnswer":{"@type":"Answer","text":"412 000 сум (действует с августа 2025 года, сохраняется в 2026). До этого: 375 000 сум (2024), 330 000 сум (2023)."}},{"@type":"Question","name":"Для чего используется БРВ?","acceptedAnswer":{"@type":"Answer","text":"Для расчёта штрафов, госпошлин, налоговых порогов, социальных пособий, вычетов по НДФЛ и многих других нормативов."}},{"@type":"Question","name":"Чем БРВ отличается от минимальной зарплаты?","acceptedAnswer":{"@type":"Answer","text":"БРВ (412 000 сум) — расчётный показатель для нормативов. МЗП (1 271 000 сум) — минимальный уровень оплаты труда. С 2022 года устанавливаются независимо."}},{"@type":"Question","name":"Как часто меняется БРВ?","acceptedAnswer":{"@type":"Answer","text":"Обычно 1-2 раза в год по Указу Президента. Индексируется с учётом инфляции и экономического роста."}},{"@type":"Question","name":"Сколько БРВ составляет порог НДС?","acceptedAnswer":{"@type":"Answer","text":"1 млрд сум. При обороте выше этой суммы за 12 месяцев регистрация плательщиком НДС обязательна."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Базовая расчётная величина","description":"Переведите суммы из БРВ в сумы и обратно. Актуальное значение базовой расчётной величины Узбекистана.","url":"https://calk.uz/ru/calculator/brv","datePublished":"2025-09-09","dateModified":"2026-02-23","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/brv"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Базовая расчётная величина","description":"Пошаговое руководство по использованию калькулятора: Базовая расчётная величина","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Введите количество БРВ","text":"Укажите количество базовых расчётных величин."},{"@type":"HowToStep","position":2,"name":"Выберите период","text":"Выберите год для определения актуального размера БРВ."},{"@type":"HowToStep","position":3,"name":"Получите сумму","text":"Нажмите «Рассчитать» — узнайте сумму в сумах для указанного количества БРВ."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
