2:T158a,[{"@context":"https://schema.org","@type":"WebPage","name":"Больничный","description":"Рассчитайте оплату больничного листа. Зависит от стажа работы и среднего заработка сотрудника.","url":"https://calk.uz/ru/calculator/bolnichnyy","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/bolnichnyy#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/bolnichnyy/opengraph-image"},"dateModified":"2025-12-18"},{"@context":"https://schema.org","@type":"WebApplication","name":"Больничный","description":"Рассчитайте оплату больничного листа. Зависит от стажа работы и среднего заработка сотрудника.","url":"https://calk.uz/ru/calculator/bolnichnyy","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/bolnichnyy#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Зарплата","item":"https://calk.uz/ru/category/salary"},{"@type":"ListItem","position":3,"name":"Больничный","item":"https://calk.uz/ru/calculator/bolnichnyy"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Как оплачивается больничный?","acceptedAnswer":{"@type":"Answer","text":"В зависимости от страхового стажа: до 5 лет — 60%, 5-8 лет — 80%, более 8 лет — 100% среднего заработка. Минимальный страховой стаж для получения выплат — 6 месяцев."}},{"@type":"Question","name":"Кто оплачивает больничный?","acceptedAnswer":{"@type":"Answer","text":"С 1 июля 2026 года: первые 5 календарных дней в году — работодатель, с 6-го дня — напрямую ГССФ (Государственный страховой социальный фонд)."}},{"@type":"Question","name":"Какой максимальный срок больничного?","acceptedAnswer":{"@type":"Answer","text":"До 182 календарных дней в год (при туберкулёзе — до 240). Далее решает МСЭК."}},{"@type":"Question","name":"Облагается ли больничный налогом?","acceptedAnswer":{"@type":"Answer","text":"Да, НДФЛ 12% и ИНПС 0,1% удерживаются. Социальный налог не начисляется."}},{"@type":"Question","name":"Как оплачивается больничный по уходу за ребёнком?","acceptedAnswer":{"@type":"Answer","text":"До 14 календарных дней за ребёнком до 14 лет, до 30 дней за ребёнком-инвалидом."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Больничный","description":"Рассчитайте оплату больничного листа. Зависит от стажа работы и среднего заработка сотрудника.","url":"https://calk.uz/ru/calculator/bolnichnyy","datePublished":"2025-03-10","dateModified":"2025-12-18","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/bolnichnyy"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Больничный","description":"Пошаговое руководство по использованию калькулятора: Больничный","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Введите стаж работы","text":"Укажите общий трудовой стаж для определения процента оплаты."},{"@type":"HowToStep","position":2,"name":"Укажите дни больничного","text":"Введите количество дней нетрудоспособности по больничному листу."},{"@type":"HowToStep","po