2:T15e8,[{"@context":"https://schema.org","@type":"WebPage","name":"Калькулятор НДС","description":"Выделите или начислите НДС 12%. Быстрый расчёт суммы налога на добавленную стоимость для любых сумм.","url":"https://calk.uz/ru/calculator/nds","inLanguage":"ru","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/ru/calculator/nds#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/ru/calculator/nds/opengraph-image"},"dateModified":"2026-01-14"},{"@context":"https://schema.org","@type":"WebApplication","name":"Калькулятор НДС","description":"Выделите или начислите НДС 12%. Быстрый расчёт суммы налога на добавленную стоимость для любых сумм.","url":"https://calk.uz/ru/calculator/nds","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"ru","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/ru/calculator/nds#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Главная","item":"https://calk.uz/ru"},{"@type":"ListItem","position":2,"name":"Налоги","item":"https://calk.uz/ru/category/tax"},{"@type":"ListItem","position":3,"name":"Калькулятор НДС","item":"https://calk.uz/ru/calculator/nds"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Какая ставка НДС в Узбекистане?","acceptedAnswer":{"@type":"Answer","text":"Стандартная ставка НДС составляет 12%. Экспорт облагается по ставке 0%."}},{"@type":"Question","name":"Как выделить НДС из суммы?","acceptedAnswer":{"@type":"Answer","text":"Разделите сумму с НДС на 112 и умножьте на 12. Формула: НДС = Сумма с НДС × 12 / 112. Например, из 1 120 000 сум НДС = 120 000 сум."}},{"@type":"Question","name":"Как начислить НДС на сумму?","acceptedAnswer":{"@type":"Answer","text":"Умножьте сумму без НДС на 0,12. Например, 1 000 000 × 0,12 = 120 000 сум НДС. Итого с НДС: 1 120 000 сум."}},{"@type":"Question","name":"Кто обязан платить НДС?","acceptedAnswer":{"@type":"Answer","text":"Юридические лица и ИП с оборотом более 1 млрд сум за 12 месяцев. Остальные могут зарегистрироваться добровольно."}},{"@type":"Question","name":"Какие товары и услуги освобождены от НДС?","acceptedAnswer":{"@type":"Answer","text":"Образовательные и медицинские услуги, финансовые услуги, аренда жилых помещений, ритуальные услуги, ряд продуктов питания."}},{"@type":"Question","name":"Как часто сдавать отчётность по НДС?","acceptedAnswer":{"@type":"Answer","text":"Крупные плательщики (оборот >100 млрд сум) — ежемесячно, остальные — ежеквартально. Срок — до 20-го числа месяца после отчётного периода."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Калькулятор НДС","description":"Выделите или начислите НДС 12%. Быстрый расчёт суммы налога на добавленную стоимость для любых сумм.","url":"https://calk.uz/ru/calculator/nds","datePublished":"2025-05-22","dateModified":"2026-01-14","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/ru/author/konstantin-yakovlev","jobTitle":"Основатель и руководитель проекта Calk.UZ","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"ru","mainEntityOfPage":"https://calk.uz/ru/calculator/nds"},{"@context":"https://schema.org","@type":"HowTo","name":"Как пользоваться: Калькулятор НДС","description":"Пошаговое руководство по использованию калькулятора: Калькулятор НДС","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Введите сумму","text":"Укажите сумму, для которой нужно рассчитать НДС."},{"@type":"HowToStep","position":2,"name":"Выберите операцию","text":"Выберите «Начислить НДС» (добавить 12%) или «Выделить НДС» (извлечь из суммы)."},{"@type":"HowToStep","position":3,"name":"Получите результат","text":"Нажмите «Рассчитать» — получите сумму НДС, сумму без НДС и сумму с НДС."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
