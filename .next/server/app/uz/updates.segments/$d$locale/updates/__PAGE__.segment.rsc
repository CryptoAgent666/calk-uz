8:["$","section","2026-05-23",{"children":[["$","h2",null,{"className":"text-lg font-semibold text-foreground mb-5 pb-2 border-b border-border","children":"2026-yil 23-may"}],["$","div",null,{"className":"space-y-3","children":[["$","article","0",{"className":"rounded-xl border border-border bg-card p-5","children":[["$","h3",null,{"className":"font-semibold text-foreground leading-snug mb-1.5","children":"Kalkulyator sahifalarida «Qisqa javob» bloki"}],["$","p",null,{"className":"text-sm text-muted-foreground leading-relaxed","children":"Kalkulyatorlarning asosiy maqolasi tepasiga «Qisqa javob» bloki qo'shildi — dolzarb raqamlar (2026-yil stavkalari va summalari) bilan 1–3 jumlalik to'g'ridan-to'g'ri javob. Hisob mohiyatini darhol tushunishga yordam beradi va saytning AI-qidiruvda (ChatGPT, Perplexity, Google AI Overviews) iqtibos keltirilishini oshiradi. 20 dan ortiq kalkulyator qamrab olindi."}]]}],["$","article","1",{"className":"rounded-xl border border-border bg-card p-5","children":[["$","h3",null,{"className":"font-semibold text-foreground leading-snug mb-1.5","children":"Foiz stavkalarini ko'rsatish aniqligi"}],["$","p",null,{"className":"text-sm text-muted-foreground leading-relaxed","children":"Stavkalar jadvallaridagi suzuvchi nuqtali sonlarni yaxlitlash xatolari tuzatildi: endi, masalan, 0,33999999% o'rniga 0,34% ko'rsatiladi. Bu hisob-kitoblarning o'ziga ta'sir qilmadi — faqat jadvallardagi sonlar ko'rinishiga."}]]}],["$","article","2",{"className":"rounded-xl border border-border bg-card p-5","children":[["$","h3",null,{"className":"font-semibold text-foreground leading-snug mb-1.5","children":"Strukturalashgan ma'lumotlar va muallif sahifasi"}],["$","p",null,{"className":"text-sm text-muted-foreground leading-relaxed","children":"Schema.org razmetkasi chuqurlashtirildi — qidiruv tizimlari va AI-xizmatlar sahifa mazmunini osonroq tushunadi. Muallif biografiyasi qisqartirildi va faktlarga muvofiqlashtirildi (loyihalar xronologiyasi: Zanimaem.kz — 2016, Calk.kz — 2025, Profinance.kz va Calk.UZ — 2026)."}]]}]]}]]}]
9:["$","section","2026-05-03",{"children":[["$","h2",null,{"className":"text-lg font-semibold text-foreground mb-5 pb-2 border-b border-border","children":"2026-yil 3-may"}],["$","div",null,{"className":"space-y-3","children":[["$","article","0",{"className":"rounded-xl border border-border bg-card p-5","children":[["$","h3",null,{"className":"font-semibold text-foreground leading-snug mb-1.5","children":"Transport solig'i — stavkalar Soliq kodeksining 446-moddasiga muvofiqlashtirildi"}],["$","p",null,{"className":"text-sm text-muted-foreground leading-relaxed","children":"Kalkulyator o'zboshimcha stavkalardan foydalanardi (1, 2, 3, 5, 7, 10 BHK). Endi stavkalar qonunga muvofiq: 1.5 l gacha — 1.5 BHK (618 000), 1.5–2.0 l — 3 BHK (1 236 000), 2.0–3.0 l — 5 BHK (2 060 000), 3.0 l dan ortiq — 7.5 BHK (3 090 000). Yosh koeffitsiyenti olib tashlandi — Soliq kodeksi uni nazarda tutmaydi (stavka faqat dvigatel hajmiga bog'liq)."}]]}],["$","article","1",{"className":"rounded-xl border border-border bg-card p-5","children":[["$","h3",null,{"className":"font-semibold text-foreground leading-snug mb-1.5","children":"Standart USD kursi yangilandi"}],["$","p",null,{"className":"text-sm text-muted-foreground leading-relaxed","children":"USD/UZS zaxira kursi 12 780 dan 11 938 so'mga tushirildi — bu MB ning 2026-yil 1-may holati. Cbu.uz ning jonli kursi mavjud bo'lmaganda bojxona, viza va pul o'tkazmalari kalkulyatorlariga ta'sir qiladi. So'm ikki hafta ichida dollarga nisbatan taxminan 6,6% ga mustahkamlandi."}]]}]]}]]}]
