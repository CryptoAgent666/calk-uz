2:T11bf,[{"@context":"https://schema.org","@type":"WebPage","name":"Avtokredit","description":"Avtokreditni hisoblang: oylik to'lov, boshlang'ich to'lov va kredit muddati davomidagi ortiqcha to'lov.","url":"https://calk.uz/uz/calculator/avtokredit","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/avtokredit#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/avtokredit/opengraph-image"},"dateModified":"2025-10-20"},{"@context":"https://schema.org","@type":"WebApplication","name":"Avtokredit","description":"Avtokreditni hisoblang: oylik to'lov, boshlang'ich to'lov va kredit muddati davomidagi ortiqcha to'lov.","url":"https://calk.uz/uz/calculator/avtokredit","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/avtokredit#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Kreditlar","item":"https://calk.uz/uz/category/credit"},{"@type":"ListItem","position":3,"name":"Avtokredit","item":"https://calk.uz/uz/calculator/avtokredit"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O'zbekistonda avtokredit stavkalari qanday?","acceptedAnswer":{"@type":"Answer","text":"19-24% dan (mahalliy avto maxsus dasturlari, UzAuto — 0% bo'lib to'lash) 33% gacha (tijorat stavkalari). O'rtacha — yillik 22-28%."}},{"@type":"Question","name":"Avtokredit uchun boshlang'ich to'lov qancha kerak?","acceptedAnswer":{"@type":"Answer","text":"Odatda avtomobil qiymatining 20% dan 40% gacha. Qancha ko'p to'lov — shuncha past stavka va ortiqcha to'lov."}},{"