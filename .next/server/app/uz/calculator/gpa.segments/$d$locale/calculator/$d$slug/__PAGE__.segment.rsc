2:T101f,[{"@context":"https://schema.org","@type":"WebPage","name":"GPA kalkulyatori","description":"O'rtacha GPA ballni hisoblang. Baholarni o'zbek tizimidan xalqaro shkala bo'yicha o'tkazing.","url":"https://calk.uz/uz/calculator/gpa","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/gpa#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/gpa/opengraph-image"},"dateModified":"2025-06-25"},{"@context":"https://schema.org","@type":"WebApplication","name":"GPA kalkulyatori","description":"O'rtacha GPA ballni hisoblang. Baholarni o'zbek tizimidan xalqaro shkala bo'yicha o'tkazing.","url":"https://calk.uz/uz/calculator/gpa","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/gpa#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Ta'lim","item":"https://calk.uz/uz/category/education"},{"@type":"ListItem","position":3,"name":"GPA kalkulyatori","item":"https://calk.uz/uz/calculator/gpa"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Baholarni GPAga qanday o'girish mumkin?","acceptedAnswer":{"@type":"Answer","text":"5 = 4.0, 4 = 3.0, 3 = 2.0, 2 = 0. Har bir fanning kreditlarini hisobga olgan holda o'rtacha tortilgan qiymatni hisoblang."}},{"@type":"Question","name":"Xorijda magistratura uchun qanday GPA kerak?","acceptedAnswer":{"@type":"Answer","text":"AQSh (top): 3.7 dan. Buyuk Britaniya: 3.5 dan. Germaniya: 3.0 dan. «El-yurt umidi» dasturi: 3.5 dan."}},{"@type":"Question","name":"GPAni qanday oshirish mumkin?","acceptedAnswer":{"@type":"Answer","text":"Past baholi fanlarni qayta topshiring (3→4 GPAga +0,07-0,15 beradi). Yuqori baholi qo'shimcha kurslar oling."}},{"@type":"Question","name":"GPA hisoblashda kreditlar hisobga olinadimi?","acceptedAnswer":{"@type":"Answer","text":"Ha, GPA — o'rtacha tortilgan qiymat. 5 kreditli fan 2 kreditliga qaraganda kuchliroq ta'sir qiladi."}},{"@type":"Question","name":"WES bahosi nima?","acceptedAnswer":{"@type":"Answer","text":"World Education Services — xorijiy OTMlar uchun GPA verifikatsiyasi. Narxi ~$200. AQSh va Kanadaga kirish uchun tavsiya etiladi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"GPA kalkulyatori","description":"O'rtacha GPA ballni hisoblang. Baholarni o'zbek tizimidan xalqaro shkala bo'yicha o'tkazing.","url":"https://calk.uz/uz/calculator/gpa","datePublished":"2025-05-25","dateModified":"2025-06-25","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/gpa"},{"@context":"https://schema.org","@type":"HowTo","name":"GPA kalkulyatoridan qanday foydalanish","description":"GPA kalkulyatoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Fanlarni kiriting","text":"Fan nomlarini va olingan baholarni qo'shing."},{"@type":"HowToStep","position":2,"name":"Kreditlarni ko'rsating","text":"Har bir fan bo'yicha kreditlar (soatlar) sonini kiriting."},{"@type":"HowToStep","position":3,"name":"GPA ni ol