2:T12d5,[{"@context":"https://schema.org","@type":"WebPage","name":"Kredit kalkulyatori","description":"Kreditning oylik to'lovi, ortiqcha to'lov va to'liq qiymatini hisoblang. Annuitet va differentsial jadvallar.","url":"https://calk.uz/uz/calculator/kredit","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/kredit#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/kredit/opengraph-image"},"dateModified":"2026-03-16"},{"@context":"https://schema.org","@type":"WebApplication","name":"Kredit kalkulyatori","description":"Kreditning oylik to'lovi, ortiqcha to'lov va to'liq qiymatini hisoblang. Annuitet va differentsial jadvallar.","url":"https://calk.uz/uz/calculator/kredit","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/kredit#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Kreditlar","item":"https://calk.uz/uz/category/credit"},{"@type":"ListItem","position":3,"name":"Kredit kalkulyatori","item":"https://calk.uz/uz/calculator/kredit"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O'zbekistonda kreditlar bo'yicha o'rtacha stavka qancha?","acceptedAnswer":{"@type":"Answer","text":"MB kalit stavkasi — 14%. Iste'mol kreditlari: yillik 22-33%. Ipoteka: 17-22% (subsidiyali) / 23-31% (tijorat). Avtokredit: 22-33%."}},{"@type":"Question","name":"Annuitet va differentsial to'lov nima?","acceptedAnswer":{"@type":"Answer","text":"Annuitet — har oy bir xil summa. Differentsial — kamayib boruvchi to'lov. Differentsial ortiqcha to'lov bo'yicha foydaliroq."}},{"@type":"Question","name":"Kreditni muddatidan oldin to'lash mumkinmi?","acceptedAnswer":{"@type":"Answer","text":"Ha, 2020-yildan jarimasisz ruxsat etilgan. Foizlar haqiqiy muddat uchun qayta hisoblanadi."}},{"@type":"Question","name":"Kredit bo'yicha maksimal to'lov miqdori qancha?","acceptedAnswer":{"@type":"Answer","text":"Banklar oylik to'lovni qarz oluvchining sof daromadining 50% bilan cheklaydi."}},{"@type":"Question","name":"Kredit olish uchun qanday hujjatlar kerak?","acceptedAnswer":{"@type":"Answer","text":"Pasport, daromad to'g'risida ma'lumotnoma, kredit tarixi. Garovli kreditlar uchun — mulk hujjatlari."}},{"@type":"Question","name":"Kredit bo'yicha ortiqcha to'lovni qanday kamaytirish mumkin?","acceptedAnswer":{"@type":"Answer","text":"Differentsial sxemani tanlang, kredit muddatini qisqartiring, qisman muddatidan oldin to'lovlar qiling, stavkalar pasayganda qayta moliyalashni ko'rib chiqing."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Kredit kalkulyatori","description":"Kreditning oylik to'lovi, ortiqcha to'lov va to'liq qiymatini hisoblang. Annuitet va differentsial jadvallar.","url":"https://calk.uz/uz/calculator/kredit","datePublished":"2025-05-09","dateModified":"2026-03-16","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/kredit"},{"@context":"https://schema.org","@type":"HowTo","name":"Kredit kalkulyatoridan qanday foydalanish","description":"Kredit kalkulyatoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT3M","step":[{"@type":"HowToStep","position":1,"name":"Kredit summasini kiriting","text":"Kerakli kredit summasini o'zbek so'mida kiriting."},{"@type":"HowToStep","position":2,"name":"Foiz stavkasini ko'rsating","text":"Bankning yillik foiz stavkasini kiriting."},{"@type":"HowToStep","position":3,"name":"Kredit muddatini tanlang","text":"Kreditlash muddatini oylar yoki yillarda ko'rsating."},{"@type":"HowToStep","position":4,"name":"To'lov turini tanlang","text":"Annuitet (teng qismlar) yoki differensial (kamayuvchi) turni tanlang."},{"@type":"HowToStep","position":5,"name":"To'lov jadvalini oling","text":"«Hisoblash» tugmasini bosing va oylik to'lov, ortiqcha to'lov va to'liq jadvalni ko'ring."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
