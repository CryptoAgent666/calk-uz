2:Tfe2,[{"@context":"https://schema.org","@type":"WebPage","name":"Foiz kalkulyatori","description":"Sonning foizini, foizli nisbatni va o'zgarishni hisoblang. Foizlar bilan barcha amallar.","url":"https://calk.uz/uz/calculator/foiz","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/foiz#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/foiz/opengraph-image"},"dateModified":"2026-03-04"},{"@context":"https://schema.org","@type":"WebApplication","name":"Foiz kalkulyatori","description":"Sonning foizini, foizli nisbatni va o'zgarishni hisoblang. Foizlar bilan barcha amallar.","url":"https://calk.uz/uz/calculator/foiz","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/foiz#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Asboblar","item":"https://calk.uz/uz/category/tools"},{"@type":"ListItem","position":3,"name":"Foiz kalkulyatori","item":"https://calk.uz/uz/calculator/foiz"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Sondan foizni qanday topish mumkin?","acceptedAnswer":{"@type":"Answer","text":"Son × Foiz / 100. Masalan, 800 000 so'mdan 25% = 800 000 × 25 / 100 = 200 000 so'm."}},{"@type":"Question","name":"Foiz nisbatini qanday bilish mumkin?","acceptedAnswer":{"@type":"Answer","text":"Qism / Butun × 100. Masalan, 600 000 dan 150 000 = 150 000 / 600 000 × 100 = 25%."}},{"@type":"Question","name":"Foiz o'zgarishni qanday hisoblash mumkin?","acceptedAnswer":{"@type":"Answer","text":"(Yangi − Eski) / Eski × 100%. 500 000 edi, 650 000 bo'ldi: o'sish = 30%."}},{"@type":"Question","name":"12% QQSni qanday tez hisoblash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Summani 0,12 ga ko'paytiring. 5 000 000 so'm uchun: QQS = 600 000 so'm, QQS bilan jami = 5 600 000 so'm."}},{"@type":"Question","name":"Inflyatsiyani hisobga olgan real daromadlilikni qanday hisoblash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Real daromadlilik ≈ Nominal − Inflyatsiya. Omonat 24% − inflyatsiya 10% = ~14% real daromadlilik."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Foiz kalkulyatori","description":"Sonning foizini, foizli nisbatni va o'zgarishni hisoblang. Foizlar bilan barcha amallar.","url":"https://calk.uz/uz/calculator/foiz","datePublished":"2025-02-02","dateModified":"2026-03-04","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/foiz"},{"@context":"https://schema.org","@type":"HowTo","name":"Foiz kalkulyatoridan qanday foydalanish","description":"Foiz kalkulyatoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Hisoblash turini tanlang","text":"Tanlang: sondan foiz topish, foizdan son topish yoki foiz nisbatini aniqlash."},{"@type":"HowToStep","position":2,"name":"Qiymatlarni kiriting","text":"Tanlangan turga qarab raqamli maydonlarni to'ldiring."},{"@type":"HowToStep","position":3,"name":"Natijani oling","text":"«Hisoblash» tugmasini