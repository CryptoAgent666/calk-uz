2:T1128,[{"@context":"https://schema.org","@type":"WebPage","name":"O'qish narxi","description":"O'zbekiston oliy ta'lim muassasalarida o'qish narxini hisoblang. Kontrakt, stipendiya va qo'shimcha xarajatlar.","url":"https://calk.uz/uz/calculator/oqish-narxi","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/oqish-narxi#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/oqish-narxi/opengraph-image"},"dateModified":"2025-09-15"},{"@context":"https://schema.org","@type":"WebApplication","name":"O'qish narxi","description":"O'zbekiston oliy ta'lim muassasalarida o'qish narxini hisoblang. Kontrakt, stipendiya va qo'shimcha xarajatlar.","url":"https://calk.uz/uz/calculator/oqish-narxi","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/oqish-narxi#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Ta'lim","item":"https://calk.uz/uz/category/education"},{"@type":"ListItem","position":3,"name":"O'qish narxi","item":"https://calk.uz/uz/calculator/oqish-narxi"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"OTMda o'qish qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"Davlat: yiliga 12-30 mln. Tibbiyot: 25-45 mln. Xususiy: 15-50 mln. Xorijiy filiallar: 25-80 mln. Byudjet — bepul."}},{"@type":"Question","name":"Ta'lim kreditlari bormi?","acceptedAnswer":{"@type":"Answer","text":"Ha, banklar (Ipoteka bank, Kapitalbank) o'qish tugagunga qadar kechiktirish bilan 7 yilgacha muddatga 14-18% stavkada kreditlar taklif etadi."}},{"@type":"Question","name":"Qo'shimcha xarajatlar qanday?","acceptedAnswer":{"@type":"Answer","text":"Darsliklar: yiliga 1-3 mln, yotoqxona: 1-3 mln, ovqatlanish: 3-5 mln, transport: 0,5-1,2 mln. Jami: boshqa shahardagi talabalar uchun yiliga 5-12 mln."}},{"@type":"Question","name":"Byudjet o'rinlari qancha?","acceptedAnswer":{"@type":"Answer","text":"Barcha o'rinlarning taxminan 20-25%. DTM natijalari bo'yicha taqsimlanadi. Shuningdek nomli stipendiya va grantlar mavjud."}},{"@type":"Question","name":"Eng qimmat OTMlar qaysilar?","acceptedAnswer":{"@type":"Answer","text":"Xorijiy filiallar: Westminster (45 mln dan), INHA (35 mln dan). Mahalliylardan: tibbiyot OTMlari — yiliga 45 mln so'mgacha."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"O'qish narxi","description":"O'zbekiston oliy ta'lim muassasalarida o'qish narxini hisoblang. Kontrakt, stipendiya va qo'shimcha xarajatlar.","url":"https://calk.uz/uz/calculator/oqish-narxi","datePublished":"2025-09-25","dateModified":"2025-09-15","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/oqish-narxi"},{"@context":"https://schema.org","@type":"HowTo","name":"O'qish narxidan qanday foydalanish","description":"O'qish narxidan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Universitetni tanlang","text":"O'zbekiston universitetlari ro'yxatidan OTMni tanlang."},{"@type":"HowToStep",