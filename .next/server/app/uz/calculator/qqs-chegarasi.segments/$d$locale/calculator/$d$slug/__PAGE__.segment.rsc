2:T10b1,[{"@context":"https://schema.org","@type":"WebPage","name":"QQS chegarasi","description":"Daromadingiz O'zbekistonda QQS bo'yicha majburiy ro'yxatga olish chegarasiga yetganligini tekshiring.","url":"https://calk.uz/uz/calculator/qqs-chegarasi","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/qqs-chegarasi#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/qqs-chegarasi/opengraph-image"},"dateModified":"2026-01-14"},{"@context":"https://schema.org","@type":"WebApplication","name":"QQS chegarasi","description":"Daromadingiz O'zbekistonda QQS bo'yicha majburiy ro'yxatga olish chegarasiga yetganligini tekshiring.","url":"https://calk.uz/uz/calculator/qqs-chegarasi","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/qqs-chegarasi#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Soliqlar","item":"https://calk.uz/uz/category/tax"},{"@type":"ListItem","position":3,"name":"QQS chegarasi","item":"https://calk.uz/uz/calculator/qqs-chegarasi"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"QQS bo'yicha majburiy ro'yxatdan o'tish chegarasi qancha?","acceptedAnswer":{"@type":"Answer","text":"Ketma-ket 12 oy uchun 1 mlrd so'm."}},{"@type":"Question","name":"Ixtiyoriy ro'yxatdan o'tish mumkinmi?","acceptedAnswer":{"@type":"Answer","text":"Ha, har qanday aylanmada. QQS to'lovchilari bilan ishlashda foydali — ular sizning QQSni hisobga olishi mumkin."}},{"@type":"Question","name":"Ro'yxatdan o'tmasdan chegaradan oshsa nima bo'ladi?","acceptedAnswer":{"@type":"Answer","text":"Oshish davri uchun QQS qayta hisoblanadi va ro'yxatsiz ishlangan davrdagi daromadning 5% miqdorida, lekin kamida 5 000 000 so'm jarima solinadi (SK 219-moddasi)."}},{"@type":"Question","name":"12 oylik aylanma qanday hisoblanadi?","acceptedAnswer":{"@type":"Answer","text":"Sirpanuvchi usulda: joriy sanadan oxirgi 12 oy olinadi, kalendar yil emas. Barcha sotish turlari jamlanadi."}},{"@type":"Question","name":"Ixtiyoriy ro'yxatdan o'tish qachon foydali?","acceptedAnswer":{"@type":"Answer","text":"Mijozlar QQS to'lovchilari bo'lganda (B2B). Chakana savdo (B2C) uchun odatda foydasiz, chunki narxlarni 12% ga oshirishga to'g'ri keladi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"QQS chegarasi","description":"Daromadingiz O'zbekistonda QQS bo'yicha majburiy ro'yxatga olish chegarasiga yetganligini tekshiring.","url":"https://calk.uz/uz/calculator/qqs-chegarasi","datePublished":"2025-09-08","dateModified":"2026-01-14","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/qqs-chegarasi"},{"@context":"https://schema.org","@type":"HowTo","name":"QQS chegarasidan qanday foydalanish","description":"QQS chegarasidan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Tushumni kiriting","text":"Biznesingizning yillik tushumini so'mda kiriting."},{"@type":"HowToStep","position":2,"name":"Faoliya