2:T188f,[{"@context":"https://schema.org","@type":"WebPage","name":"JSHSHS kalkulyatori","description":"O'zbekistonda jismoniy shaxslarning daromad solig'ini hisoblang. 12% stavka va IT Park rezidentlari uchun imtiyozlarni hisobga oladi.","url":"https://calk.uz/uz/calculator/jshshs","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/jshshs#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/jshshs/opengraph-image"},"dateModified":"2025-10-09"},{"@context":"https://schema.org","@type":"WebApplication","name":"JSHSHS kalkulyatori","description":"O'zbekistonda jismoniy shaxslarning daromad solig'ini hisoblang. 12% stavka va IT Park rezidentlari uchun imtiyozlarni hisobga oladi.","url":"https://calk.uz/uz/calculator/jshshs","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/jshshs#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Soliqlar","item":"https://calk.uz/uz/category/tax"},{"@type":"ListItem","position":3,"name":"JSHSHS kalkulyatori","item":"https://calk.uz/uz/calculator/jshshs"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"2026-yilda O'zbekistonda JShShS stavkasi qancha?","acceptedAnswer":{"@type":"Answer","text":"Standart JShShS stavkasi 12% — rezidentlar uchun ham, norezidentlar uchun ham (O'zbekistondagi manbalardan olingan daromadlar bo'yicha). IT Park rezidentlari uchun imtiyozli stavka 7,5%."}},{"@type":"Question","name":"Ish haqidan JShShSni qanday hisoblash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Hisoblangan ish haqini 0,12 ga ko'paytiring. Masalan, 10 000 000 so'm ish haqida JShShS 1 200 000 so'm. Shuningdek IJPH 0,1% (10 000 so'm) ushlab qolinadi."}},{"@type":"Question","name":"Qanday daromadlar JShShSga tortilmaydi?","acceptedAnswer":{"@type":"Answer","text":"Tortilmaydi: nafaqa, pensiya, stipendiya, yiliga 4,22 BHK gacha moddiy yordam (1 738 640 so'm), ishdan bo'shatilgandagi kompensatsiya, sug'urta to'lovlari."}},{"@type":"Question","name":"JShShS deklaratsiyasini qachon topshirish kerak?","acceptedAnswer":{"@type":"Answer","text":"Hisobot yilidan keyingi yilning 1-aprelgacha. Bir nechta manbadan daromad olganlar uchun majburiy. my.soliq.uz orqali topshiriladi."}},{"@type":"Question","name":"Uy-joy sotib olganda mulkiy chegirma qancha?","acceptedAnswer":{"@type":"Answer","text":"Chegirma 500 BHK gacha (2025-yil avgustidan 206 000 000 so'm). Umr davomida bir marta beriladi."}},{"@type":"Question","name":"IT Park xodimlari uchun JShShS qanday farq qiladi?","acceptedAnswer":{"@type":"Answer","text":"IT Park rezidentlari 12% o'rniga 7,5% stavkada JShShS to'laydilar. 10 mln so'm ish haqida oylik tejamkorlik 450 000 so'm."}},{"@type":"Question","name":"JShShSni to'lamaganlik uchun jarima qancha?","acceptedAnswer":{"@type":"Answer","text":"O'z vaqtida to'lamaganlik uchun har bir kechiktirilgan kun uchun MB qayta moliyalash stavkasining 1/300 qismi miqdorida penya hisoblanadi (MB stavkasi 14% da — 0,047%/kun, yillik 17,0%)."}},{"@type":"Question","name":"Ish haqim mahalla orqali to'lansa, JShShS qanday ushlanadi?","acceptedAnswer":{"@type":"Answer","text":"Mahalla orqali rasmiy ish haqi to'lanadigan bo'lsa (masalan, ijtimoiy ish o'rinlari), to'lovchi tashkilot soliq agenti sifatida ishlaydi va 12% JShShSni o'zi ushlab qoladi. Sizning xatti-harakatingiz talab qilinmaydi."}},{"@type":"Question","name":"Frilanser bo'lsam, daromad solig'ini qanday to'layman?","acceptedAnswer":{"@type":"Answer","text":"2026-yildan boshlab samozanyat (o'z-o'zini band qilgan) shaxs sifatida ro'yxatdan o'tib, aylanmadan 1% stavkada soliq to'lashingiz mumkin — bu YaTTga o'tishdan ko'ra arzon. Ro'yxatdan o'tish my.soliq.uz orqali bepul."}},{"@type":"Question","name":"Daromadim 100 mln dan oshsa, qo'shimcha soliq bormi?","acceptedAnswer":{"@type":"Answer","text":"Yo'q — O'zbekistondagi JShShS yagona tekis stavkadir, daromad oshsa ham 12% qoladi (IT Park rezidentlari uchun 7,5%). Bu Rossiya yoki Qozog'istondagi progressiv tizimdan farq qiladi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"JSHSHS kalkulyatori","description":"O'zbekistonda jismoniy shaxslarning daromad solig'ini hisoblang. 12% stavka va IT Park rezidentlari uchun imtiyozlarni hisobga oladi.","url":"https://calk.uz/uz/calculator/jshshs","datePublished":"2025-05-16","dateModified":"2025-10-09","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/jshshs"},{"@context":"https://schema.org","@type":"HowTo","name":"JSHSHS kalkulyatoridan qanday foydalanish","description":"JSHSHS kalkulyatoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Daromadni kiriting","text":"Davr uchun daromad summasini o'zbek so'mida kiriting."},{"@type":"HowToStep","position":2,"name":"Chegirmalarni tanlang","text":"Tegishli soliq chegirmalari va imtiyozlarni belgilang (IT Park, nogironlik va boshq.)."},{"@type":"HowToStep","position":3,"name":"«Hisoblash» tugmasini bosing","text":"Kalkulyator JShShS 12% stavkasini qo'llaydi va ko'rsatilgan chegirmalarni hisobga oladi."},{"@type":"HowToStep","position":4,"name":"Natijani o'rganing","text":"To'lanadigan JShShS summasini, samarali stavkani va soliqdan keyingi sof daromadni ko'ring."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
