2:T1108,[{"@context":"https://schema.org","@type":"WebPage","name":"Chegirma kalkulyatori","description":"Chegirma bilan narx va tejash summasini hisoblang. Bir nechta ketma-ket chegirmalarni qo'llab-quvvatlaydi.","url":"https://calk.uz/uz/calculator/chegirma","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/chegirma#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/chegirma/opengraph-image"},"dateModified":"2025-08-15"},{"@context":"https://schema.org","@type":"WebApplication","name":"Chegirma kalkulyatori","description":"Chegirma bilan narx va tejash summasini hisoblang. Bir nechta ketma-ket chegirmalarni qo'llab-quvvatlaydi.","url":"https://calk.uz/uz/calculator/chegirma","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/chegirma#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Asboblar","item":"https://calk.uz/uz/category/tools"},{"@type":"ListItem","position":3,"name":"Chegirma kalkulyatori","item":"https://calk.uz/uz/calculator/chegirma"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Chegirmani qanday hisoblash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Narx × (100 − Chegirma%) / 100. Masalan, 2 000 000 so'mlik tovar 15% chegirma bilan: 2 000 000 × 0,85 = 1 700 000 so'm."}},{"@type":"Question","name":"Ikki chegirma qanday ishlaydi?","acceptedAnswer":{"@type":"Answer","text":"Ikkinchi chegirma allaqachon pasaytirilgan narxga qo'llaniladi. 20% + 10% = 30% emas, balki 28% haqiqiy chegirma. Natijani kalkulyator bilan tekshiring."}},{"@type":"Question","name":"Chegirma foizini qanday bilish mumkin?","acceptedAnswer":{"@type":"Answer","text":"(Boshlang'ich − Yangi) / Boshlang'ich × 100. 500 000 so'm edi, 350 000 bo'ldi: (500 000 − 350 000) / 500 000 × 100 = 30%."}},{"@type":"Question","name":"O'zbekistonda eng katta chegirmalar qachon bo'ladi?","acceptedAnswer":{"@type":"Answer","text":"Qora juma (noyabr, 50% gacha), yangi yil savdosi (dekabr-yanvar, 70% gacha), yozgi chegirmalar (iyul-avgust, 50% gacha)."}},{"@type":"Question","name":"Bozorda kalkulyator bilan savdolashish mumkinmi?","acceptedAnswer":{"@type":"Answer","text":"Ha, Chorsu va Olay bozorlarida savdolashish o'rinli. Kalkulyator taklif qilingan chegirma va yakuniy narxni tezda tekshirishga yordam beradi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Chegirma kalkulyatori","description":"Chegirma bilan narx va tejash summasini hisoblang. Bir nechta ketma-ket chegirmalarni qo'llab-quvvatlaydi.","url":"https://calk.uz/uz/calculator/chegirma","datePublished":"2025-05-17","dateModified":"2025-08-15","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/chegirma"},{"@context":"https://schema.org","@type":"HowTo","name":"Chegirma kalkulyatoridan qanday foydalanish","description":"Chegirma kalkulyatoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Boshlang'ich narxni kiriting","text":"Tovarning chegirmadan oldingi narxini kiriting."},{"@type":"HowToStep","position":2,"name":"Chegirma miqdorini ko'rsating","text":"Chegirma foizini kiriting."},{"@type":"HowToStep","position":3,"name":"Yakuniy narxni oling","text":"«Hisoblash» tugmasini bosing — chegirmali narx va tejamkorlik summasini bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
