2:T10a1,[{"@context":"https://schema.org","@type":"WebPage","name":"OYU kalkulyatori","description":"Kunlik oqsil, yog' va uglevodlar me'yorini hisoblang. Maqsadlaringiz uchun optimal OYU balansi.","url":"https://calk.uz/uz/calculator/oyu","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/oyu#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/oyu/opengraph-image"},"dateModified":"2025-08-10"},{"@context":"https://schema.org","@type":"WebApplication","name":"OYU kalkulyatori","description":"Kunlik oqsil, yog' va uglevodlar me'yorini hisoblang. Maqsadlaringiz uchun optimal OYU balansi.","url":"https://calk.uz/uz/calculator/oyu","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/oyu#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Salomatlik","item":"https://calk.uz/uz/category/health"},{"@type":"ListItem","position":3,"name":"OYU kalkulyatori","item":"https://calk.uz/uz/calculator/oyu"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Qanday BYU nisbati optimal?","acceptedAnswer":{"@type":"Answer","text":"Saqlash: oqsillar 30%, yog'lar 25%, uglevodlar 45%. Oriqlamoq: oqsillar 35-40%, uglevodlar 30-35%. Massa oshirish: uglevodlar 50-55%."}},{"@type":"Question","name":"Kuniga qancha oqsil kerak?","acceptedAnswer":{"@type":"Answer","text":"Faol turmush tarzida 1,5-2 g/kg. 80 kg odam uchun: 120-160 g. Mashg'ulotlarda: 2,2 g/kg gacha (176 g)."}},{"@type":"Question","name":"KBYUni qanday hisoblash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Kunlik kaloriyalarni aniqlang (kaloriya kalkulyatori), keyin taqsimlang: oqsillar (×4 kkal/g), yog'lar (×9 kkal/g), uglevodlar (×4 kkal/g)."}},{"@type":"Question","name":"Oshda qancha KBYU bor?","acceptedAnswer":{"@type":"Answer","text":"Bir porsiya osh (~400 g): ~800 kkal, 40 g oqsil, 35 g yog', 90 g uglevod."}},{"@type":"Question","name":"KBYU hisoblamasdan oriqlamoq mumkinmi?","acceptedAnswer":{"@type":"Answer","text":"Mumkin, lekin KBYU nazorati tadqiqotlarga ko'ra samaradorlikni 30-50% ga oshiradi. Aniq hisoblash mushak yo'qotilishining oldini oladi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"OYU kalkulyatori","description":"Kunlik oqsil, yog' va uglevodlar me'yorini hisoblang. Maqsadlaringiz uchun optimal OYU balansi.","url":"https://calk.uz/uz/calculator/oyu","datePublished":"2025-09-15","dateModified":"2025-08-10","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/oyu"},{"@context":"https://schema.org","@type":"HowTo","name":"OYU kalkulyatoridan qanday foydalanish","description":"OYU kalkulyatoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Shaxsiy ma'lumotlarni kiriting","text":"Yosh, jins, bo'y va vaznni ko'rsating."},{"@type":"HowToStep","position":2,"name":"Maqsadni tanlang","text":"Maqsadni ko'rsating: ozish, vaznni saqlash yoki massa yig'ish."},{"@type":"HowToStep","position":3,"na