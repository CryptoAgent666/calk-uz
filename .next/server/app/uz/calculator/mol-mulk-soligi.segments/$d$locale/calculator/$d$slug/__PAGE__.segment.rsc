2:T1223,[{"@context":"https://schema.org","@type":"WebPage","name":"Mol-mulk solig'i","description":"Jismoniy va yuridik shaxslarning mol-mulk solig'ini hisoblang. Maydon, kadastr qiymati va obyekt turini hisobga oladi.","url":"https://calk.uz/uz/calculator/mol-mulk-soligi","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/mol-mulk-soligi#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/mol-mulk-soligi/opengraph-image"},"dateModified":"2026-01-22"},{"@context":"https://schema.org","@type":"WebApplication","name":"Mol-mulk solig'i","description":"Jismoniy va yuridik shaxslarning mol-mulk solig'ini hisoblang. Maydon, kadastr qiymati va obyekt turini hisobga oladi.","url":"https://calk.uz/uz/calculator/mol-mulk-soligi","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/mol-mulk-soligi#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Soliqlar","item":"https://calk.uz/uz/category/tax"},{"@type":"ListItem","position":3,"name":"Mol-mulk solig'i","item":"https://calk.uz/uz/calculator/mol-mulk-soligi"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Mol-mulk solig'i stavkasi qancha?","acceptedAnswer":{"@type":"Answer","text":"Jismoniy shaxslar uchun (2026-yildan, +7% indeksatsiya): 0,36% (200 m² gacha), 0,48% (200-500 m²), 0,64% (500 m² dan ortiq) kadastr qiymatidan. Pasaytirilgan — 0,70%. Yuridik shaxslar uchun: qoldiq qiymatdan 1,5%."}},{"@type":"Question","name":"Kim mol-mulk solig'idan ozod?","acceptedAnswer":{"@type":"Answer","text":"Yoshi bo'yicha pensionerlar (bitta ob'ekt), I-II guruh nogironlari, urush ishtirokchilari, ko'p bolali oilalar (4+ bola), yolg'iz pensionerlar."}},{"@type":"Question","name":"Qachon to'lash kerak?","acceptedAnswer":{"@type":"Answer","text":"Teng ikki qismda 15-aprel va 15-oktabrgacha. Kechiktirilganda — MB qayta moliyalash stavkasining 1/300 qismi kuniga penya (MB stavkasi 14% da — 0,047%/kun)."}},{"@type":"Question","name":"Kadastr qiymatini qanday bilish mumkin?","acceptedAnswer":{"@type":"Answer","text":"kadastr.uz portali yoki Kadastr palatasining hududiy bo'linmasi orqali. Oshirib ko'rsatilgan bo'lsa qiymatga e'tiroz bildirilishi mumkin."}},{"@type":"Question","name":"Yangi qurilgan uy-joylar soliqqa tortiladimi?","acceptedAnswer":{"@type":"Answer","text":"Ha, kadastr raqami olingandan keyin. Yangi qurilishlar kadastr qiymati odatda sotib olish narxiga yaqin bo'ladi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Mol-mulk solig'i","description":"Jismoniy va yuridik shaxslarning mol-mulk solig'ini hisoblang. Maydon, kadastr qiymati va obyekt turini hisobga oladi.","url":"https://calk.uz/uz/calculator/mol-mulk-soligi","datePublished":"2025-09-08","dateModified":"2026-01-22","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/mol-mulk-soligi"},{"@context":"https://schema.org","@type":"HowTo","name":"Mol-mulk solig'idan qanday foydalanish","description":"Mol-mulk solig'idan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Obyekt turini tanlang","text":"Mulk turini ko'rsating: kvartira, uy, tijorat ko'chmas mulki."},{"@type":"HowToStep","position":2,"name":"Maydonni kiriting","text":"Obyektning umumiy maydonini kvadrat metrlarda kiriting."},{"@type":"HowToStep","position":3,"name":"Kadastr qiymatini ko'rsating","text":"Obyektning kadastr qiymatini kiriting (agar ma'lum bo'lsa)."},{"@type":"HowToStep","position":4,"name":"Soliq hisobini oling","text":"«Hisoblash» tugmasini bosing — yillik mol-mulk solig'ini bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
