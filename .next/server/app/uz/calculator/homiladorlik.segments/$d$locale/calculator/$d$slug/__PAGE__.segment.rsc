2:T1128,[{"@context":"https://schema.org","@type":"WebPage","name":"Homiladorlik kalkulyatori","description":"Homiladorlik muddati, taxminiy tug'ruq sanasi va joriy haftani hisoblang. Oxirgi hayz sanasi bo'yicha.","url":"https://calk.uz/uz/calculator/homiladorlik","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/homiladorlik#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/homiladorlik/opengraph-image"},"dateModified":"2025-07-05"},{"@context":"https://schema.org","@type":"WebApplication","name":"Homiladorlik kalkulyatori","description":"Homiladorlik muddati, taxminiy tug'ruq sanasi va joriy haftani hisoblang. Oxirgi hayz sanasi bo'yicha.","url":"https://calk.uz/uz/calculator/homiladorlik","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/homiladorlik#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Salomatlik","item":"https://calk.uz/uz/category/health"},{"@type":"ListItem","position":3,"name":"Homiladorlik kalkulyatori","item":"https://calk.uz/uz/calculator/homiladorlik"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Tug'ilish sanasini qanday hisoblash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Oxirgi hayzning birinchi kuni + 280 kun (40 hafta). Yoki kalkulyatorga sanani kiriting — u UZI sanalari bilan avtomatik hisoblaydi."}},{"@type":"Question","name":"Homiladorlik necha hafta davom etadi?","acceptedAnswer":{"@type":"Answer","text":"Oxirgi hayzning birinchi kunidan 40 hafta (280 kun). Normal tug'ilish: 37-42 hafta. Faqat 5% tug'ilishlar aniq TTSda bo'ladi."}},{"@type":"Question","name":"UZI qachon qilish kerak?","acceptedAnswer":{"@type":"Answer","text":"Uchta majburiy UZI: 11-14 hafta (1-skrining), 18-22 hafta (2-skrining), 30-34 hafta (3-UZI). Ayollar maslahatxonasida — bepul."}},{"@type":"Question","name":"O'zbekistonda tug'ruq qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"Davlat tug'ruqxonasida — bepul. Xususiy klinikalarda: xizmat darajasiga qarab 5-25 mln so'm."}},{"@type":"Question","name":"Shifokorga qanchalik tez-tez tashrif buyurish kerak?","acceptedAnswer":{"@type":"Answer","text":"28 haftagacha — oyda 1 marta, 28-36 hafta — oyda 2 marta, 36 haftadan keyin — har hafta. Ayollar maslahatxonasida kuzatish bepul."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Homiladorlik kalkulyatori","description":"Homiladorlik muddati, taxminiy tug'ruq sanasi va joriy haftani hisoblang. Oxirgi hayz sanasi bo'yicha.","url":"https://calk.uz/uz/calculator/homiladorlik","datePublished":"2025-07-25","dateModified":"2025-07-05","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/homiladorlik"},{"@context":"https://schema.org","@type":"HowTo","name":"Homiladorlik kalkulyatoridan qanday foydalanish","description":"Homiladorlik kalkulyatoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Sanani kiriting","text":"Oxirgi hayz birinchi kuni yoki homiladorlik sanasini kiriting."},{"@type":"HowToStep","position":2,"name":"Hisoblash usulini tanlang","text":"Hayz sanasi yoki homiladorlik sanasi bo'yicha hisoblashni tanlang."},{"@type":"HowToStep","position":3,"name":"Natijani oling","text":"«Hisoblash» tugmasini bosing — taxminiy tug'ilish sanasi va homiladorlik muddatini bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
