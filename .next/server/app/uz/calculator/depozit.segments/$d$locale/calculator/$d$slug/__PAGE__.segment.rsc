2:T117b,[{"@context":"https://schema.org","@type":"WebPage","name":"Depozit kalkulyatori","description":"O'zbekistonda bank depoziti bo'yicha daromadni hisoblang. Muddat, stavka va foizlarning kapitalizatsiyasini hisobga oladi.","url":"https://calk.uz/uz/calculator/depozit","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/depozit#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/depozit/opengraph-image"},"dateModified":"2026-02-26"},{"@context":"https://schema.org","@type":"WebApplication","name":"Depozit kalkulyatori","description":"O'zbekistonda bank depoziti bo'yicha daromadni hisoblang. Muddat, stavka va foizlarning kapitalizatsiyasini hisobga oladi.","url":"https://calk.uz/uz/calculator/depozit","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/depozit#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Depozitlar","item":"https://calk.uz/uz/category/deposit"},{"@type":"ListItem","position":3,"name":"Depozit kalkulyatori","item":"https://calk.uz/uz/calculator/depozit"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"2026-yilda so'mdagi omonat stavkalari qanday?","acceptedAnswer":{"@type":"Answer","text":"Bank va muddatga qarab yillik 20% dan 26% gacha. Eng foydali stavkalar — 12-24 oylik muddatli omonatlarda."}},{"@type":"Question","name":"Omonat foizlari soliqqa tortiladimi?","acceptedAnswer":{"@type":"Answer","text":"Ha, depozit foizlari rezidentlar uchun 5% (norezidentlar uchun 10%) stavkada JShShSga tortiladi. Bank foizlarni to'lashda soliqni avtomatik ravishda ushlab qoladi."}},{"@type":"Question","name":"Omonatlar bo'yicha qancha summa kafolatlanadi?","acceptedAnswer":{"@type":"Answer","text":"Bir omonatchiga bir bankda 200 000 000 so'mgacha. Omonatlarni kafolatlash fondi tomonidan kafolatlanadi."}},{"@type":"Question","name":"Foizlar kapitalizatsiyasi nima?","acceptedAnswer":{"@type":"Answer","text":"Avval hisoblangan foizlarga foiz hisoblash. Oylik kapitalizatsiyada samarali stavka nominaldan yuqori (24% → 26,82%)."}},{"@type":"Question","name":"Valyutali omonat stavkalari qanday?","acceptedAnswer":{"@type":"Answer","text":"Dollar/yevroda yillik 4% dan 7% gacha. So'mdagiga qaraganda past, lekin valyuta xavfisiz."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Depozit kalkulyatori","description":"O'zbekistonda bank depoziti bo'yicha daromadni hisoblang. Muddat, stavka va foizlarning kapitalizatsiyasini hisobga oladi.","url":"https://calk.uz/uz/calculator/depozit","datePublished":"2025-09-10","dateModified":"2026-02-26","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/depozit"},{"@context":"https://schema.org","@type":"HowTo","name":"Depozit kalkulyatoridan qanday foydalanish","description":"Depozit kalkulyatoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Omonat summasini kiriting","text":"Depozitga joylashtirmoqchi bo'lgan summaningizni kiriting."},{"@type":"HowToStep","position":2,"name":"Foiz stavkasini ko'rsating","text":"Bankning omonat bo'yicha yillik foiz stavkasini kiriting."},{"@type":"HowToStep","position":3,"name":"Omonat muddatini tanlang","text":"Depozit joylashtirish muddatini oylarda ko'rsating."},{"@type":"HowToStep","position":4,"name":"Daromadni oling","text":"«Hisoblash» tugmasini bosing — hisoblangan foiz summasini va yakuniy summani bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
