2:T1441,[{"@context":"https://schema.org","@type":"WebPage","name":"Umumiy kommunal","description":"Oylik kommunal to'lovlarning umumiy summasini hisoblang. Barcha uy-joy kommunal xizmatlari bitta kalkulyatorda.","url":"https://calk.uz/uz/calculator/umumiy-kommunal","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/umumiy-kommunal#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/umumiy-kommunal/opengraph-image"},"dateModified":"2026-02-02"},{"@context":"https://schema.org","@type":"WebApplication","name":"Umumiy kommunal","description":"Oylik kommunal to'lovlarning umumiy summasini hisoblang. Barcha uy-joy kommunal xizmatlari bitta kalkulyatorda.","url":"https://calk.uz/uz/calculator/umumiy-kommunal","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/umumiy-kommunal#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Kommunal","item":"https://calk.uz/uz/category/utilities"},{"@type":"ListItem","position":3,"name":"Umumiy kommunal","item":"https://calk.uz/uz/calculator/umumiy-kommunal"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Toshkentda kommunal xizmatlar o'rtacha qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"2 xonali kvartira: yozda 400 000-800 000 so'm, qishda 600 000-1 200 000 so'm. Xususiy uy: qishda 3 000 000 so'mgacha."}},{"@type":"Question","name":"Qaysi xizmat eng qimmat?","acceptedAnswer":{"@type":"Answer","text":"Qishda — gaz (isitish), barcha xarajatlarning 40% gacha. Yozda — elektr energiya (konditsioner), 30-40%."}},{"@type":"Question","name":"Kommunal to'lovlarni qanday kamaytirish mumkin?","acceptedAnswer":{"@type":"Answer","text":"Hisoblagichlar (suvda 50% gacha tejash), izolyatsiya (gazda 30-50%), LED-lampalar (yorug'likda 80%), ilovalar orqali iste'molni nazorat qilish."}},{"@type":"Question","name":"Kommunal xizmatlarni qachon to'lash kerak?","acceptedAnswer":{"@type":"Answer","text":"Hisob-kitob oyidan keyingi oyning 10-sanasigacha. Kechikish uchun — penya."}},{"@type":"Question","name":"Kommunal xizmatlarni qanday to'lash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Mobil ilovalar (Click, Payme, Uzum), bank terminallari, kassalar orqali. Eng qulay usul — mobil ilovadagi avtoto'lov."}},{"@type":"Question","name":"Hisoblagichlar yo'q bo'lsa, kommunal qanday hisoblanadi?","acceptedAnswer":{"@type":"Answer","text":"Hisoblagich bo'lmagan xonadonlar uchun me'yor bo'yicha hisob ishlatiladi: bir kishiga belgilangan miqdor (suv, gaz, elektr). Tariflar Vazirlar Mahkamasi qarorlari bilan tasdiqlanadi va tashkilotlar veb-saytlarida e'lon qilinadi."}},{"@type":"Question","name":"Mahallada elektr o'chsa, hisob qaytariladimi?","acceptedAnswer":{"@type":"Answer","text":"Yo'q, avtomatik qayta hisob amalga oshmaydi. Lekin uzilish 24 soatdan oshsa, «Hududiy elektr tarmoqlari» ga ariza yozsangiz, qisman kompensatsiya yoki hisobni qayta ko'rib chiqishni so'rashingiz mumkin."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Umumiy kommunal","description":"Oylik kommunal to'lovlarning umumiy summasini hisoblang. Barcha uy-joy kommunal xizmatlari bitta kalkulyatorda.","url":"https://calk.uz/uz/calculator/umumiy-kommunal","datePublished":"2025-03-13","dateModified":"2026-02-02","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/umumiy-kommunal"},{"@context":"https://schema.org","@type":"HowTo","name":"Umumiy kommunaldan qanday foydalanish","description":"Umumiy kommunaldan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Hisoblagich ko'rsatkichlarini kiriting","text":"Elektr (kVt·s), gaz (m³) va suv (m³) sarfini ko'rsating."},{"@type":"HowToStep","position":2,"name":"Uy-joy maydonini ko'rsating","text":"Isitish va chiqindi chiqarish hisobi uchun kvartira maydonini kiriting."},{"@type":"HowToStep","position":3,"name":"Tariflarni tanlang","text":"Tegishli tariflarni tanlang (maishiy, imtiyozli)."},{"@type":"HowToStep","position":4,"name":"Umumiy summani oling","text":"«Hisoblash» tugmasini bosing — oylik kommunal to'lovlarning umumiy summasini bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
