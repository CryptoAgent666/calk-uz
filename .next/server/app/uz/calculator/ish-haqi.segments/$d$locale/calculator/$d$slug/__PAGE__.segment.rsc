2:T1574,[{"@context":"https://schema.org","@type":"WebPage","name":"Ish haqi kalkulyatori","description":"\"Qo'lga\" yoki \"yalpi\" ish haqini hisoblang. O'zbekistondagi JSHSHS, INPS va barcha majburiy ajratmalarni hisobga oladi.","url":"https://calk.uz/uz/calculator/ish-haqi","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/ish-haqi#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/ish-haqi/opengraph-image"},"dateModified":"2025-12-12"},{"@context":"https://schema.org","@type":"WebApplication","name":"Ish haqi kalkulyatori","description":"\"Qo'lga\" yoki \"yalpi\" ish haqini hisoblang. O'zbekistondagi JSHSHS, INPS va barcha majburiy ajratmalarni hisobga oladi.","url":"https://calk.uz/uz/calculator/ish-haqi","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/ish-haqi#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Ish haqi","item":"https://calk.uz/uz/category/salary"},{"@type":"ListItem","position":3,"name":"Ish haqi kalkulyatori","item":"https://calk.uz/uz/calculator/ish-haqi"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"2026-yilda O'zbekistonda minimal ish haqi qancha?","acceptedAnswer":{"@type":"Answer","text":"Minimal ish haqi oyiga 1 271 000 so'm (2025-yildan amal qiladi, 2026-yilda ham saqlanmoqda)."}},{"@type":"Question","name":"Ish haqidan necha foiz ushlab qolinadi?","acceptedAnswer":{"@type":"Answer","text":"JShShS 12% + IJPH 0,1% = hisoblangan ish haqining 12,1%. IT Park uchun: 7,5% + 0,1% = 7,6%."}},{"@type":"Question","name":"Qo'lga tegadigan ish haqini qanday hisoblash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Qo'lga = Hisoblangan × 0,879. Masalan, 10 000 000 × 0,879 = 8 790 000 so'm."}},{"@type":"Question","name":"Ish beruvchi ish haqidan tashqari qancha to'laydi?","acceptedAnswer":{"@type":"Answer","text":"Ish haqi fondidan 12% ijtimoiy soliq (byudjet uchun 25%). 10 mln so'm ish haqida qo'shimcha = 1 200 000 so'm."}},{"@type":"Question","name":"Ortiqcha ish qanday to'lanadi?","acceptedAnswer":{"@type":"Answer","text":"Dastlabki 2 soat — 1,5 baravarda, keyin — ikki baravarda. Dam olish/bayram kunlarida — ikki baravarda yoki qo'shimcha dam olish kuni."}},{"@type":"Question","name":"Ish haqi qanchalik tez-tez to'lanishi kerak?","acceptedAnswer":{"@type":"Answer","text":"Oyiga kamida ikki marta. Kechiktirganlik uchun — MB stavkasining (14%) 1/300 miqdorida har kunlik kompensatsiya."}},{"@type":"Question","name":"OTMda o'qiyotgan bo'lsam, ish beruvchi qo'shimcha imtiyoz beradimi?","acceptedAnswer":{"@type":"Answer","text":"OTM (oliy ta'lim muassasasi) talabasi bo'lib ishlasangiz, qonun bo'yicha ish beruvchi sizga maxsus soliq imtiyozi bermaydi. Lekin yiliga 4,22 BHK gacha bo'lgan moddiy yordam JShShSdan ozod (chegirma o'zingizning my.soliq.uz dagi deklaratsiyangiz orqali)."}},{"@type":"Question","name":"Qishloqda joylashgan ishxonada ish haqi shaharnikidan farq qiladimi?","acceptedAnswer":{"@type":"Answer","text":"Soliq stavkalari bir xil. Lekin minimal ish haqi Vazirlar Mahkamasi qarorlari bilan barcha hududlar uchun bir xil belgilanadi. Tarmoq tarif kelishuvlari ba'zi sohalarda farq qilishi mumkin."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Ish haqi kalkulyatori","description":"\"Qo'lga\" yoki \"yalpi\" ish haqini hisoblang. O'zbekistondagi JSHSHS, INPS va barcha majburiy ajratmalarni hisobga oladi.","url":"https://calk.uz/uz/calculator/ish-haqi","datePublished":"2025-09-16","dateModified":"2025-12-12","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/ish-haqi"},{"@context":"https://schema.org","@type":"HowTo","name":"Ish haqi kalkulyatoridan qanday foydalanish","description":"Ish haqi kalkulyatoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Ish haqini kiriting","text":"Hisoblangan (gross) ish haqi summasini so'mda kiriting."},{"@type":"HowToStep","position":2,"name":"Hisoblash turini tanlang","text":"«Yalpi» (ajratmalardan oldin) yoki «sof» (qo'lga tegadigan) ish haqini kiritayotganingizni tanlang."},{"@type":"HowToStep","position":3,"name":"Imtiyozlarni ko'rsating","text":"JShShS bo'yicha imtiyozlaringiz bo'lsa (nogironlik, urush qatnashchisi va boshq.), belgilang."},{"@type":"HowToStep","position":4,"name":"Natijani oling","text":"«Hisoblash» tugmasini bosing va qo'lga tegadigan summa, JShShS, INPS va barcha ajratmalarni ko'ring."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
