2:T1046,[{"@context":"https://schema.org","@type":"WebPage","name":"Gaz","description":"Uy uchun tabiiy gaz narxini hisoblang. O'zbekistonning qishgi va yozgi tariflari.","url":"https://calk.uz/uz/calculator/gaz","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/gaz#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/gaz/opengraph-image"},"dateModified":"2026-02-04"},{"@context":"https://schema.org","@type":"WebApplication","name":"Gaz","description":"Uy uchun tabiiy gaz narxini hisoblang. O'zbekistonning qishgi va yozgi tariflari.","url":"https://calk.uz/uz/calculator/gaz","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/gaz#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Kommunal","item":"https://calk.uz/uz/category/utilities"},{"@type":"ListItem","position":3,"name":"Gaz","item":"https://calk.uz/uz/calculator/gaz"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O'zbekistonda gaz qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"Bazaviy stavka — ijtimoiy norma doirasida 1 000 so'm/m³ (yozda oyiga 100 m³ gacha, qishda 500 m³ gacha). Normadan oshganda — yuqori tarif."}},{"@type":"Question","name":"Xususiy uy qancha gaz iste'mol qiladi?","acceptedAnswer":{"@type":"Answer","text":"Gaz isitishi bilan: yiliga 2 000-4 000 m³. Isitishsiz (faqat plita): yiliga 300-800 m³. Asosiy iste'mol — qishda."}},{"@type":"Question","name":"Gaz uchun to'lov qanday hisoblanadi?","acceptedAnswer":{"@type":"Answer","text":"Ijtimoiy normalar tizimi bo'yicha: oylik norma doirasida (yozda 100 m³ / qishda 500 m³) — bazaviy stavka 1 000 so'm/m³; normadan ortiqda — yuqori tarif."}},{"@type":"Question","name":"Qishda gaz uchun qancha to'lash kerak?","acceptedAnswer":{"@type":"Answer","text":"Isitishli uy uchun: oyiga 300-500 m³ × 2 000-2 500 so'm = 600 000-1 250 000 so'm/oy. Yozda: 20-50 m³ × 1 000 so'm = 20 000-50 000 so'm."}},{"@type":"Question","name":"Gazni qanday tejash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Devor va derazalarni izolyatsiya qilish (30-50% tejash), dasturlashtiriladigan termostat, qozonni muntazam xizmat qilish, kondensatsion qozon (FIK 95%)."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Gaz","description":"Uy uchun tabiiy gaz narxini hisoblang. O'zbekistonning qishgi va yozgi tariflari.","url":"https://calk.uz/uz/calculator/gaz","datePublished":"2025-03-23","dateModified":"2026-02-04","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/gaz"},{"@context":"https://schema.org","@type":"HowTo","name":"Gazdan qanday foydalanish","description":"Gazdan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Gaz iste'molini kiriting","text":"Oyiga sarflangan gaz hajmini kub metrda (m³) kiriting."},{"@type":"HowToStep","position":2,"name":"Tarifni tanlang","text":"Tarif turini tanlang (maishiy, isitish bilan / isitishsiz)."},{"@type":"HowTo