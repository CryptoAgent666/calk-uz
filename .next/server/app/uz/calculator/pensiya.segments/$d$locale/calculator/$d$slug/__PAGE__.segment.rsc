2:T1371,[{"@context":"https://schema.org","@type":"WebPage","name":"Pensiya","description":"O'zbekistonda taxminiy pensiya miqdorini hisoblang. Ish staji, o'rtacha ish haqi va jamg'arma qismini hisobga oladi.","url":"https://calk.uz/uz/calculator/pensiya","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/pensiya#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/pensiya/opengraph-image"},"dateModified":"2026-02-26"},{"@context":"https://schema.org","@type":"WebApplication","name":"Pensiya","description":"O'zbekistonda taxminiy pensiya miqdorini hisoblang. Ish staji, o'rtacha ish haqi va jamg'arma qismini hisobga oladi.","url":"https://calk.uz/uz/calculator/pensiya","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/pensiya#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Ish haqi","item":"https://calk.uz/uz/category/salary"},{"@type":"ListItem","position":3,"name":"Pensiya","item":"https://calk.uz/uz/calculator/pensiya"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O'zbekistonda pensiya yoshi necha?","acceptedAnswer":{"@type":"Answer","text":"Erkaklar — 60 yosh, ayollar — 55 yosh. 2026-yil iyunidan 20+ yil stajli ayollar 54 yoshda pensiyaga chiqishi mumkin. Muddatidan oldingi pensiya huquqiga ega boshqa toifalar ham bor."}},{"@type":"Question","name":"Minimal pensiya qancha?","acceptedAnswer":{"@type":"Answer","text":"Taxminan 1 BHK (412 000 so'm). Aniq miqdor staj va o'rtacha ish haqiga bog'liq."}},{"@type":"Question","name":"IJPH nima?","acceptedAnswer":{"@type":"Answer","text":"Individual jamg'arma pensiya hisobvarag'i. To'lov ish haqining 0,1%. Shaxsiy mulk, meros qilib qoldiriladi."}},{"@type":"Question","name":"To'liq pensiya uchun qancha staj kerak?","acceptedAnswer":{"@type":"Answer","text":"Erkaklar — 25 yil, ayollar — 20 yil. Kam stajda (7 yildan) — mutanosib pensiya."}},{"@type":"Question","name":"Kim muddatidan oldingi pensiyaga haqli?","acceptedAnswer":{"@type":"Answer","text":"Zararli ishlab chiqarish xodimlari, pedagoglar (25 yil staj), tibbiyot xodimlari (25-30 yil), ko'p bolali onalar (5+ bola — 50 yoshdan)."}},{"@type":"Question","name":"Pensiyaga chiqish yoshi va shartlari qanday?","acceptedAnswer":{"@type":"Answer","text":"Erkaklar uchun 60 yosh (kamida 25 yil staj), ayollar uchun 55 yosh (kamida 20 yil staj). 20+ yil staji bo'lgan ayollar 54 yoshda chiqishi mumkin. Imtiyozli kasblar (shaxtyor, kimyogar) uchun yosh kamayadi."}},{"@type":"Question","name":"Pensiya qaerda olinadi?","acceptedAnswer":{"@type":"Answer","text":"Pensiya bank kartasiga (Uzcard yoki Humo) yoki «Aloqabank», «Xalq banki» ofislariga o'tkaziladi. Ariza my.soliq.uz yoki tuman pensiya jamg'armasi bo'limiga topshiriladi. Tayyor hujjatlar — pasport, mehnat daftarchasi, INPS spravkasi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Pensiya","description":"O'zbekistonda taxminiy pensiya miqdorini hisoblang. Ish staji, o'rtacha ish haqi va jamg'arma qismini hisobga oladi.","url":"https://calk.uz/uz/calculator/pensiya","datePublished":"2025-05-09","dateModified":"2026-02-26","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/pensiya"},{"@context":"https://schema.org","@type":"HowTo","name":"Pensiyadan qanday foydalanish","description":"Pensiyadan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Ish stajini kiriting","text":"Umumiy mehnat stajini yillarda ko'rsating."},{"@type":"HowToStep","position":2,"name":"O'rtacha ish haqini kiriting","text":"O'rtacha oylik ish haqini ko'rsating."},{"@type":"HowToStep","position":3,"name":"Yoshni ko'rsating","text":"Pensiya yoshini aniqlash uchun hozirgi yosh va jinsni kiriting."},{"@type":"HowToStep","position":4,"name":"Pensiya hisobini oling","text":"«Hisoblash» tugmasini bosing — taxminiy pensiya miqdorini va chiqish yoshini bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
