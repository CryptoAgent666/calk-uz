2:T10ae,[{"@context":"https://schema.org","@type":"WebPage","name":"Ta'lim krediti","description":"O'qishni to'lash uchun ta'lim kreditini hisoblang. Imtiyozli stavka va to'lovni kechiktirish.","url":"https://calk.uz/uz/calculator/talim-krediti","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/talim-krediti#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/talim-krediti/opengraph-image"},"dateModified":"2025-10-15"},{"@context":"https://schema.org","@type":"WebApplication","name":"Ta'lim krediti","description":"O'qishni to'lash uchun ta'lim kreditini hisoblang. Imtiyozli stavka va to'lovni kechiktirish.","url":"https://calk.uz/uz/calculator/talim-krediti","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/talim-krediti#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Ta'lim","item":"https://calk.uz/uz/category/education"},{"@type":"ListItem","position":3,"name":"Ta'lim krediti","item":"https://calk.uz/uz/calculator/talim-krediti"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Ta'lim kreditlari stavkalari qanday?","acceptedAnswer":{"@type":"Answer","text":"Yillik 14-18% — bozor stavkalaridan 22-33% ancha past. Stavka MB stavkasiga (14%) bog'langan."}},{"@type":"Question","name":"Qaytarishni qachon boshlash kerak?","acceptedAnswer":{"@type":"Answer","text":"O'qish tugaganidan keyin. O'qish davrida — faqat foizlar (oyiga 1-3 mln so'm) yoki ba'zi banklarda to'liq kechiktirish."}},{"@type":"Question","name":"Qanday hujjatlar kerak?","acceptedAnswer":{"@type":"Answer","text":"Ro'yxatga olish ma'lumotnomasi, pasport, daromadli kafil, kafil daromadlari ma'lumotnomasi, OTM bilan shartnoma."}},{"@type":"Question","name":"Qancha summa olish mumkin?","acceptedAnswer":{"@type":"Answer","text":"O'qish qiymatining 100% gacha, bank va OTMga qarab maksimum 200 mln so'mgacha."}},{"@type":"Question","name":"Kredit bo'yicha ortiqcha to'lov qancha?","acceptedAnswer":{"@type":"Answer","text":"16% stavka va 7 yil muddatda ortiqcha to'lov kredit summasining taxminan 50-60% ni tashkil etadi. Aniq hisoblash uchun kalkulyatordan foydalaning."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Ta'lim krediti","description":"O'qishni to'lash uchun ta'lim kreditini hisoblang. Imtiyozli stavka va to'lovni kechiktirish.","url":"https://calk.uz/uz/calculator/talim-krediti","datePublished":"2025-03-20","dateModified":"2025-10-15","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/talim-krediti"},{"@context":"https://schema.org","@type":"HowTo","name":"Ta'lim kreditidan qanday foydalanish","description":"Ta'lim kreditidan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"O'qish narxini kiriting","text":"Yillik kontrakt narxini kiriting."},{"@type":"HowToStep","position":2,"name":"O'qish muddatini ko'rsating","text":"O'qish yillar sonini kiriting."},{"@type":"HowToStep","positio