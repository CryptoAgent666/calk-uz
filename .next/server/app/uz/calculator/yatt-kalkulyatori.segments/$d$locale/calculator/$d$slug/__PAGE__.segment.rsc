2:T11e4,[{"@context":"https://schema.org","@type":"WebPage","name":"YaTT kalkulyatori","description":"O'zbekistonda yakka tartibdagi tadbirkor uchun soliqlar va ajratmalarni hisoblang.","url":"https://calk.uz/uz/calculator/yatt-kalkulyatori","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/yatt-kalkulyatori#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/yatt-kalkulyatori/opengraph-image"},"dateModified":"2025-09-04"},{"@context":"https://schema.org","@type":"WebApplication","name":"YaTT kalkulyatori","description":"O'zbekistonda yakka tartibdagi tadbirkor uchun soliqlar va ajratmalarni hisoblang.","url":"https://calk.uz/uz/calculator/yatt-kalkulyatori","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/yatt-kalkulyatori#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Biznes","item":"https://calk.uz/uz/category/business"},{"@type":"ListItem","position":3,"name":"YaTT kalkulyatori","item":"https://calk.uz/uz/calculator/yatt-kalkulyatori"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O'zbekistonda YaTT qancha soliq to'laydi?","acceptedAnswer":{"@type":"Answer","text":"Aylanma solig'i 1% (aylanma 1 mlrd so'mgacha) yoki 4% (1 mlrd dan ortiq) + ijtimoiy soliq 412 000 so'm/oy + IJPH 0,1%."}},{"@type":"Question","name":"YaTT o'z-o'zini band qilgandan nimasi bilan farq qiladi?","acceptedAnswer":{"@type":"Answer","text":"YaTT: 1% soliq (1 mlrd gacha), 10 tagacha xodim yollashi mumkin. O'z-o'zini band qilgan (2026-yildan): 1% soliq, xodimsiz, aylanma 1 mlrd/yilgacha."}},{"@type":"Question","name":"YaTTga kassa kerakmi?","acceptedAnswer":{"@type":"Answer","text":"Ha, YaTTlar naqd va karta to'lovlarini qabul qilishda NKT yoki virtual kassadan foydalanishi shart."}},{"@type":"Question","name":"QQS to'lash uchun chegara qancha?","acceptedAnswer":{"@type":"Answer","text":"12 oy davomida 1 mlrd so'm. Bu chegaradan past bo'lsa YaTT QQS to'lamaydi."}},{"@type":"Question","name":"YaTTni qanday ro'yxatdan o'tkazish mumkin?","acceptedAnswer":{"@type":"Answer","text":"my.gov.uz yoki soliq inspektsiyasi orqali. Bepul, 1-3 kun. Pasport kerak, STIR avtomatik beriladi."}},{"@type":"Question","name":"YaTT nechta xodim yollashi mumkin?","acceptedAnswer":{"@type":"Answer","text":"10 kishigacha (2025-yildan ayrim faoliyat turlari uchun 25 tagacha)."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"YaTT kalkulyatori","description":"O'zbekistonda yakka tartibdagi tadbirkor uchun soliqlar va ajratmalarni hisoblang.","url":"https://calk.uz/uz/calculator/yatt-kalkulyatori","datePublished":"2025-04-03","dateModified":"2025-09-04","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/yatt-kalkulyatori"},{"@context":"https://schema.org","@type":"HowTo","name":"YaTT kalkulyatoridan qanday foydalanish","description":"YaTT kalkulyatoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,