2:T12ac,[{"@context":"https://schema.org","@type":"WebPage","name":"O'z-o'zini band qilganlar solig'i","description":"O'zbekistonda o'z-o'zini band qilganlar uchun soliqlarni hisoblang. Belgilangan stavka va soddalashtirilgan hisobot.","url":"https://calk.uz/uz/calculator/oz-ozini-band-qilganlar-soligi","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/oz-ozini-band-qilganlar-soligi#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/oz-ozini-band-qilganlar-soligi/opengraph-image"},"dateModified":"2025-12-10"},{"@context":"https://schema.org","@type":"WebApplication","name":"O'z-o'zini band qilganlar solig'i","description":"O'zbekistonda o'z-o'zini band qilganlar uchun soliqlarni hisoblang. Belgilangan stavka va soddalashtirilgan hisobot.","url":"https://calk.uz/uz/calculator/oz-ozini-band-qilganlar-soligi","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/oz-ozini-band-qilganlar-soligi#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Soliqlar","item":"https://calk.uz/uz/category/tax"},{"@type":"ListItem","position":3,"name":"O'z-o'zini band qilganlar solig'i","item":"https://calk.uz/uz/calculator/oz-ozini-band-qilganlar-soligi"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O'z-o'zini band qilganlik solig'i qancha?","acceptedAnswer":{"@type":"Answer","text":"Aylanmaning 1% (2026-yildan). O'zbekistondagi barcha rejimlar orasida eng past stavka."}},{"@type":"Question","name":"Kim o'z-o'zini band qilgan bo'lishi mumkin?","acceptedAnswer":{"@type":"Answer","text":"Yillik aylanmasi 1 mlrd so'mgacha (2026-yildan limit 100 mln dan 1 mlrd ga oshirildi), yollama xodimsiz, ruxsat etilgan faoliyat turlari bilan jismoniy shaxslar."}},{"@type":"Question","name":"O'z-o'zini band qilgan YaTTdan nimasi bilan farq qiladi?","acceptedAnswer":{"@type":"Answer","text":"O'z-o'zini band qilgan: 1% soliq, xodimsiz, 1 mlrd/yilgacha, minimal hisobot. YaTT: 1% (1 mlrd gacha) yoki 4% (ortiq), 10 tagacha xodim, aylanma cheklovisiz."}},{"@type":"Question","name":"O'z-o'zini band qilganda pensiya staji boradimi?","acceptedAnswer":{"@type":"Answer","text":"Yo'q, ijtimoiy soliq va IJPH hisoblanmaydi. Pensiya uchun ixtiyoriy badal to'lash tavsiya etiladi."}},{"@type":"Question","name":"O'z-o'zini band qilgan sifatida qanday ro'yxatdan o'tish mumkin?","acceptedAnswer":{"@type":"Answer","text":"Mobil ilova yoki my.soliq.uz orqali. Ro'yxatdan o'tish bir necha daqiqa oladi, ofislarga borish shart emas."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"O'z-o'zini band qilganlar solig'i","description":"O'zbekistonda o'z-o'zini band qilganlar uchun soliqlarni hisoblang. Belgilangan stavka va soddalashtirilgan hisobot.","url":"https://calk.uz/uz/calculator/oz-ozini-band-qilganlar-soligi","datePublished":"2025-02-04","dateModified":"2025-12-10","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/oz-ozini-band-qilganlar-soligi"},{"@context":"https://schema.org","@type":"HowTo","name":"O'z-o'zini band qilganlar solig'idan qanday foydalanish","description":"O'z-o'zini band qilganlar solig'idan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Daromadni kiriting","text":"O'z-o'zini band qilishdan oylik yoki yillik daromadni kiriting."},{"@type":"HowToStep","position":2,"name":"Faoliyat turini tanlang","text":"Soliq stavkasini aniqlash uchun faoliyat turini ko'rsating."},{"@type":"HowToStep","position":3,"name":"Hududni ko'rsating","text":"Faoliyat yuritiladigan hududni tanlang."},{"@type":"HowToStep","position":4,"name":"Hisobni oling","text":"«Hisoblash» tugmasini bosing — o'z-o'zini band qilganlarning soliq va badallarini bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
