1a:T11d4,[{"@context":"https://schema.org","@type":"WebPage","name":"Foyda solig'i","description":"Korxona foyda solig'ini hisoblang. O'zbekistonda biznes uchun chegirmalar va imtiyozlarni hisobga olgan holda 15% stavka.","url":"https://calk.uz/uz/calculator/foyda-soligi","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/foyda-soligi#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/foyda-soligi/opengraph-image"},"dateModified":"2026-01-25"},{"@context":"https://schema.org","@type":"WebApplication","name":"Foyda solig'i","description":"Korxona foyda solig'ini hisoblang. O'zbekistonda biznes uchun chegirmalar va imtiyozlarni hisobga olgan holda 15% stavka.","url":"https://calk.uz/uz/calculator/foyda-soligi","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/foyda-soligi#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Soliqlar","item":"https://calk.uz/uz/category/tax"},{"@type":"ListItem","position":3,"name":"Foyda solig'i","item":"https://calk.uz/uz/calculator/foyda-soligi"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Foyda solig'i stavkasi qancha?","acceptedAnswer":{"@type":"Answer","text":"Oddiy yuridik shaxslar uchun 15% (shu jumladan 2026-yildan e-tijorat), banklar, sug'urta va mobil operatorlar uchun 20%, yuqori texnologiyali ishlab chiqarish uchun 0% (ZRU-1104). Soddalashtirilda — aylanmadan 4% (yuridik shaxslar), 1% (1 mlrd gacha YaTTlar)."}},{"@type":"Question","name":"Zararlarni o'tkazish mumkinmi?","acceptedAnswer":{"@type":"Answer","text":"Ha, zararlar keyingi 5 soliq davriga o'tkaziladi, kelajakdagi yillar foydasini kamaytiradi."}},{"@type":"Question","name":"Foyda solig'i bo'yicha qanday imtiyozlar bor?","acceptedAnswer":{"@type":"Answer","text":"EIZ (10 yilgacha ozod qilish), IT Park (tushumdan 1%), ijtimoiy loyihalarga investorlar — pasaytirilgan stavkalar."}},{"@type":"Question","name":"Deklaratsiyani qachon topshirish kerak?","acceptedAnswer":{"@type":"Answer","text":"Hisobot yilidan keyingi yilning 1-aprelgacha. Avans to'lovlari — har chorak birinchi oyining 25-sanasigacha."}},{"@type":"Question","name":"Dividendlarga soliq qancha?","acceptedAnswer":{"@type":"Answer","text":"Ta'sischi-jismoniy shaxslarga to'lanadigan dividendlardan JShShS 5%. Yuridik shaxs-ta'sischilar uchun ham 5%."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Foyda solig'i","description":"Korxona foyda solig'ini hisoblang. O'zbekistonda biznes uchun chegirmalar va imtiyozlarni hisobga olgan holda 15% stavka.","url":"https://calk.uz/uz/calculator/foyda-soligi","datePublished":"2025-08-03","dateModified":"2026-01-25","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/foyda-soligi"},{"@context":"https://schema.org","@type":"HowTo","name":"Foyda solig'idan qanday foydalanish","description":"Foyda solig'idan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Korxona daromadini kiriting","text":"Yuridik shaxsning davr uchun jami daromadini ko'rsating."},{"@type":"HowToStep","position":2,"name":"Chegiriladigan xarajatlarni ko'rsating","text":"Chegirmaga tegishli xarajatlar summasini kiriting."},{"@type":"HowToStep","position":3,"name":"Soliq rejimini tanlang","text":"Soliqqa tortish tizimini ko'rsating (umumiy, soddalashtirilgan, IT Park)."},{"@type":"HowToStep","position":4,"name":"Hisobni oling","text":"«Hisoblash» tugmasini bosing — foyda solig'i summasini va samarali stavkani ko'ring."}]}]11:["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1a"}}],"$L1b","$L1c"]}]
