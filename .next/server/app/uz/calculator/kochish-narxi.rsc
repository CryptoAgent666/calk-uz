20:["$","$L3d",null,{"formats":"$undefined","locale":"uz","messages":{"site_name":"Calk.UZ","site_tagline":"O'zbekiston uchun onlayn kalkulyatorlar","site_description":"Soliqlar, ish haqi, kreditlar, omonatlar va boshqa moliyaviy hisob-kitoblar uchun qulay va aniq onlayn kalkulyatorlar","nav_home":"Bosh sahifa","nav_tax":"Soliqlar","nav_salary":"Ish haqi","nav_credit":"Kreditlar","nav_deposit":"Omonatlar","nav_currency":"Valyuta","nav_auto":"Avto","nav_utilities":"Kommunal xizmatlar","nav_realestate":"Ko'chmas mulk","nav_business":"Biznes","nav_health":"Salomatlik","nav_education":"Ta'lim","nav_religion":"Din","nav_tools":"Asboblar","nav_about":"Biz haqimizda","nav_contact":"Aloqa","hero_title":"O'zbekiston uchun onlayn kalkulyatorlar","hero_subtitle":"Tez va aniq hisob-kitoblar","hero_description":"O'zbekiston uchun moslashtirilgan bepul kalkulyatorlar yordamida soliqlar, ish haqi, kreditlar, omonatlar va boshqalarni hisoblang","hero_search_placeholder":"Kalkulyator qidirish...","calculator_open":"Kalkulyatorni ochish","calculator_calculate":"Hisoblash","calculator_clear":"Tozalash","calculator_result":"Natija","calculator_details":"Hisob-kitob tafsilotlari","category_all":"Barcha kalkulyatorlar","category_tax":"Soliqlar","category_salary":"Ish haqi","category_credit":"Kreditlar","category_deposit":"Omonatlar","category_currency":"Valyuta","category_auto":"Avto","category_utilities":"Kommunal xizmatlar","category_realestate":"Ko'chmas mulk","category_business":"Biznes","category_health":"Salomatlik","category_education":"Ta'lim","category_religion":"Din","category_tools":"Asboblar","category_unique":"Noyob","common_sum":"Summa","common_currency":"Valyuta","common_percent":"Foiz","common_months":"Oylar","common_years":"Yillar","common_per_month":"oyiga","common_per_year":"yiliga","common_total":"Jami","common_loading":"Yuklanmoqda...","footer_description":"Calk.UZ — O'zbekiston aholisi uchun bepul onlayn kalkulyatorlar. Dolzarb stavkalar va tariflar bo'yicha aniq hisob-kitoblar.","footer_quick_links":"Tezkor havolalar","footer_categories":"Kategoriyalar","footer_legal":"Huquqiy ma'lumot","footer_privacy":"Maxfiylik siyosati","footer_terms":"Foydalanish shartlari","footer_disclaimer":"Hisob-kitob natijalari faqat ma'lumot uchun mo'ljallangan bo'lib, yuridik yoki moliyaviy maslahat hisoblanmaydi.","footer_not_government":"Calk.UZ davlat xizmati emas va O'zbekiston Respublikasi davlat organlari bilan bog'liq emas.","disclaimer_not_government_title":"Muhim ma'lumot","disclaimer_not_government_text":"Calk.UZ — xususiy dasturchilar tomonidan yaratilgan mustaqil axborot loyihasidir. Ilova davlat xizmati EMAS va O'zbekiston Respublikasi davlat organlari bilan BOG'LIQ EMAS. Barcha hisoblar rasmiy manbalar (cbu.uz, lex.uz, soliq.uz) asosida ma'lumotnoma xarakteriga ega bo'lib, moliyaviy yoki yuridik maslahat hisoblanmaydi. Moliyaviy qarorlar qabul qilish uchun malakali mutaxassislarga murojaat qilishni tavsiya etamiz.","footer_copyright":"© {year} Calk.UZ. Barcha huquqlar himoyalangan.","theme_light":"Yorug'","theme_dark":"Qorong'u","theme_system":"Tizim","language_ru":"Ruscha","language_uz":"O'zbek","breadcrumb_home":"Bosh sahifa","error_404_title":"Sahifa topilmadi","error_404_description":"So'ralgan sahifa mavjud emas yoki ko'chirilgan.","error_404_back":"Bosh sahifaga qaytish","related_calculators":"Aloqador kalkulyatorlar","no_results_title":"Kalkulyatorlar topilmadi","no_results_description":"Qidiruv so'rovini o'zgartirib ko'ring","about_title":"Calk.UZ haqida","about_description":"Calk.UZ — O'zbekiston aholisi uchun bepul onlayn kalkulyatorlar","about_mission":"Bizning maqsadimiz — O'zbekiston har bir fuqarosi uchun moliyaviy hisob-kitoblarni oddiy va qulay qilish.","about_features_title":"Bizning afzalliklarimiz","about_feature_calculators":"78 ta bepul kalkulyator","about_feature_bilingual":"Ikki tilli interfeys (ruscha va o'zbekcha)","about_feature_accurate":"O'zbekistonning dolzarb stavkalari va tariflari","about_feature_mobile":"Mobil qurilmalar uchun optimallashtirilgan","about_feature_dark":"Qulay ishlash uchun qorong'u mavzu","about_feature_free":"Butunlay bepul, ro'yxatdan o'tmasdan","contact_title":"Aloqa","contact_description":"Calk.UZ jamoasi bilan bog'laning — savollarga javob beramiz, takliflarni qabul qilamiz va xatolarni tuzatamiz","contact_email":"Elektron pochta","contact_telegram":"Telegram","contact_feedback":"Agar hisob-kitoblarda xatolik topsangiz, yangi kalkulyator taklif qilmoqchi bo'lsangiz yoki sayt ishlashi bo'yicha savollaringiz bo'lsa — bizga yozing. Biz odatda 24 soat ichida javob beramiz.","contact_when_title":"Qanday masalalar bo'yicha murojaat qilish mumkin","contact_when_error":"Hisob-kitoblarda noaniqlik yoki eskirgan ma'lumotlarni topdingiz","contact_when_suggest":"Yangi kalkulyator yoki funksiya taklif qilmoqchisiz","contact_when_question":"Kalkulyatorlardan foydalanish bo'yicha savollaringiz bor","contact_when_cooperation":"Hamkorlik yoki sheriklik bo'yicha takliflar","contact_faq_title":"Ko'p beriladigan savollar","contact_faq_accuracy_q":"Kalkulyatorlar natijalari qanchalik aniq?","contact_faq_accuracy_a":"Barcha kalkulyatorlar O'zbekistonning amaldagi qonunchiligiga asoslangan. Stavkalar har chorakda yangilanadi. Biroq natijalar faqat ma'lumot uchun mo'ljallangan — rasmiy hisob-kitoblar uchun mutaxassislarga murojaat qiling.","contact_faq_update_q":"Ma'lumotlar qanchalik tez-tez yangilanadi?","contact_faq_update_a":"Stavkalar va tariflar har chorakda yoki yangi normativ hujjatlar kuchga kirganda yangilanadi. Biz lex.uz, cbu.uz, soliq.uz va boshqa rasmiy manbalarni kuzatamiz.","contact_faq_new_q":"Yangi kalkulyator taklif qilsa bo'ladimi?","contact_faq_new_a":"Ha! Biz foydalanuvchilar so'roviga ko'ra muntazam yangi kalkulyatorlar qo'shamiz. info@calk.uz manziliga yoki Telegram @calkuz_bot ga kerakli kalkulyator tavsifi bilan yozing.","contact_response_time":"Odatda 24 soat ichida javob beramiz","privacy_title":"Maxfiylik siyosati","terms_title":"Foydalanish shartlari","more_dropdown":"Yana","mobile_menu_title":"Navigatsiya","calculator_count_badge":"78 ta bepul kalkulyator","results_count":"{count} ta kalkulyator topildi","no_results":"Hech narsa topilmadi","no_results_hint":"So'rovingizni o'zgartirib ko'ring yoki boshqa kategoriyani tanlang","related_title":"Tegishli kalkulyatorlar","calculator_about":"Kalkulyator haqida","coming_soon":"Kalkulyator tez orada tayyor bo'ladi","coming_soon_hint":"Biz ushbu kalkulyatorni ishlab chiqmoqdamiz. Tez orada foydalanish mumkin.","back_to_home":"Bosh sahifaga qaytish","article_heading":"Kalkulyatordan qanday foydalanish","faq_heading":"Ko'p beriladigan savollar","see_also":"Shuningdek qarang","category_page_title":"{category} — onlayn kalkulyatorlar | Calk.UZ","category_page_description":"O'zbekiston aholisi uchun «{category}» kategoriyasidagi bepul onlayn kalkulyatorlar. Dolzarb stavkalar bo'yicha aniq hisob-kitoblar.","category_calculators_count":"{count} ta kalkulyator","category_open_calculator":"Ochish","all_categories":"Barcha kategoriyalar","methodology_title":"Hisob-kitob metodologiyasi","methodology_description":"Calk.UZ da hisob-kitoblar aniqligini qanday ta'minlashimizni bilib oling","methodology_intro_title":"Aniqlikni qanday ta'minlaymiz","methodology_intro_p1":"Calk.UZ dagi barcha kalkulyatorlar O'zbekiston Respublikasining amaldagi qonunchiligiga asoslangan. Hisoblash formulalari Soliq kodeksi, Mehnat kodeksi, Vazirlar Mahkamasi qarorlari va Markaziy bank normativ hujjatlari asosida ishlab chiqilgan.","methodology_intro_p2":"Biz qonunchilikdagi o'zgarishlarni muntazam kuzatib boramiz va natijalarning dolzarbligi hamda aniqligini ta'minlash uchun stavkalar, tariflar va hisoblash formulalarini yangilab turamiz.","methodology_formulas_title":"Formulalar qanday shakllantiriladi","methodology_formulas_p1":"Soliq kalkulyatorlari O'zbekiston Respublikasi Soliq kodeksining moddalariga (xususan, JShShS, QQS, foyda solig'i, yagona soliq to'lovi bo'yicha boblar) asoslangan. Stavkalar va chegaralar Prezident va Vazirlar Mahkamasi yillik qarorlariga muvofiq yangilanadi.","methodology_formulas_p2":"Kredit va depozit kalkulyatorlari standart moliyaviy formulalardan (annuitet va differensial hisoblash) foydalanadi, foiz stavkalari esa O'zbekiston Respublikasi Markaziy banki ma'lumotlariga asoslangan.","methodology_formulas_p3":"Kommunal xizmatlar kalkulyatorlari tegishli tartibga soluvchi organlar tomonidan tasdiqlangan tariflardan foydalanadi. Ish haqi kalkulyatorlari Mehnat kodeksiga muvofiq barcha majburiy ajratmalarni hisobga oladi.","methodology_rates_title":"Stavkalar qanday yangilanadi","methodology_rates_p1":"Stavkalar va tariflar har chorakda yoki yangi normativ hujjatlar kuchga kirganda yangilanadi. Biz quyidagi manbalarni kuzatamiz:","methodology_rates_source_lex":"lex.uz — Qonunchilik milliy bazasi","methodology_rates_source_cbu":"cbu.uz — O'zbekiston Respublikasi Markaziy banki","methodology_rates_source_soliq":"soliq.uz — Davlat soliq qo'mitasi","methodology_rates_source_gazeta":"gazeta.uz — Qonunchilik o'zgarishlari yangiliklari va tahlili","methodology_verification_title":"Ma'lumotlarni tekshirish","methodology_verification_p1":"Har bir kalkulyator tekshiruvdan o'tadi: natijalar rasmiy manbalar, uslubiy qo'llanmalar va davlat organlari tushuntirishlaridagi misollar bilan solishtiriladi. Farqlar aniqlanganda formula tuzatiladi.","methodology_verification_date":"Ma'lumotlarning oxirgi tekshiruvi: 2026-yil mart","methodology_contact_title":"Xato topdingizmi?","methodology_contact_p1":"Agar hisob-kitoblarda noaniqlik yoki eskirgan ma'lumotlarni topsangiz, iltimos, info@calk.uz manziliga yoki Telegram @calkuz_bot orqali xabar bering. Biz ma'lumotni tezkor tekshirib, tuzatamiz.","about_mission_p1":"Calk.UZ O'zbekistonning har bir fuqarosi soliqlar, ish haqi, kredit to'lovlari, kommunal xizmatlar va boshqa moliyaviy ko'rsatkichlarni tez va aniq hisoblashi uchun yaratilgan. Biz moliyaviy savodxonlik ishonchli hisoblash vositalariga kirishdan boshlanishini tushunamiz va maqsadimiz — bunday vositalarni bepul, ro'yxatdan o'tmasdan va cheklovlarsiz taqdim etish.","about_mission_p2":"Jamoamiz kalkulyatorlarning funksionalligini kengaytirish va aniqligini oshirish ustida doimiy ishlaydi. Biz O'zbekiston qonunchiligidagi o'zgarishlarni kuzatamiz, stavkalar va tariflarni yangilaymiz, shuningdek foydalanuvchilar so'roviga ko'ra yangi kalkulyatorlar qo'shamiz. Calk.UZ — bu shunchaki kalkulyatorlar to'plami emas, balki O'zbekiston uchun to'laqonli moliyaviy hisob-kitoblar platformasi.","about_methodology_title":"Aniqlikni qanday ta'minlaymiz","about_methodology_p1":"Calk.UZ dagi barcha hisoblash formulalari O'zbekiston Respublikasining amaldagi qonunchiligiga asoslangan: Soliq kodeksi, Mehnat kodeksi, Vazirlar Mahkamasi qarorlari va tartibga soluvchi organlarning normativ hujjatlari. Stavkalar va tariflar har chorakda yangilanadi.","about_methodology_p2":"Hisob-kitob natijalari rasmiy manbalar va uslubiy materiallar bilan solishtiriladi. Qonunchilik o'zgarganda kalkulyatorlar qisqa muddatda yangilanadi.","about_editorial_title":"Tahririyat siyosati","about_editorial_p1":"Sayt kontenti O'zbekistonning soliq va bank tizimini yaxshi biladigan moliya sohasidagi mutaxassislar tomonidan tekshiriladi. Har bir kalkulyator nashr etilishidan oldin ko'p bosqichli tekshiruvdan o'tadi.","about_sources_title":"Ma'lumot manbalari","about_source_lex":"lex.uz — O'zbekiston Respublikasi qonunchiligining milliy bazasi","about_source_cbu":"cbu.uz — Markaziy bank: valyuta kurslari, qayta moliyalash stavkasi","about_source_soliq":"soliq.uz — Davlat soliq qo'mitasi: stavkalar va tushuntirishlar","about_source_stat":"stat.uz — Davlat statistika qo'mitasi: iqtisodiy ko'rsatkichlar","about_source_mf":"mf.uz — Moliya vazirligi: byudjet ma'lumotlari va normativlar","about_team_title":"Loyiha ortida kim turibdi","about_team_p1":"Calk.UZ O'zbekistonning soliq va bank tizimida tajribaga ega dasturchilar va moliya mutaxassislari jamoasi tomonidan yaratilgan va qo'llab-quvvatlanmoqda. Biz texnik bilimlar va mahalliy qonunchilikni tushunishni birlashtirgan holda aniq va qulay hisoblash vositalarini yaratamiz.","about_team_p2":"Loyiha 2025-yildan beri rivojlanmoqda va foydalanuvchilar — buxgalterlar, tadbirkorlar va oddiy fuqarolarning fikr-mulohazalari tufayli doimiy kengaymoqda.","about_audience_title":"Calk.UZ kim uchun yaratilgan","about_audience_accountants":"Buxgalterlar va moliyachilar — soliq va ish haqi bo'yicha hisob-kitoblarni tezkor tekshirish uchun","about_audience_entrepreneurs":"Tadbirkorlar va YaTT — soliq yuklamasi va kredit to'lovlarini rejalashtirish uchun","about_audience_citizens":"Oddiy fuqarolar — kommunal to'lovlar, kreditlar, omonatlar va valyuta konvertatsiyasini hisoblash uchun","about_audience_students":"Talabalar — O'zbekistonning amaliy misollarida moliyaviy hisob-kitoblarni o'rganish uchun","about_stats_title":"Raqamlarda Calk.UZ","about_stats_calculators":"78 ta kalkulyator","about_stats_categories":"14 ta kategoriya","about_stats_updates":"Har chorakda yangilanadi","about_stats_languages":"2 ta interfeys tili","home_intro_title":"O'zbekiston uchun moliyaviy kalkulyatorlar","home_intro_p1":"Calk.UZ — O'zbekiston aholisi uchun eng yirik bepul moliyaviy kalkulyatorlar platformasi. Barcha 78 ta kalkulyator amaldagi qonunchilik asosida ishlaydi: Soliq kodeksi, Mehnat kodeksi, Markaziy bank stavkalari va tasdiqlangan tariflar. Natijalar har chorakda yangilanadi.","home_intro_p2":"JShShS, QQS, ish haqi, kredit to'lovlari, kommunal xizmatlar, avtomobil bojxona qiymatini va boshqalarni hisoblang — bepul, ro'yxatdan o'tmasdan, ruscha va o'zbekcha tillarda. Ma'lumotlar rasmiy manbalardan olinadi: lex.uz, cbu.uz, soliq.uz.","cookie_message":"Bu sayt tahlil va ishlashni yaxshilash uchun cookie fayllaridan foydalanadi.","cookie_accept":"Qabul qilish","cookie_decline":"Rad etish","last_updated":"Oxirgi yangilanish","sources_title":"Manbalar","reviewed_by":"Calk.UZ tahririyati tomonidan tekshirilgan","article_h3_how_it_works":"Kalkulyator qanday ishlaydi","article_h3_formula":"Hisoblash formulasi","article_h3_example":"Hisoblash misoli","article_h3_considerations":"Nimalarni hisobga olish kerak","article_h3_tips":"Foydali maslahatlar","article_tables_heading":"Ma'lumotnoma va tariflar","footer_data_verified":"Ma'lumotlar rasmiy manbalar bo'yicha tekshirilgan","footer_methodology":"Metodologiya","howto_heading":"Qanday foydalanish","howto_step":"Qadam","howto_time":"Hisoblash vaqti","howto_minutes":"daq."},"now":"$undefined","timeZone":"UTC","children":["$L3e","$L3f","$L40","$L41"]}]
