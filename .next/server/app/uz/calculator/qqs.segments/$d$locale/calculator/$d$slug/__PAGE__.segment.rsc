2:T138d,[{"@context":"https://schema.org","@type":"WebPage","name":"QQS kalkulyatori","description":"QQS 12% ni ajratib oling yoki hisoblang. Har qanday summa uchun qo'shilgan qiymat solig'ini tez hisoblash.","url":"https://calk.uz/uz/calculator/qqs","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/qqs#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/qqs/opengraph-image"},"dateModified":"2026-01-14"},{"@context":"https://schema.org","@type":"WebApplication","name":"QQS kalkulyatori","description":"QQS 12% ni ajratib oling yoki hisoblang. Har qanday summa uchun qo'shilgan qiymat solig'ini tez hisoblash.","url":"https://calk.uz/uz/calculator/qqs","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/qqs#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Soliqlar","item":"https://calk.uz/uz/category/tax"},{"@type":"ListItem","position":3,"name":"QQS kalkulyatori","item":"https://calk.uz/uz/calculator/qqs"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O'zbekistonda QQS stavkasi qancha?","acceptedAnswer":{"@type":"Answer","text":"Standart QQS stavkasi 12%. Eksportga 0% stavka qo'llaniladi."}},{"@type":"Question","name":"Summadan QQSni qanday ajratish mumkin?","acceptedAnswer":{"@type":"Answer","text":"QQS bilan summani 112 ga bo'ling va 12 ga ko'paytiring. Formula: QQS = QQS bilan summa × 12 / 112."}},{"@type":"Question","name":"Summaga QQSni qanday hisoblash mumkin?","acceptedAnswer":{"@type":"Answer","text":"QQSsiz summani 0,12 ga ko'paytiring. Masalan, 1 000 000 × 0,12 = 120 000 so'm QQS."}},{"@type":"Question","name":"QQS to'lash kimga majburiy?","acceptedAnswer":{"@type":"Answer","text":"12 oy davomida aylanmasi 60 000 BHK (24,72 mlrd so'm) dan ortiq yuridik shaxslar va YaTTlarga. Qolganlari ixtiyoriy ro'yxatdan o'tishi mumkin."}},{"@type":"Question","name":"Qanday tovar va xizmatlar QQSdan ozod?","acceptedAnswer":{"@type":"Answer","text":"Ta'lim va tibbiy xizmatlar, moliyaviy xizmatlar, turar-joy ijarasi, dafn marosimlari xizmatlari."}},{"@type":"Question","name":"QQS bo'yicha hisobotni qanchalik tez-tez topshirish kerak?","acceptedAnswer":{"@type":"Answer","text":"Yirik to'lovchilar (aylanma >100 mlrd so'm) — har oy, qolganlari — har chorak. Muddat — hisobot davridan keyin oyning 20-sanasigacha."}},{"@type":"Question","name":"Bozorda sotuvchi bo'lsam, QQS to'lashim kerakmi?","acceptedAnswer":{"@type":"Answer","text":"Yo'q, agar 12 oylik aylanmangiz 60 000 BHK (24,72 mlrd so'm) dan kam bo'lsa, QQS to'lovchisi emassiz. Bozordagi ko'pchilik chakana sotuvchilar bu chegaradan oshmaydi."}},{"@type":"Question","name":"Faktura.soliq.uz da hisob-faktura qanday rasmiylashtirish?","acceptedAnswer":{"@type":"Answer","text":"Davlat soliq qo'mitasining faktura.soliq.uz portali orqali. EIMZO yoki Faol kalit bilan kiring, kontragent INNni kiriting, mahsulotni tanlang va imzolang. Hisob-faktura avtomatik kontragentga jo'natiladi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"QQS kalkulyatori","description":"QQS 12% ni ajratib oling yoki hisoblang. Har qanday summa uchun qo'shilgan qiymat solig'ini tez hisoblash.","url":"https://calk.uz/uz/calculator/qqs","datePublished":"2025-05-22","dateModified":"2026-01-14","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/qqs"},{"@context":"https://schema.org","@type":"HowTo","name":"QQS kalkulyatoridan qanday foydalanish","description":"QQS kalkulyatoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Summani kiriting","text":"QQS hisoblash kerak bo'lgan summani kiriting."},{"@type":"HowToStep","position":2,"name":"Amalni tanlang","text":"«QQS hisoblash» (12% qo'shish) yoki «QQS ajratish» (summadan ajratish) ni tanlang."},{"@type":"HowToStep","position":3,"name":"Natijani oling","text":"«Hisoblash» tugmasini bosing — QQS summasini, QQSsiz va QQS bilan summani ko'ring."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
