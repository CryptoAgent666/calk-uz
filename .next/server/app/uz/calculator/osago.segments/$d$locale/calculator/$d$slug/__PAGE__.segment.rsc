2:T1381,[{"@context":"https://schema.org","@type":"WebPage","name":"OSAGO kalkulyatori","description":"O'zbekistonda OSAGO polisi narxini hisoblang. Hudud, tajriba va dvigatel quvvatini hisobga oladi.","url":"https://calk.uz/uz/calculator/osago","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/osago#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/osago/opengraph-image"},"dateModified":"2026-01-14"},{"@context":"https://schema.org","@type":"WebApplication","name":"OSAGO kalkulyatori","description":"O'zbekistonda OSAGO polisi narxini hisoblang. Hudud, tajriba va dvigatel quvvatini hisobga oladi.","url":"https://calk.uz/uz/calculator/osago","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/osago#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Avtomobil","item":"https://calk.uz/uz/category/auto"},{"@type":"ListItem","position":3,"name":"OSAGO kalkulyatori","item":"https://calk.uz/uz/calculator/osago"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O'zbekistonda OSAGO qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"65 000 so'mdan (bazaviy tarif). Koeffitsientlar bilan: Toshkentda tajribali haydovchi uchun — taxminan 94 000 so'm/yil, yangi haydovchi uchun — 199 000 so'mgacha."}},{"@type":"Question","name":"OSAGOsiz haydash uchun jarima qancha?","acceptedAnswer":{"@type":"Answer","text":"Ogohlantirish yoki 0,5 BHK (206 000 so'm) — MJtKning 135-1-moddasi bo'yicha."}},{"@type":"Question","name":"OSAGO bo'yicha maksimal to'lov qancha?","acceptedAnswer":{"@type":"Answer","text":"Sog'likka zarar uchun — 52 mln so'mgacha. Mol-mulkka — 28 mln so'mgacha (umumiy limit 80 mln so'm)."}},{"@type":"Question","name":"Bonus-malus koeffitsienti nima?","acceptedAnswer":{"@type":"Answer","text":"Avariyasiz haydash uchun chegirma: 0,5 dan (5+ yil YTHsiz — 50% chegirma) 2,5 gacha (tez-tez YTH — 150% ustama)."}},{"@type":"Question","name":"OSAGOni onlayn rasmiylashtirish mumkinmi?","acceptedAnswer":{"@type":"Answer","text":"Ha, OSAGO polisini sug'urta kompaniyalari saytlari orqali onlayn sotib olish mumkin."}},{"@type":"Question","name":"OSAGOni qaysi sug'urta kompaniyalaridan xarid qilish mumkin?","acceptedAnswer":{"@type":"Answer","text":"O'zbekistondagi yetakchi sug'urtachilar: Kafolat, Uzagrosugurta, Alskom, Apex Insurance, Gross Insurance, Inson, Trust Insurance. Stavkalar O'zbekiston Respublikasi Moliya vazirligi tomonidan tasdiqlangan va bir xil — farq xizmat sifatida."}},{"@type":"Question","name":"OSAGO yo'q haydovchi jarima qancha?","acceptedAnswer":{"@type":"Answer","text":"Ma'muriy javobgarlik kodeksining 135-1-moddasi bo'yicha ogohlantirish yoki 0,5 BHK jarima (hozir 206 000 so'm). Baxtsiz hodisada zarar o'z hisobingizdan to'lanadi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"OSAGO kalkulyatori","description":"O'zbekistonda OSAGO polisi narxini hisoblang. Hudud, tajriba va dvigatel quvvatini hisobga oladi.","url":"https://calk.uz/uz/calculator/osago","datePublished":"2025-09-13","dateModified":"2026-01-14","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/osago"},{"@context":"https://schema.org","@type":"HowTo","name":"OSAGO kalkulyatoridan qanday foydalanish","description":"OSAGO kalkulyatoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"TV turini tanlang","text":"Transport vositasi turini ko'rsating (yengil, yuk, avtobus)."},{"@type":"HowToStep","position":2,"name":"Ro'yxatga olingan hududni ko'rsating","text":"O'zbekistonda avtomobil ro'yxatga olingan viloyatni tanlang."},{"@type":"HowToStep","position":3,"name":"Haydovchilar ma'lumotini kiriting","text":"Koeffitsientni hisoblash uchun haydovchilarning yoshi va stajini ko'rsating."},{"@type":"HowToStep","position":4,"name":"Polis narxini oling","text":"«Hisoblash» tugmasini bosing — OSAGO polisi narxini bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
