2:T10f3,[{"@context":"https://schema.org","@type":"WebPage","name":"Davlat boji","description":"O'zbekistonda davlat boji miqdorini hisoblang. Sud, notarius, ro'yxatga olish va boshqa xizmatlar.","url":"https://calk.uz/uz/calculator/davlat-boji","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/davlat-boji#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/davlat-boji/opengraph-image"},"dateModified":"2025-09-20"},{"@context":"https://schema.org","@type":"WebApplication","name":"Davlat boji","description":"O'zbekistonda davlat boji miqdorini hisoblang. Sud, notarius, ro'yxatga olish va boshqa xizmatlar.","url":"https://calk.uz/uz/calculator/davlat-boji","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/davlat-boji#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"O'zbekiston","item":"https://calk.uz/uz/category/unique"},{"@type":"ListItem","position":3,"name":"Davlat boji","item":"https://calk.uz/uz/calculator/davlat-boji"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Mulkni ro'yxatdan o'tkazish qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"Jismoniy shaxslar uchun maydon bo'yicha: 100 m² gacha 1,25 BHK (515 000 so'm), 101-300 m² 2 BHK, 300 dan ortiq 3 BHK. Yuridik shaxslar uchun 5 BHK (2 060 000). Shartnomani notarial tasdiqlash — belgilangan 1 BHK (412 000)."}},{"@type":"Question","name":"Da'vo ariza berish uchun davlat boji qancha?","acceptedAnswer":{"@type":"Answer","text":"Fuqarolik sudlarida mulkiy da'vo summasining 4%, iqtisodiy sudlarda 2%. Minimum — 1 BHK (412 000 so'm). Mehnat nizolari va nafaqa — bepul."}},{"@type":"Question","name":"Kim davlat bojlaridan ozod?","acceptedAnswer":{"@type":"Answer","text":"I-II guruh nogironlari (sud), mehnat nizolari va nafaqa bo'yicha da'vogarlar, urush ishtirokchilari. Pensionerlar — 50% chegirma."}},{"@type":"Question","name":"Nikohni ro'yxatdan o'tkazish qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"Nikoh guvohnomasi uchun 1 BHK (412 000 so'm). Sud orqali bekor qilish — 3 BHK (1 236 000 so'm)."}},{"@type":"Question","name":"Davlat bojini qanday to'lash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Bank terminallari, Click, Payme, Uzum yoki bank kassasi orqali. Kvitansiya 3 oy amal qiladi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Davlat boji","description":"O'zbekistonda davlat boji miqdorini hisoblang. Sud, notarius, ro'yxatga olish va boshqa xizmatlar.","url":"https://calk.uz/uz/calculator/davlat-boji","datePublished":"2025-05-20","dateModified":"2025-09-20","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/davlat-boji"},{"@context":"https://schema.org","@type":"HowTo","name":"Davlat bojidan qanday foydalanish","description":"Davlat bojidan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Xizmat turini tanlang","text":"Davlat xizmatini ko'rsating (ro'yxatga olish, litsenziyalash va boshq.)."},{"@type":"HowToStep","position":2,"name":"Parametrlarni ko'rsating","text":"Agar kerak bo'lsa, qo'shimcha parametrlarni kiriting."},{"@type":"HowToStep","position":3,"name":"Boj summasini oling","text":"«Hisoblash» tugmasini bosing — davlat boji miqdorini bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
