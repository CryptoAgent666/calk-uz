2:T1181,[{"@context":"https://schema.org","@type":"WebPage","name":"Elektr energiya","description":"O'zbekiston tariflari bo'yicha elektr energiyasi narxini hisoblang. 6 bosqichli iste'mol hisobga olinadi.","url":"https://calk.uz/uz/calculator/elektr-energiya","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/elektr-energiya#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/elektr-energiya/opengraph-image"},"dateModified":"2026-03-29"},{"@context":"https://schema.org","@type":"WebApplication","name":"Elektr energiya","description":"O'zbekiston tariflari bo'yicha elektr energiyasi narxini hisoblang. 6 bosqichli iste'mol hisobga olinadi.","url":"https://calk.uz/uz/calculator/elektr-energiya","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/elektr-energiya#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Kommunal","item":"https://calk.uz/uz/category/utilities"},{"@type":"ListItem","position":3,"name":"Elektr energiya","item":"https://calk.uz/uz/calculator/elektr-energiya"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O'zbekistonda elektr energiya qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"6 bosqichli shkala bo'yicha: 600 so'm/kVt·soat (200 kVt·soatgacha) dan 2 000 so'm/kVt·soat (10 000 dan ortiq). Iste'mol qancha ko'p — shuncha qimmat."}},{"@type":"Question","name":"Elektr energiya narxini qanday hisoblash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Iste'mol bosqichlarga bo'linadi: birinchi 200 kVt·soat 600 so'mdan, keyingi 300 ta 800 so'mdan va h.k. Kalkulyatorimiz buni avtomatik qiladi."}},{"@type":"Question","name":"Kvartirada o'rtacha elektr energiya iste'moli qancha?","acceptedAnswer":{"@type":"Answer","text":"2 xonali kvartira uchun: yozda 200-400 kVt·soat, qishda 300-600 kVt·soat. O'rtacha hisob: 150 000 - 500 000 so'm."}},{"@type":"Question","name":"Nima uchun tariflar bosqichli?","acceptedAnswer":{"@type":"Answer","text":"Energiya tejashni rag'batlantirish uchun. Asosiy iste'mol (200 kVt·soatgacha) past tarif bo'yicha, ortiqchasi — yuqori tarif bo'yicha to'lanadi."}},{"@type":"Question","name":"Elektr energiya xarajatlarini qanday kamaytirish mumkin?","acceptedAnswer":{"@type":"Answer","text":"LED-lampalar (80% tejash), taymerlar, izolyatsiya, quyosh panellari. Iste'molni 500 kVt·soat ichida ushlab turishga harakat qiling."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Elektr energiya","description":"O'zbekiston tariflari bo'yicha elektr energiyasi narxini hisoblang. 6 bosqichli iste'mol hisobga olinadi.","url":"https://calk.uz/uz/calculator/elektr-energiya","datePublished":"2025-07-23","dateModified":"2026-03-29","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/elektr-energiya"},{"@context":"https://schema.org","@type":"HowTo","name":"Elektr energiyadan qanday foydalanish","description":"Elektr energiyadan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Iste'mol miqdorini kiriting","text":"Oyiga sarflangan kilovatt-soat (kVt·s) miqdorini kiriting."},{"@type":"HowToStep","position":2,"name":"Tarifni tanlang","text":"Tarif turini tanlang (maishiy, imtiyozli, gaz plita / elektr plita bilan)."},{"@type":"HowToStep","position":3,"name":"To'lov summasini oling","text":"«Hisoblash» tugmasini bosing va elektr energiya uchun to'lov summasini bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
