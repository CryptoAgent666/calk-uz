2:T10b7,[{"@context":"https://schema.org","@type":"WebPage","name":"Zakot kalkulyatori","description":"Zakot miqdorini hisoblang — Islomda majburiy yillik xayriya. Nisob miqdoridan 2,5%.","url":"https://calk.uz/uz/calculator/zakot","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/zakot#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/zakot/opengraph-image"},"dateModified":"2025-09-10"},{"@context":"https://schema.org","@type":"WebApplication","name":"Zakot kalkulyatori","description":"Zakot miqdorini hisoblang — Islomda majburiy yillik xayriya. Nisob miqdoridan 2,5%.","url":"https://calk.uz/uz/calculator/zakot","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/zakot#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Din","item":"https://calk.uz/uz/category/religion"},{"@type":"ListItem","position":3,"name":"Zakot kalkulyatori","item":"https://calk.uz/uz/calculator/zakot"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Zakot qancha?","acceptedAnswer":{"@type":"Answer","text":"To'liq qamariy yil davomida ega bo'lgan, nisobdan (85 g oltin qiymati ≈ 70 mln so'm) ortiq mol-mulkning 2,5%."}},{"@type":"Question","name":"Nisob nima va uni qanday aniqlash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Nisob — minimal chegara: 85 g oltin qiymati (~$5 500 yoki 2025–2026-yilda ~70 mln so'm). Agar aktivlaringiz bundan past bo'lsa, zakot majburiy emas."}},{"@type":"Question","name":"Qaysi mol-mulkdan zakot to'lanadi?","acceptedAnswer":{"@type":"Answer","text":"Pul (elektron hamyonlar kiritilgan holda), omonatlar, oltin/kumush, tovar zahiralari, aksiyalar. Turar-joy, transport va shaxsiy buyumlar kiritilmaydi."}},{"@type":"Question","name":"O'zbekistonda zakotni qayerga uzatish mumkin?","acceptedAnswer":{"@type":"Answer","text":"Masjidlar, Vaqf fondi (vaqf.uz), xayriya tashkilotlari orqali yoki 8 ta oluvchi toifasidagi muhtojlarga bevosita."}},{"@type":"Question","name":"Zakotni qachon to'lash yaxshiroq?","acceptedAnswer":{"@type":"Answer","text":"Ramazonda tavsiya etiladi (savob ko'paytiriladi), lekin majburiy muddat yo'q — asosiysi havl (qamariy yil egaligi) o'tganidan keyin to'lash."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Zakot kalkulyatori","description":"Zakot miqdorini hisoblang — Islomda majburiy yillik xayriya. Nisob miqdoridan 2,5%.","url":"https://calk.uz/uz/calculator/zakot","datePublished":"2025-05-06","dateModified":"2025-09-10","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/zakot"},{"@context":"https://schema.org","@type":"HowTo","name":"Zakot kalkulyatoridan qanday foydalanish","description":"Zakot kalkulyatoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Mulkni kiriting","text":"Zakotga tegishli mulkning umumiy qiymatini ko'rsating (pul, oltin, tovar)."},{"@type":"HowToStep","position":2,"name":"Qarzlarni ko'rsating","text":"Zakot bazasidan chegirib tashlash uchun joriy qarzlar summasini kiriting."},{"@type":"HowToStep","position":3,"name":"Zakot hisobini oling","text":"«Hisoblash» tugmasini bosing — nisob yetganligini va zakot summasini (2,5%) bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
