2:T10b1,[{"@context":"https://schema.org","@type":"WebPage","name":"Ortiqcha ish vaqti","description":"O'zbekiston MK bo'yicha ortiqcha ish vaqti, dam olish va bayram kunlaridagi ish haqini hisoblang.","url":"https://calk.uz/uz/calculator/ortiqcha-ish-vaqti","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/ortiqcha-ish-vaqti#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/ortiqcha-ish-vaqti/opengraph-image"},"dateModified":"2025-09-15"},{"@context":"https://schema.org","@type":"WebApplication","name":"Ortiqcha ish vaqti","description":"O'zbekiston MK bo'yicha ortiqcha ish vaqti, dam olish va bayram kunlaridagi ish haqini hisoblang.","url":"https://calk.uz/uz/calculator/ortiqcha-ish-vaqti","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/ortiqcha-ish-vaqti#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Ish haqi","item":"https://calk.uz/uz/category/salary"},{"@type":"ListItem","position":3,"name":"Ortiqcha ish vaqti","item":"https://calk.uz/uz/calculator/ortiqcha-ish-vaqti"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Ortiqcha ish qanday to'lanadi?","acceptedAnswer":{"@type":"Answer","text":"Dastlabki 2 soat — soatlik stavkadan ×1,5, keyin — ×2. Dam olish/bayramlarda — ×2 yoki qo'shimcha dam."}},{"@type":"Question","name":"Necha soat ortiqcha ishlash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Ketma-ket 2 kun uchun 4 soatgacha, yiliga 120 soatgacha. Faqat xodimning yozma roziligi bilan."}},{"@type":"Question","name":"Kimni ortiqcha ishga jalb qilib bo'lmaydi?","acceptedAnswer":{"@type":"Answer","text":"Homiladorlar, 18 yoshgacha yoshlar, nogironlar (ularning roziligi va tibbiy xulosasisiz)."}},{"@type":"Question","name":"Tungi ish qanday to'lanadi?","acceptedAnswer":{"@type":"Answer","text":"Soatlik stavkaning kamida 50% ustamasi bilan. Tungi vaqt: 22:00 dan 06:00 gacha."}},{"@type":"Question","name":"Ortiqcha ish soliqqa tortiladimi?","acceptedAnswer":{"@type":"Answer","text":"Ha, JShShS 12% va ijtimoiy soliq umumiy asoslarda. Imtiyozlar yo'q."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Ortiqcha ish vaqti","description":"O'zbekiston MK bo'yicha ortiqcha ish vaqti, dam olish va bayram kunlaridagi ish haqini hisoblang.","url":"https://calk.uz/uz/calculator/ortiqcha-ish-vaqti","datePublished":"2025-05-09","dateModified":"2025-09-15","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/ortiqcha-ish-vaqti"},{"@context":"https://schema.org","@type":"HowTo","name":"Ortiqcha ish vaqtidan qanday foydalanish","description":"Ortiqcha ish vaqtidan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Maoshni kiriting","text":"Oylik lavozim maoshingizni ko'rsating."},{"@type":"HowToStep","position":2,"name":"Ortiqcha soatlarni ko'rsating","text":"Ortiqcha ishlangan soatlar sonini kiriting."},{"@type":"HowToStep","position":3,"name":"Ortiqc