2:T1473,[{"@context":"https://schema.org","@type":"WebPage","name":"Avto rastamozhka","description":"O'zbekistonda avtomobilni rastamozhka qilish narxini hisoblang. Bojxona boji, aksiz va QQS.","url":"https://calk.uz/uz/calculator/rastamozhka","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/rastamozhka#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/rastamozhka/opengraph-image"},"dateModified":"2025-08-21"},{"@context":"https://schema.org","@type":"WebApplication","name":"Avto rastamozhka","description":"O'zbekistonda avtomobilni rastamozhka qilish narxini hisoblang. Bojxona boji, aksiz va QQS.","url":"https://calk.uz/uz/calculator/rastamozhka","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/rastamozhka#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Avtomobil","item":"https://calk.uz/uz/category/auto"},{"@type":"ListItem","position":3,"name":"Avto rastamozhka","item":"https://calk.uz/uz/calculator/rastamozhka"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Bojxona to'lovlari nimalardan iborat?","acceptedAnswer":{"@type":"Answer","text":"Bojxona boji (0-30%), QQS (qiymat+bojdan 12%), aksiz (aksiz tovarlar uchun), rasmiylashtirish yig'imi (tarif setkasi)."}},{"@type":"Question","name":"Bojsiz qancha tovar olib kirish mumkin?","acceptedAnswer":{"@type":"Answer","text":"2025-yil 1-maydan: samolyotda — $1 000 gacha va 50 kg; poyezdda/suv orqali — $500 gacha; avtoda/piyoda — $300 gacha; kuryer pochtasi — $200/oy; jo'natmalar — $100. Chet elda minimal bo'lish muddati: 2 kun (avto), 3 kun (samolyot)."}},{"@type":"Question","name":"Bojxona boji miqdorini qanday aniqlash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Tovarning TIF TN kodi bo'yicha. Stavkalar Davlat bojxona qo'mitasi tomonidan e'lon qilinadi."}},{"@type":"Question","name":"Boj hisobi uchun qaysi valyuta kursi ishlatiladi?","acceptedAnswer":{"@type":"Answer","text":"Bojxona deklaratsiyasi topshirilgan sanadagi MB rasmiy kursi."}},{"@type":"Question","name":"Bojxona to'lovlari bo'yicha imtiyozlar bormi?","acceptedAnswer":{"@type":"Answer","text":"Ha: texnologik uskunalar (O'zbekistonda ishlab chiqarilmaydigan), EIZ uchun tovarlar, investitsiya loyihalari."}},{"@type":"Question","name":"BAA dan elektronika olib kirish chegarasi qancha?","acceptedAnswer":{"@type":"Answer","text":"Yakka shaxs uchun bojsiz olib kirish chegarasi — 1 000 EUR (~13,7 mln so'm joriy kursda) yoki 50 kg. Limitdan ortiq qiymatga 30% boj solinadi. Pochta yoki kuryer orqali kelgan paketlar uchun chegara 100 EUR."}},{"@type":"Question","name":"Avtomobil rasmiylashtirishda «utilizatsiya yig'imi» qancha?","acceptedAnswer":{"@type":"Answer","text":"Yengil avtomobillar uchun yig'im hajm va ishlab chiqarish yiliga bog'liq: yangi avto uchun 5-15 mln so'm, foydalanilgan uchun ko'proq. Aniq summa zip kalkulyatorda hisoblanadi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Avto rastamozhka","description":"O'zbekistonda avtomobilni rastamozhka qilish narxini hisoblang. Bojxona boji, aksiz va QQS.","url":"https://calk.uz/uz/calculator/rastamozhka","datePublished":"2025-03-20","dateModified":"2025-08-21","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/rastamozhka"},{"@context":"https://schema.org","@type":"HowTo","name":"Avto rastamozhkadan qanday foydalanish","description":"Avto rastamozhkadan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT3M","step":[{"@type":"HowToStep","position":1,"name":"Avtomobil turini tanlang","text":"Yengil, yuk yoki mototsikl olib kirayotganingizni ko'rsating."},{"@type":"HowToStep","position":2,"name":"Dvigatel hajmini ko'rsating","text":"Dvigatel hajmini kub santimetrlarda kiriting."},{"@type":"HowToStep","position":3,"name":"Ishlab chiqarilgan yilini tanlang","text":"Transport vositasining ishlab chiqarilgan yilini ko'rsating."},{"@type":"HowToStep","position":4,"name":"Narxini kiriting","text":"Avtomobilning bojxona qiymatini dollar yoki so'mda kiriting."},{"@type":"HowToStep","position":5,"name":"Bojlar hisobini oling","text":"«Hisoblash» tugmasini bosing — aksiz, bojxona boji, QQS va umumiy summani ko'ring."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
