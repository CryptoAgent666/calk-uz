2:T1314,[{"@context":"https://schema.org","@type":"WebPage","name":"Ishdan bo'shatish kompensatsiyasi","description":"Ishdan bo'shatish kompensatsiyasini hisoblang: foydalanilmagan ta'til, chiqish nafaqasi va yakuniy hisob-kitob.","url":"https://calk.uz/uz/calculator/ishdan-boshatish-kompensatsiyasi","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/ishdan-boshatish-kompensatsiyasi#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/ishdan-boshatish-kompensatsiyasi/opengraph-image"},"dateModified":"2025-12-19"},{"@context":"https://schema.org","@type":"WebApplication","name":"Ishdan bo'shatish kompensatsiyasi","description":"Ishdan bo'shatish kompensatsiyasini hisoblang: foydalanilmagan ta'til, chiqish nafaqasi va yakuniy hisob-kitob.","url":"https://calk.uz/uz/calculator/ishdan-boshatish-kompensatsiyasi","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/ishdan-boshatish-kompensatsiyasi#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Ish haqi","item":"https://calk.uz/uz/category/salary"},{"@type":"ListItem","position":3,"name":"Ishdan bo'shatish kompensatsiyasi","item":"https://calk.uz/uz/calculator/ishdan-boshatish-kompensatsiyasi"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Ishdan bo'shatishda chiqish nafaqasi beriladimi?","acceptedAnswer":{"@type":"Answer","text":"Qisqartirishda — ha, graduatsiyalangan shkala bo'yicha: 3 yilgacha staj — 50%, 3-5 yil — 75%, 5-10 yil — 100%, 10-15 yil — 150%, 15+ yil — o'rtacha oylik ish haqining 200%. O'z xohishi bilan — yo'q (faqat ta'til kompensatsiyasi)."}},{"@type":"Question","name":"Foydalanilmagan ta'til kompensatsiyasini qanday hisoblash mumkin?","acceptedAnswer":{"@type":"Answer","text":"O'rtacha kunlik ish haqi (3 oy uchun) × foydalanilmagan kunlar soni."}},{"@type":"Question","name":"Qisqartirish vaqtida qanday to'lovlar bor?","acceptedAnswer":{"@type":"Answer","text":"Chiqish nafaqasi (stajga qarab o'rtacha oylikning 50% dan 200% gacha shkala bo'yicha) + ta'til kompensatsiyasi + ish topish davri uchun ish haqi (2-3 oygacha)."}},{"@type":"Question","name":"Ishdan bo'shatishda qancha muddatda hisob-kitob qilishlari kerak?","acceptedAnswer":{"@type":"Answer","text":"Oxirgi ish kunida. Har kechiktirilgan kun uchun o'rtacha ish haqi miqdorida kompensatsiya."}},{"@type":"Question","name":"Ishdan bo'shatish to'lovlari soliqqa tortiladimi?","acceptedAnswer":{"@type":"Answer","text":"Ta'til kompensatsiyasi — JShShS 12%. Chiqish nafaqasi — 4,22 BHK (1 738 640 so'm) dan ortiq summadan JShShS."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Ishdan bo'shatish kompensatsiyasi","description":"Ishdan bo'shatish kompensatsiyasini hisoblang: foydalanilmagan ta'til, chiqish nafaqasi va yakuniy hisob-kitob.","url":"https://calk.uz/uz/calculator/ishdan-boshatish-kompensatsiyasi","datePublished":"2025-03-28","dateModified":"2025-12-19","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/ishdan-boshatish-kompensatsiyasi"},{"@context":"https://schema.org","@type":"HowTo","name":"Ishdan bo'shatish kompensatsiyasidan qanday foydalanish","description":"Ishdan bo'shatish kompensatsiyasidan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"O'rtacha ish haqini kiriting","text":"Oxirgi 3 oydagi o'rtacha oylik ish haqini kiriting."},{"@type":"HowToStep","position":2,"name":"Ish stajini ko'rsating","text":"Oxirgi ish joyidagi stajni kiriting."},{"@type":"HowToStep","position":3,"name":"Ishdan bo'shatish asosini tanlang","text":"Ishdan bo'shatish sababini ko'rsating (qisqartirish, tomonlar kelishuvi va boshq.)."},{"@type":"HowToStep","position":4,"name":"Hisobni oling","text":"«Hisoblash» tugmasini bosing — ishdan bo'shatish nafaqasi miqdorini bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
