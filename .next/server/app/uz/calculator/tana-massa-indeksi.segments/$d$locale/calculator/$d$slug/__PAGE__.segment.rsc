2:T109f,[{"@context":"https://schema.org","@type":"WebPage","name":"Tana massa indeksi","description":"Tana massa indeksini (TMI) hisoblang. Vazningiz bo'yingizga nisbatan me'yorda ekanligini bilib oling.","url":"https://calk.uz/uz/calculator/tana-massa-indeksi","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/tana-massa-indeksi#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/tana-massa-indeksi/opengraph-image"},"dateModified":"2025-06-20"},{"@context":"https://schema.org","@type":"WebApplication","name":"Tana massa indeksi","description":"Tana massa indeksini (TMI) hisoblang. Vazningiz bo'yingizga nisbatan me'yorda ekanligini bilib oling.","url":"https://calk.uz/uz/calculator/tana-massa-indeksi","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/tana-massa-indeksi#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Salomatlik","item":"https://calk.uz/uz/category/health"},{"@type":"ListItem","position":3,"name":"Tana massa indeksi","item":"https://calk.uz/uz/calculator/tana-massa-indeksi"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"TMI qanday hisoblanadi?","acceptedAnswer":{"@type":"Answer","text":"TMI = Vazn(kg) / Bo'y(m)². Masalan: 170 sm bo'yda 70 kg → 70 / 1,70² = 24,2. Bu normaning yuqori chegarasi."}},{"@type":"Question","name":"Qanday TMI normal hisoblanadi?","acceptedAnswer":{"@type":"Answer","text":"JSST tasnifi bo'yicha 18,5-24,9. 18,5 dan past — tanqislik, 25-29,9 — ortiqcha vazn, 30+ — semirish."}},{"@type":"Question","name":"TMI sportchilar uchun aniqmi?","acceptedAnswer":{"@type":"Answer","text":"Yo'q, TMI mushak va yog' massasini farqlamaydi. Sportchilarga yog' foizini o'lchash yaxshiroq (erkaklar uchun norma 10-20%, ayollar uchun 18-28%)."}},{"@type":"Question","name":"175 sm bo'yda normal vazn qancha?","acceptedAnswer":{"@type":"Answer","text":"JSST bo'yicha (TMI 18,5-24,9): 57-76 kg. Optimal diapazon: 63-72 kg."}},{"@type":"Question","name":"O'zbekistonda semirish holati qanday?","acceptedAnswer":{"@type":"Answer","text":"Katta yoshdagi aholining taxminan 30% ortiqcha vaznli, 15% — semiz. Asosiy sabablar: kaloriyali oshxona va kam harakatlilik."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Tana massa indeksi","description":"Tana massa indeksini (TMI) hisoblang. Vazningiz bo'yingizga nisbatan me'yorda ekanligini bilib oling.","url":"https://calk.uz/uz/calculator/tana-massa-indeksi","datePublished":"2025-08-01","dateModified":"2025-06-20","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/tana-massa-indeksi"},{"@context":"https://schema.org","@type":"HowTo","name":"Tana massa indeksidan qanday foydalanish","description":"Tana massa indeksidan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Bo'yingizni kiriting","text":"Bo'yingizni santimetrlarda ko'rsating."},{"@type":"HowToStep","position":2,"name":"Vazningizni kirit