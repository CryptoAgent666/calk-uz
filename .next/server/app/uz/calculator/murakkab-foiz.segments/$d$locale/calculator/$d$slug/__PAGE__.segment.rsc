2:T11f1,[{"@context":"https://schema.org","@type":"WebPage","name":"Murakkab foiz","description":"Murakkab foiz bilan investitsiyalarning o'sishini hisoblang. Kapitalizatsiya va qayta investitsiya qanday ishlashini ko'rsatamiz.","url":"https://calk.uz/uz/calculator/murakkab-foiz","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/murakkab-foiz#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/murakkab-foiz/opengraph-image"},"dateModified":"2026-02-22"},{"@context":"https://schema.org","@type":"WebApplication","name":"Murakkab foiz","description":"Murakkab foiz bilan investitsiyalarning o'sishini hisoblang. Kapitalizatsiya va qayta investitsiya qanday ishlashini ko'rsatamiz.","url":"https://calk.uz/uz/calculator/murakkab-foiz","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/murakkab-foiz#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Depozitlar","item":"https://calk.uz/uz/category/deposit"},{"@type":"ListItem","position":3,"name":"Murakkab foiz","item":"https://calk.uz/uz/calculator/murakkab-foiz"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Murakkab foizlar oddiydan nimasi bilan farq qiladi?","acceptedAnswer":{"@type":"Answer","text":"Oddiy: faqat boshlang'ich summaga foiz. Murakkab: boshlang'ich summa hamda avval hisoblangan foizlarga foiz (kapitalizatsiya)."}},{"@type":"Question","name":"Kapitalizatsiya daromadga qanday ta'sir qiladi?","acceptedAnswer":{"@type":"Answer","text":"Yillik 24% da 5 yilga: kapitalizatsiyasiz — +120%, oylik bilan — +226,9%. 50 mln so'mda farq — 53 mln dan ortiq."}},{"@type":"Question","name":"Qanchalik tez-tez kapitalizatsiya qilgan yaxshi?","acceptedAnswer":{"@type":"Answer","text":"Qanchalik tez-tez — shunchalik foydali. 24% da oylik kapitalizatsiya 5 yilda yillikdan 33,7% ko'proq beradi."}},{"@type":"Question","name":"Omonat daromadi soliqqa tortiladimi?","acceptedAnswer":{"@type":"Answer","text":"Ha, omonat daromadidan rezidentlar uchun 5% (norezidentlar uchun 10%) JShShS ushlab qolinadi. Bank foizlarni to'lashda soliqni avtomatik ravishda ushlab qoladi."}},{"@type":"Question","name":"Omonatlarning real daromadliligi qancha?","acceptedAnswer":{"@type":"Answer","text":"Nominal 20-26% minus inflyatsiya ~7,3% = real daromadlilik yillik 13-19% (foizlarga 5% JShShS chegirilgunicha)."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Murakkab foiz","description":"Murakkab foiz bilan investitsiyalarning o'sishini hisoblang. Kapitalizatsiya va qayta investitsiya qanday ishlashini ko'rsatamiz.","url":"https://calk.uz/uz/calculator/murakkab-foiz","datePublished":"2025-07-28","dateModified":"2026-02-22","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/murakkab-foiz"},{"@context":"https://schema.org","@type":"HowTo","name":"Murakkab foizdan qanday foydalanish","description":"Murakkab foizdan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Boshlang'ich summani kiriting","text":"Investitsiya yoki omonatning boshlang'ich summasini kiriting."},{"@type":"HowToStep","position":2,"name":"Foiz stavkasini ko'rsating","text":"Yillik foiz stavkasini kiriting."},{"@type":"HowToStep","position":3,"name":"Davr va kapitalizatsiyani tanlang","text":"Yillardagi muddatni va kapitalizatsiya chastotasini (oylik, choraklik, yillik) ko'rsating."},{"@type":"HowToStep","position":4,"name":"Natijani oling","text":"«Hisoblash» tugmasini bosing — yakuniy summa va omonat o'sish jadvalini ko'ring."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
