2:T129b,[{"@context":"https://schema.org","@type":"WebPage","name":"Viza narxi","description":"O'zbekiston fuqarolari uchun viza narxini hisoblang. Konsullik yig'imi, sug'urta va servis yig'imi.","url":"https://calk.uz/uz/calculator/viza-narxi","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/viza-narxi#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/viza-narxi/opengraph-image"},"dateModified":"2025-10-16"},{"@context":"https://schema.org","@type":"WebApplication","name":"Viza narxi","description":"O'zbekiston fuqarolari uchun viza narxini hisoblang. Konsullik yig'imi, sug'urta va servis yig'imi.","url":"https://calk.uz/uz/calculator/viza-narxi","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/viza-narxi#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"O'zbekiston","item":"https://calk.uz/uz/category/unique"},{"@type":"ListItem","position":3,"name":"Viza narxi","item":"https://calk.uz/uz/calculator/viza-narxi"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Shengen vizasi qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"Konsullik to'lovi €80 (~1 050 000 so'm) + viza markazi servis to'lovi €20-30 (~260 000-395 000 so'm) + foto, hujjatlar tarjimasi va sug'urta. Jami: kishiga 1 740 000-2 800 000 so'm."}},{"@type":"Question","name":"Qaysi mamlakatlarga viza kerak emas?","acceptedAnswer":{"@type":"Answer","text":"Rossiya, Qozog'iston, Qirg'iziston, Tojikiston, Gruziya, Turkiya (30 kungacha), Malayziya (30 kungacha), Janubiy Koreya (30 kungacha), Indoneziya, Singapur va bir qator MDH mamlakatlari. To'liq ro'yxat — TIV sayti mfa.uz da."}},{"@type":"Question","name":"Viza narxi nimalardan tashkil topadi?","acceptedAnswer":{"@type":"Answer","text":"Konsullik to'lovi (asosiy qism, €40-185) + viza markazi servis to'lovi (€20-30) + foto (30 000-50 000 so'm) + hujjatlar tarjimasi (200 000-500 000 so'm) + tibbiy sug'urta (200 000-800 000 so'm)."}},{"@type":"Question","name":"Toshkentda viza uchun hujjatlarni qayerga topshirish mumkin?","acceptedAnswer":{"@type":"Answer","text":"Viza markazlarida: VFS Global (Compass SM, Shengen mamlakatlari), TLS Contact (Bobur ko'chasi, Frantsiya). Elchixonalar ham ba'zi viza toifalari uchun hujjatlarni bevosita qabul qiladi."}},{"@type":"Question","name":"Bolalar uchun viza qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"Shengen: 6 yoshgacha bolalar — bepul, 6-12 yosh — €40 (~525 000 so'm). AQSh (B1/B2): barcha yoshdagilar uchun bir xil $185. Servis to'lovi va sug'urta yoshdan qat'i nazar to'lanadi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Viza narxi","description":"O'zbekiston fuqarolari uchun viza narxini hisoblang. Konsullik yig'imi, sug'urta va servis yig'imi.","url":"https://calk.uz/uz/calculator/viza-narxi","datePublished":"2025-07-26","dateModified":"2025-10-16","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/viza-narxi"},{"@context":"https://schema.org","@type":"HowTo","name":"Viza narxidan qanday foydalanish","description":"Viza narxidan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Mamlakatni tanlang","text":"Viza rasmiylashtirilayotgan mamlakatni ko'rsating."},{"@type":"HowToStep","position":2,"name":"Viza turini tanlang","text":"Turini ko'rsating: turistik, ishchi, talaba, tranzit."},{"@type":"HowToStep","position":3,"name":"Shoshilinchligini ko'rsating","text":"Oddiy yoki tezlashtirilgan rasmiylashtirish muddatini tanlang."},{"@type":"HowToStep","position":4,"name":"Hisobni oling","text":"«Hisoblash» tugmasini bosing — konsullik yig'imi va viza uchun umumiy xarajatlarni bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
