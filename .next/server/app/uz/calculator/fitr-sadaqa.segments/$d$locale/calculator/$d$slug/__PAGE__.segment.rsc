2:T119f,[{"@context":"https://schema.org","@type":"WebPage","name":"Fitr sadaqa","description":"Fitr sadaqa (zakotul-fitr) miqdorini hisoblang. Iyd al-Fitr bayrami oldidan majburiy xayriya.","url":"https://calk.uz/uz/calculator/fitr-sadaqa","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/fitr-sadaqa#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/fitr-sadaqa/opengraph-image"},"dateModified":"2025-05-20"},{"@context":"https://schema.org","@type":"WebApplication","name":"Fitr sadaqa","description":"Fitr sadaqa (zakotul-fitr) miqdorini hisoblang. Iyd al-Fitr bayrami oldidan majburiy xayriya.","url":"https://calk.uz/uz/calculator/fitr-sadaqa","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/fitr-sadaqa#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Din","item":"https://calk.uz/uz/category/religion"},{"@type":"ListItem","position":3,"name":"Fitr sadaqa","item":"https://calk.uz/uz/calculator/fitr-sadaqa"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"2026-yilda fitr-sadaqa qancha?","acceptedAnswer":{"@type":"Answer","text":"Minimum ~45 000 so'm (bug'doy) dan ~65 000 so'm (guruch) gacha kishiga. 5 kishilik oila: 225 000-325 000 so'm."}},{"@type":"Question","name":"Kim to'lashi kerak?","acceptedAnswer":{"@type":"Answer","text":"Har bir musulmon o'zi va qaramog'idagilar (bolalar, keksa ota-onalar) uchun. Oila boshlig'i barcha uchun to'laydi."}},{"@type":"Question","name":"Qachon to'lash kerak?","acceptedAnswer":{"@type":"Answer","text":"Iyd al-Fitr ertalab bayram namozigacha. Ramazonning oxirgi kunlarida to'lash tavsiya etiladi."}},{"@type":"Question","name":"Fitr-sadaqani qayerga uzatish mumkin?","acceptedAnswer":{"@type":"Answer","text":"Muhtojlarga bevosita, masjid orqali, Vaqf fondi (vaqf.uz) yoki xayriya tashkilotlari orqali."}},{"@type":"Question","name":"Fitr-sadaqa miqdori qanday aniqlanadi?","acceptedAnswer":{"@type":"Answer","text":"1 so' (~3,5 kg) asosiy mahsulot narxi: bug'doy, guruch yoki arpa. O'zbekiston Musulmonlari boshqarmasi miqdorlarni har yili e'lon qiladi."}},{"@type":"Question","name":"Fitr-sadaqani kimga berish kerak?","acceptedAnswer":{"@type":"Answer","text":"Fitr-sadaqa Ramazon hayitidan oldin kambag'allarga, mahalladagi muhtoj oilalarga yoki vaqf orqali topshiriladi. Mahalla qo'mitasi yoki masjid orqali topshirish — qabul qilingan amaliyot. Hayit namozidan keyin topshirilsa, bu oddiy sadaqa hisoblanadi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Fitr sadaqa","description":"Fitr sadaqa (zakotul-fitr) miqdorini hisoblang. Iyd al-Fitr bayrami oldidan majburiy xayriya.","url":"https://calk.uz/uz/calculator/fitr-sadaqa","datePublished":"2025-08-01","dateModified":"2025-05-20","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/fitr-sadaqa"},{"@context":"https://schema.org","@type":"HowTo","name":"Fitr sadaqadan qanday foydalanish","description":"Fitr sadaqadan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Mahsulotni tanlang","text":"Fitr-sadaqa hisoblash uchun mahsulotni ko'rsating (bug'doy, guruch, un va boshq.)."},{"@type":"HowToStep","position":2,"name":"Oila a'zolari sonini ko'rsating","text":"Sadaqa to'lanadigan kishilar sonini kiriting."},{"@type":"HowToStep","position":3,"name":"Hisobni oling","text":"«Hisoblash» tugmasini bosing — har bir kishi uchun fitr-sadaqa summasini bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
