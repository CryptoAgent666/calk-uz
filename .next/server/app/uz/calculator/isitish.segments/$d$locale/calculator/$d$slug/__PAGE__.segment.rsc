2:T1004,[{"@context":"https://schema.org","@type":"WebPage","name":"Isitish","description":"Markaziy isitish narxini hisoblang. Kvartira maydoni va isitish mavsumiga bog'liq.","url":"https://calk.uz/uz/calculator/isitish","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/isitish#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/isitish/opengraph-image"},"dateModified":"2026-03-07"},{"@context":"https://schema.org","@type":"WebApplication","name":"Isitish","description":"Markaziy isitish narxini hisoblang. Kvartira maydoni va isitish mavsumiga bog'liq.","url":"https://calk.uz/uz/calculator/isitish","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/isitish#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Kommunal","item":"https://calk.uz/uz/category/utilities"},{"@type":"ListItem","position":3,"name":"Isitish","item":"https://calk.uz/uz/calculator/isitish"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Eng arzon isitish usuli qanday?","acceptedAnswer":{"@type":"Answer","text":"Markaziy isitish (~2 mln mavsumiga). Gaz qozoni — o'rtacha (3-5 mln). Elektr — eng qimmat (60 m² uchun 5-7 mln)."}},{"@type":"Question","name":"Kvartirani mavsumiga isitish qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"Toshkentda 60 m² kvartira: markaziy — 1,8-2,5 mln, gaz — 2,5-4,5 mln, elektr — 4-7 mln so'm."}},{"@type":"Question","name":"Isitish xarajatlarini qanday kamaytirish mumkin?","acceptedAnswer":{"@type":"Answer","text":"Devorlarni izolyatsiya qilish (30-40% tejash), derazalarni almashtirish (20-30%), tomni izolyatsiya qilish (15-20%). 2-3 mavsumda qoplanadi."}},{"@type":"Question","name":"Gaz qozoni qancha gaz sarflaydi?","acceptedAnswer":{"@type":"Answer","text":"60 m² kvartira uchun: oyiga 300-500 m³. 100 m² uy uchun: oyiga 600-1000 m³. Tarif ~1 000 so'm/m³."}},{"@type":"Question","name":"Isitish mavsumi qachon boshlanadi?","acceptedAnswer":{"@type":"Answer","text":"Oktyabrdan martgacha (taxminan 180 kun). Markaziy isitish o'rtacha sutkalik harorat +8°C dan past bo'lganda yoqiladi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Isitish","description":"Markaziy isitish narxini hisoblang. Kvartira maydoni va isitish mavsumiga bog'liq.","url":"https://calk.uz/uz/calculator/isitish","datePublished":"2025-02-04","dateModified":"2026-03-07","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/isitish"},{"@context":"https://schema.org","@type":"HowTo","name":"Isitishdan qanday foydalanish","description":"Isitishdan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Xona maydonini kiriting","text":"Isitilayotgan maydonni kvadrat metrlarda kiriting."},{"@type":"HowToStep","position":2,"name":"Isitish turini tanlang","text":"Markazlashtirilgan yoki individual isitishni tanlang."},{"@type":"HowToStep","position":3,"name":"To'lov summasini oling","text":"«