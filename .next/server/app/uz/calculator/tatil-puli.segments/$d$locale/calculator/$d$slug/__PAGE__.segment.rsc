2:T1118,[{"@context":"https://schema.org","@type":"WebPage","name":"Ta'til puli","description":"Ta'til to'lovlari summasini hisoblang. O'rtacha ish haqi, ish staji va ta'til kunlari sonini hisobga oladi.","url":"https://calk.uz/uz/calculator/tatil-puli","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/tatil-puli#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/tatil-puli/opengraph-image"},"dateModified":"2026-02-20"},{"@context":"https://schema.org","@type":"WebApplication","name":"Ta'til puli","description":"Ta'til to'lovlari summasini hisoblang. O'rtacha ish haqi, ish staji va ta'til kunlari sonini hisobga oladi.","url":"https://calk.uz/uz/calculator/tatil-puli","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/tatil-puli#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Ish haqi","item":"https://calk.uz/uz/category/salary"},{"@type":"ListItem","position":3,"name":"Ta'til puli","item":"https://calk.uz/uz/calculator/tatil-puli"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O'zbekistonda necha kun ta'til beriladi?","acceptedAnswer":{"@type":"Answer","text":"Kamida 21 kalendar kun. Pedagoglar uchun — 56 kalendar kungacha, zararli sharoitlar uchun — qo'shimcha 6-36 ish kuni."}},{"@type":"Question","name":"Ta'til haqi qanday hisoblanadi?","acceptedAnswer":{"@type":"Answer","text":"12 oydagi o'rtacha kunlik ish haqi ta'til kunlari soniga ko'paytiriladi. O'rtacha kunlik = 12 oydagi ish haqi / Ishlangan kunlar."}},{"@type":"Question","name":"Ta'til haqi qachon to'lanishi kerak?","acceptedAnswer":{"@type":"Answer","text":"Ta'til boshlanishidan oldingi oxirgi ish kunidan kechiktirmay (Mehnat kodeksining 233-moddasi)."}},{"@type":"Question","name":"Ta'til haqidan JShShS ushlab qolinadimi?","acceptedAnswer":{"@type":"Answer","text":"Ha, ta'til haqidan 12% stavkada JShShS ushlab qolinadi (IT Park uchun 7,5%)."}},{"@type":"Question","name":"Ta'tilni pul kompensatsiyasiga almashtirish mumkinmi?","acceptedAnswer":{"@type":"Answer","text":"Yo'q, almashtirish taqiqlangan. Kompensatsiya faqat ishdan bo'shatilganda to'lanadi."}},{"@type":"Question","name":"Bayram kunlari ta'tilga kiradimi?","acceptedAnswer":{"@type":"Answer","text":"Yo'q, bayram dam olish kunlari ta'til kunlari soniga kiritilmaydi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Ta'til puli","description":"Ta'til to'lovlari summasini hisoblang. O'rtacha ish haqi, ish staji va ta'til kunlari sonini hisobga oladi.","url":"https://calk.uz/uz/calculator/tatil-puli","datePublished":"2025-02-07","dateModified":"2026-02-20","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/tatil-puli"},{"@context":"https://schema.org","@type":"HowTo","name":"Ta'til pulidan qanday foydalanish","description":"Ta'til pulidan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"O'rtacha ish haqini kiriting","text":"Oxirgi 12 oydagi o'rtacha oylik ish haqini kiriting."},{"@type":"HowToStep","position":2,"name":"Ta'til kunlarini ko'rsating","text":"Yillik haq to'lanadigan ta'til kunlari sonini kiriting."},{"@type":"HowToStep","position":3,"name":"Ta'til pulini oling","text":"«Hisoblash» tugmasini bosing — JShShS chegirilgandan keyin ta'til puli summasini bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
