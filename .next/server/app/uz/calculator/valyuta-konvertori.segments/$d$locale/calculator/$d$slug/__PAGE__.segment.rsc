2:T1367,[{"@context":"https://schema.org","@type":"WebPage","name":"Valyuta konvertori","description":"O'zbekiston Markaziy banki joriy kursi bo'yicha valyutalarni konvertatsiya qiling. UZS, USD, EUR, RUB va boshqa valyutalar.","url":"https://calk.uz/uz/calculator/valyuta-konvertori","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/valyuta-konvertori#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/valyuta-konvertori/opengraph-image"},"dateModified":"2025-12-12"},{"@context":"https://schema.org","@type":"WebApplication","name":"Valyuta konvertori","description":"O'zbekiston Markaziy banki joriy kursi bo'yicha valyutalarni konvertatsiya qiling. UZS, USD, EUR, RUB va boshqa valyutalar.","url":"https://calk.uz/uz/calculator/valyuta-konvertori","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/valyuta-konvertori#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Valyuta","item":"https://calk.uz/uz/category/currency"},{"@type":"ListItem","position":3,"name":"Valyuta konvertori","item":"https://calk.uz/uz/calculator/valyuta-konvertori"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O'zbekistonda dollar kursi qancha?","acceptedAnswer":{"@type":"Answer","text":"2026-yil boshiga ko'ra — 1 dollar uchun taxminan 12 100–12 500 so'm. Dolzarb kurs cbu.uz da har kuni e'lon qilinadi."}},{"@type":"Question","name":"Valyutani qayerda foydaliroq ayirboshlash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Yirik summalar ($1000 dan) — banklarda kelishilgan kursda. Kichik summalar — ayirboshlash punktlarida. Spred odatda MB kursidan 0,5-1,5%."}},{"@type":"Question","name":"MB kursi qachon yangilanadi?","acceptedAnswer":{"@type":"Answer","text":"Har kuni Toshkent vaqti bilan 16:00 gacha cbu.uz saytida."}},{"@type":"Question","name":"Valyutani erkin sotib olish mumkinmi?","acceptedAnswer":{"@type":"Answer","text":"Ha, 2017-yildan jismoniy shaxslar xorijiy valyutani cheklovsiz erkin sotib olishi mumkin."}},{"@type":"Question","name":"O'zbekistonda qanday valyutalarni ayirboshlash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Asosiy: USD, EUR, RUB, GBP, CNY, KZT. Kamroq tarqalgan valyutalarni yirik banklarda ayirboshlash mumkin."}},{"@type":"Question","name":"MB kursi va bank kursi orasidagi farq nima?","acceptedAnswer":{"@type":"Answer","text":"MB kursi (cbu.uz) — kunlik rasmiy o'rtacha kurs. Tijorat banklar undan ~30-80 so'm farq qiluvchi sotish/sotib olish kursini belgilaydi. Yirik miqdorlar uchun bir nechta bankni taqqoslang yoki bank arizasi orqali ariza qoldiring."}},{"@type":"Question","name":"Naqd dollar olishda chek beriladimi?","acceptedAnswer":{"@type":"Answer","text":"Ha, banklar valyuta ayirboshlashdan keyin spravka beradilar — bu bojxonada $5 000 dan ortiq olib chiqishda kerak bo'ladi. Spravkani kamida 1 yil saqlang."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Valyuta konvertori","description":"O'zbekiston Markaziy banki joriy kursi bo'yicha valyutalarni konvertatsiya qiling. UZS, USD, EUR, RUB va boshqa valyutalar.","url":"https://calk.uz/uz/calculator/valyuta-konvertori","datePublished":"2025-01-19","dateModified":"2025-12-12","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/valyuta-konvertori"},{"@context":"https://schema.org","@type":"HowTo","name":"Valyuta konvertoridan qanday foydalanish","description":"Valyuta konvertoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Valyutalarni tanlang","text":"Ro'yxatdan boshlang'ich va maqsad valyutani tanlang (USD, EUR, RUB, UZS va boshq.)."},{"@type":"HowToStep","position":2,"name":"Summani kiriting","text":"Konvertatsiya qilish uchun summani ko'rsating."},{"@type":"HowToStep","position":3,"name":"Natijani oling","text":"Kurs O'zR MB ma'lumotlari bo'yicha avtomatik yangilanadi — natija darhol ko'rinadi."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
