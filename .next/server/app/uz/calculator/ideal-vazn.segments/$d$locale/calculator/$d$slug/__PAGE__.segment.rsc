2:T1026,[{"@context":"https://schema.org","@type":"WebPage","name":"Ideal vazn","description":"Bir nechta formula bo'yicha ideal vaznni hisoblang. Bo'y, yosh va tana tuzilishi turini hisobga oladi.","url":"https://calk.uz/uz/calculator/ideal-vazn","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/ideal-vazn#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/ideal-vazn/opengraph-image"},"dateModified":"2025-06-10"},{"@context":"https://schema.org","@type":"WebApplication","name":"Ideal vazn","description":"Bir nechta formula bo'yicha ideal vaznni hisoblang. Bo'y, yosh va tana tuzilishi turini hisobga oladi.","url":"https://calk.uz/uz/calculator/ideal-vazn","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/ideal-vazn#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Salomatlik","item":"https://calk.uz/uz/category/health"},{"@type":"ListItem","position":3,"name":"Ideal vazn","item":"https://calk.uz/uz/calculator/ideal-vazn"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Ideal vaznni qanday hisoblash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Brok, Lorents, Devayn formulalari yoki TMI 18,5-24,9 orqali. Kalkulyator barcha usullarni qo'llaydi va o'rtacha natijani ko'rsatadi."}},{"@type":"Question","name":"170 sm bo'yga qanday vazn normal?","acceptedAnswer":{"@type":"Answer","text":"Erkak: 59-72 kg (optimum 63-68 kg). Ayol: 53-68 kg (optimum 56-62 kg). TMI 18,5-24,9 bo'yicha."}},{"@type":"Question","name":"Ideal vazn erkak va ayollar uchun bir xilmi?","acceptedAnswer":{"@type":"Answer","text":"Yo'q, bir xil bo'yda erkak mushak massasi va suyak tuzilishi hisobiga 5-10 kg ko'proq tortadi."}},{"@type":"Question","name":"Qaysi formula eng aniq?","acceptedAnswer":{"@type":"Answer","text":"JSST formulasi (TMI) — eng universal. Aniqroq natija uchun barcha formulalarning o'rtachasidan foydalaning."}},{"@type":"Question","name":"O'zbekistonda o'rtacha bo'y qancha?","acceptedAnswer":{"@type":"Answer","text":"Erkaklar — taxminan 172 sm, ayollar — taxminan 160 sm. Ideal vazn: erkaklar 63-72 kg, ayollar 52-60 kg."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Ideal vazn","description":"Bir nechta formula bo'yicha ideal vaznni hisoblang. Bo'y, yosh va tana tuzilishi turini hisobga oladi.","url":"https://calk.uz/uz/calculator/ideal-vazn","datePublished":"2025-03-12","dateModified":"2025-06-10","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/ideal-vazn"},{"@context":"https://schema.org","@type":"HowTo","name":"Ideal vazndan qanday foydalanish","description":"Ideal vazndan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Bo'yingizni kiriting","text":"Bo'yingizni santimetrlarda ko'rsating."},{"@type":"HowToStep","position":2,"name":"Jins va yoshni tanlang","text":"Aniq hisoblash uchun jins va yoshni ko'rsating."},{"@type":"HowToStep","position":3,"name