22:["$","div",null,{"className":"mt-8","children":[["$","h3",null,{"className":"text-lg sm:text-xl font-semibold text-foreground mb-4","children":"Ko'p beriladigan savollar"}],["$","$L2b",null,{"className":"rounded-xl border border-border bg-card px-4","children":[["$","$L2c","0",{"value":"faq-0","children":[["$","$L2d",null,{"className":"text-left text-foreground","children":"O'zbekistonda ipoteka stavkasi qancha?"}],["$","$L2e",null,{"children":["$","p",null,{"className":"text-muted-foreground","children":"Tijorat ipotekasi: 23-31%. Subsidiyali: 17-22% (formula: MB stavkasi + 6% ≈ 20%). Imtiyozli toifalar (yosh oilalar, ko'p bolalilar, byudjet xodimlari): 7-14%."}]}]]}],["$","$L2c","1",{"value":"faq-1","children":[["$","$L2d",null,{"className":"text-left text-foreground","children":"Ipoteka uchun boshlang'ich to'lov qancha kerak?"}],["$","$L2e",null,{"children":["$","p",null,{"className":"text-muted-foreground","children":"Bank va dasturga qarab uy-joy qiymatining 15% dan 30% gacha."}]}]]}],["$","$L2c","2",{"value":"faq-2","children":[["$","$L2d",null,{"className":"text-left text-foreground","children":"Ipoteka maksimal necha yilga beriladi?"}],["$","$L2e",null,{"children":["$","p",null,{"className":"text-muted-foreground","children":"20 yilgacha. Eng keng tarqalgan muddatlar: 10-15 yil."}]}]]}],["$","$L2c","3",{"value":"faq-3","children":[["$","$L2d",null,{"className":"text-left text-foreground","children":"Ipoteka uchun qanday hujjatlar kerak?"}],["$","$L2e",null,{"children":["$","p",null,{"className":"text-muted-foreground","children":"Pasport, daromad ma'lumotnomasi, kredit tarixi, sotib olinadigan uy-joy hujjatlari, ko'chmas mulk baholash, ob'ekt sug'urtasi."}]}]]}],["$","$L2c","4",{"value":"faq-4","children":[["$","$L2d",null,{"className":"text-left text-foreground","children":"Qanday imtiyozli ipoteka dasturlari bor?"}],["$","$L2e",null,{"children":["$","p",null,{"className":"text-muted-foreground","children":"Yosh oilalar uchun «Yosh oila», qishloq joylari