2:T154b,[{"@context":"https://schema.org","@type":"WebPage","name":"Ipoteka kalkulyatori","description":"O'zbekistonda ipoteka kreditini hisoblang. Boshlang'ich to'lov, oylik to'lov, ortiqcha to'lov va to'lov jadvali.","url":"https://calk.uz/uz/calculator/ipoteka","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/ipoteka#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/ipoteka/opengraph-image"},"dateModified":"2026-03-02"},{"@context":"https://schema.org","@type":"WebApplication","name":"Ipoteka kalkulyatori","description":"O'zbekistonda ipoteka kreditini hisoblang. Boshlang'ich to'lov, oylik to'lov, ortiqcha to'lov va to'lov jadvali.","url":"https://calk.uz/uz/calculator/ipoteka","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/ipoteka#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Kreditlar","item":"https://calk.uz/uz/category/credit"},{"@type":"ListItem","position":3,"name":"Ipoteka kalkulyatori","item":"https://calk.uz/uz/calculator/ipoteka"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O'zbekistonda ipoteka stavkasi qancha?","acceptedAnswer":{"@type":"Answer","text":"Tijorat ipotekasi: 23-31%. Subsidiyali: 17-22% (formula: MB stavkasi + 6% ≈ 20%). Imtiyozli toifalar (yosh oilalar, ko'p bolalilar, byudjet xodimlari): 7-14%."}},{"@type":"Question","name":"Ipoteka uchun boshlang'ich to'lov qancha kerak?","acceptedAnswer":{"@type":"Answer","text":"Bank va dasturga qarab uy-joy qiymatining 15% dan 30% gacha."}},{"@type":"Question","name":"Ipoteka maksimal necha yilga beriladi?","acceptedAnswer":{"@type":"Answer","text":"20 yilgacha. Eng keng tarqalgan muddatlar: 10-15 yil."}},{"@type":"Question","name":"Ipoteka uchun qanday hujjatlar kerak?","acceptedAnswer":{"@type":"Answer","text":"Pasport, daromad ma'lumotnomasi, kredit tarixi, sotib olinadigan uy-joy hujjatlari, ko'chmas mulk baholash, ob'ekt sug'urtasi."}},{"@type":"Question","name":"Qanday imtiyozli ipoteka dasturlari bor?","acceptedAnswer":{"@type":"Answer","text":"Yosh oilalar uchun «Yosh oila», qishloq joylari uchun «Obod qishloq», byudjet xodimlari uchun dasturlar — yillik 7% dan stavkalar."}},{"@type":"Question","name":"Toshkentda uy-joy kvadrat metri qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"2025–2026-yilda: tumanga qarab 8 dan 15 mln so'm/m² gacha. Markaz va mashhur tumanlar — qimmatroq."}},{"@type":"Question","name":"Yosh oilalar uchun «Ipoteka 7%» dasturi nima va qanday olinadi?","acceptedAnswer":{"@type":"Answer","text":"Davlat dasturi: 35 yoshgacha bo'lgan yosh oila yoki yakka tartibdagi onaga yiliga 7% stavkada ipoteka beriladi. Birinchi to'lov 15%, muddat — 20 yilgacha. Shartlar: O'zbekiston fuqarosi, ro'yxatda turish, ilgari uy-joyga ega bo'lmaslik."}},{"@type":"Question","name":"Mahalla referensiyasi ipoteka uchun kerakmi?","acceptedAnswer":{"@type":"Answer","text":"Ko'pchilik banklar mahalla raisidan tasdiq xatini so'raydi (mahalla referensiyasi). U sizning oilaviy holatingizni va ishonchliligingizni tasdiqlaydi. Ariza topshirishdan oldin tayyorlab qo'ying."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Ipoteka kalkulyatori","description":"O'zbekistonda ipoteka kreditini hisoblang. Boshlang'ich to'lov, oylik to'lov, ortiqcha to'lov va to'lov jadvali.","url":"https://calk.uz/uz/calculator/ipoteka","datePublished":"2025-03-16","dateModified":"2026-03-02","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/ipoteka"},{"@context":"https://schema.org","@type":"HowTo","name":"Ipoteka kalkulyatoridan qanday foydalanish","description":"Ipoteka kalkulyatoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT3M","step":[{"@type":"HowToStep","position":1,"name":"Uy-joy narxini kiriting","text":"Kvartira yoki uyning to'liq narxini so'mda kiriting."},{"@type":"HowToStep","position":2,"name":"Boshlang'ich badalni ko'rsating","text":"Boshlang'ich badal summasini yoki foizini kiriting."},{"@type":"HowToStep","position":3,"name":"Foiz stavkasini o'rnating","text":"Ipoteka kreditining yillik stavkasini kiriting."},{"@type":"HowToStep","position":4,"name":"Ipoteka muddatini tanlang","text":"Kreditlash muddatini ko'rsating (odatda 10-20 yil)."},{"@type":"HowToStep","position":5,"name":"Hisobni oling","text":"«Hisoblash» tugmasini bosing va oylik to'lov, umumiy ortiqcha to'lov va kredit summasini bilib oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"XLmqlxyLlWU5g91MHKI_z"}
