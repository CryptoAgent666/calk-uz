2:T1189,[{"@context":"https://schema.org","@type":"WebPage","name":"Kvartira narxi","description":"Toshkent va boshqa shaharlarda kvartira narxini baholang. Tuman, maydon va holatni hisobga oladi.","url":"https://calk.uz/uz/calculator/kvartira-narxi","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/kvartira-narxi#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/kvartira-narxi/opengraph-image"},"dateModified":"2025-12-26"},{"@context":"https://schema.org","@type":"WebApplication","name":"Kvartira narxi","description":"Toshkent va boshqa shaharlarda kvartira narxini baholang. Tuman, maydon va holatni hisobga oladi.","url":"https://calk.uz/uz/calculator/kvartira-narxi","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/kvartira-narxi#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Ko'chmas mulk","item":"https://calk.uz/uz/category/realestate"},{"@type":"ListItem","position":3,"name":"Kvartira narxi","item":"https://calk.uz/uz/calculator/kvartira-narxi"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Toshkentda kvartira qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"2 xonali (60 m²): tumanga qarab 480-900 mln so'm. Yunusobod: ~720 mln, Sergeli: ~480 mln, Mirobod: ~900 mln."}},{"@type":"Question","name":"Toshkentning qaysi tumani eng qimmat?","acceptedAnswer":{"@type":"Answer","text":"Mirobod tumani (13-16 mln so'm/m²) va Mirzo Ulug'bek (12-15 mln). Eng qulay: Sergeli va Bektemir (7-10 mln)."}},{"@type":"Question","name":"Hududlarda uy-joy kvadrat metri qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"Samarqand: 5-8 mln, Buxoro: 4-7 mln, Namangan: 3-6 mln, Andijon/Nukus: 3-5 mln so'm/m²."}},{"@type":"Question","name":"Kvartira sotib olishda qo'shimcha xarajatlar qanday?","acceptedAnswer":{"@type":"Answer","text":"Notarius — belgilangan 1 BHK (412 000 so'm), ro'yxatdan o'tish boji — maydon bo'yicha 1,25-3 BHK (100 m² gacha — 1,25 BHK), baholash (500 000 so'mgacha), rieltor (1-2%). Jami: qiymatning 1-3%."}},{"@type":"Question","name":"Yangi qurilish yoki ikkilamchi uy sotib olish foydaliroqmi?","acceptedAnswer":{"@type":"Answer","text":"Yangi qurilishlar 20-30% ga qimmatroq, lekin ta'mir talab qilmaydi. Ikkilamchi arzonroq, lekin ta'mirga sarmoya kerak bo'lishi mumkin."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Kvartira narxi","description":"Toshkent va boshqa shaharlarda kvartira narxini baholang. Tuman, maydon va holatni hisobga oladi.","url":"https://calk.uz/uz/calculator/kvartira-narxi","datePublished":"2025-07-11","dateModified":"2025-12-26","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/kvartira-narxi"},{"@context":"https://schema.org","@type":"HowTo","name":"Kvartira narxidan qanday foydalanish","description":"Kvartira narxidan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Shahar va tumanni tanlang","tex