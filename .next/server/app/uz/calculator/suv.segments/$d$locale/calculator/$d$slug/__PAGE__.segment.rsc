2:Tfbb,[{"@context":"https://schema.org","@type":"WebPage","name":"Suv","description":"O'zbekiston tariflari bo'yicha sovuq va issiq suv narxini hisoblang. Kanalizatsiya xizmati kiritilgan.","url":"https://calk.uz/uz/calculator/suv","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/suv#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/suv/opengraph-image"},"dateModified":"2026-03-15"},{"@context":"https://schema.org","@type":"WebApplication","name":"Suv","description":"O'zbekiston tariflari bo'yicha sovuq va issiq suv narxini hisoblang. Kanalizatsiya xizmati kiritilgan.","url":"https://calk.uz/uz/calculator/suv","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/suv#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Kommunal","item":"https://calk.uz/uz/category/utilities"},{"@type":"ListItem","position":3,"name":"Suv","item":"https://calk.uz/uz/calculator/suv"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O'zbekistonda suv qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"Sovuq suv: 3 000-5 000 so'm/m³. Oqava suv: qo'shimcha 1 500-3 000 so'm/m³. Jami: 4 500-8 000 so'm/m³."}},{"@type":"Question","name":"Hisoblagich bo'yicha to'lash foydaliroqmi?","acceptedAnswer":{"@type":"Answer","text":"Ha, odatda 1,5-2 baravar foydaliroq. 4 kishilik oila: normativ bo'yicha ~144 000 so'm/oy, hisoblagich bo'yicha ~72 000 so'm."}},{"@type":"Question","name":"Hisoblagichsiz suv iste'moli normativi qancha?","acceptedAnswer":{"@ty