1a:Tfbb,[{"@context":"https://schema.org","@type":"WebPage","name":"Suv","description":"O'zbekiston tariflari bo'yicha sovuq va issiq suv narxini hisoblang. Kanalizatsiya xizmati kiritilgan.","url":"https://calk.uz/uz/calculator/suv","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/suv#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/suv/opengraph-image"},"dateModified":"2026-03-15"},{"@context":"https://schema.org","@type":"WebApplication","name":"Suv","description":"O'zbekiston tariflari bo'yicha sovuq va issiq suv narxini hisoblang. Kanalizatsiya xizmati kiritilgan.","url":"https://calk.uz/uz/calculator/suv","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/suv#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Kommunal","item":"https://calk.uz/uz/category/utilities"},{"@type":"ListItem","position":3,"name":"Suv","item":"https://calk.uz/uz/calculator/suv"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O'zbekistonda suv qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"Sovuq suv: 3 000-5 000 so'm/m³. Oqava suv: qo'shimcha 1 500-3 000 so'm/m³. Jami: 4 500-8 000 so'm/m³."}},{"@type":"Question","name":"Hisoblagich bo'yicha to'lash foydaliroqmi?","acceptedAnswer":{"@type":"Answer","text":"Ha, odatda 1,5-2 baravar foydaliroq. 4 kishilik oila: normativ bo'yicha ~144 000 so'm/oy, hisoblagich bo'yicha ~72 000 so'm."}},{"@type":"Question","name":"Hisoblagichsiz suv iste'moli normativi qancha?","acceptedAnswer":{"@type":"Answer","text":"Bir kishiga kuniga 150-200 litr (oyiga 4,5-6 m³)."}},{"@type":"Question","name":"Suv hisoblagich ko'rsatkichlarini qanday uzatish mumkin?","acceptedAnswer":{"@type":"Answer","text":"Suv kanali mobil ilovasi yoki abonent bo'limi orqali. Ko'rsatkichlar har oy uzatiladi."}},{"@type":"Question","name":"Suv hisoblagichni o'rnatish qancha turadi?","acceptedAnswer":{"@type":"Answer","text":"O'rnatish bilan 200 000-500 000 so'm. Tekshirish har 4-6 yilda. 3-6 oyda o'zini oqlaydi."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Suv","description":"O'zbekiston tariflari bo'yicha sovuq va issiq suv narxini hisoblang. Kanalizatsiya xizmati kiritilgan.","url":"https://calk.uz/uz/calculator/suv","datePublished":"2025-05-15","dateModified":"2026-03-15","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/suv"},{"@context":"https://schema.org","@type":"HowTo","name":"Suvdan qanday foydalanish","description":"Suvdan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT1M","step":[{"@type":"HowToStep","position":1,"name":"Suv iste'molini kiriting","text":"Oyiga sarflangan suv hajmini kub metrda (m³) kiriting."},{"@type":"HowToStep","position":2,"name":"Suv ta'minoti turini tanlang","text":"Sovuq, issiq suv yoki ikkalasini tanlang."},{"@type":"HowToStep","position":3,"name":"To'lov summasini oling","text":"«Hisoblash» tugmasini bosing — suv ta'minoti va kanalizatsiya narxini bilib ol