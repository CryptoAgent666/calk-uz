2:T1272,[{"@context":"https://schema.org","@type":"WebPage","name":"Kaloriya kalkulyatori","description":"Vazn yo'qotish, olish yoki saqlash uchun kunlik kaloriya me'yorini hisoblang. Mifflin-San Jeor formulasi.","url":"https://calk.uz/uz/calculator/kaloriya","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/kaloriya#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/kaloriya/opengraph-image"},"dateModified":"2025-07-15"},{"@context":"https://schema.org","@type":"WebApplication","name":"Kaloriya kalkulyatori","description":"Vazn yo'qotish, olish yoki saqlash uchun kunlik kaloriya me'yorini hisoblang. Mifflin-San Jeor formulasi.","url":"https://calk.uz/uz/calculator/kaloriya","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/kaloriya#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Salomatlik","item":"https://calk.uz/uz/category/health"},{"@type":"ListItem","position":3,"name":"Kaloriya kalkulyatori","item":"https://calk.uz/uz/calculator/kaloriya"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Kuniga necha kaloriya kerak?","acceptedAnswer":{"@type":"Answer","text":"Erkaklar: 2 000-2 500 kkal, ayollar: 1 600-2 000 kkal. Yosh, vazn, bo'y va jismoniy faollik darajasiga bog'liq. Kalkulyator shaxsiy normani hisoblab beradi."}},{"@type":"Question","name":"Vazn kamaytirish uchun necha kaloriya kerak?","acceptedAnswer":{"@type":"Answer","text":"Kunlik normadan 500-750 kkal kam. Bu haftasiga xavfsiz 0,5-0,75 kg yo'qotishni ta'minlaydi. Ayollar uchun 1 200 kkal va erkaklar uchun 1 500 kkal dan past tushirish tavsiya etilmaydi."}},{"@type":"Question","name":"Qaysi formula aniqroq?","acceptedAnswer":{"@type":"Answer","text":"Mifflin-San Jeor formulasi zamonaviy inson uchun eng aniq hisoblanadi (aniqligi ~90%). Harris-Benedikt formulasi 5-10% ga oshirib ko'rsatadi."}},{"@type":"Question","name":"Oshda necha kaloriya bor?","acceptedAnswer":{"@type":"Answer","text":"Bir porsiya osh (300-400 g) 700-900 kkal o'z ichiga oladi. Somsa — 350-450 kkal, lag'mon — 400-600 kkal, sho'rva — 300-500 kkal."}},{"@type":"Question","name":"Kaloriyalarni hisoblashda iqlimni hisobga olish kerakmi?","acceptedAnswer":{"@type":"Answer","text":"Ha, O'zbekistonning issiq iqlimida organizm termoregulyatsiyaga qo'shimcha energiya sarflaydi. Yozda ehtiyoj 5-10% ga oshishi mumkin."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Kaloriya kalkulyatori","description":"Vazn yo'qotish, olish yoki saqlash uchun kunlik kaloriya me'yorini hisoblang. Mifflin-San Jeor formulasi.","url":"https://calk.uz/uz/calculator/kaloriya","datePublished":"2025-09-11","dateModified":"2025-07-15","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/kaloriya"},{"@context":"https://schema.org","@type":"HowTo","name":"Kaloriya kalkulyatoridan qanday foydalanish","description":"Kaloriya kalkulyatoridan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Yoshingizni kiriting","text":"Yoshingizni yillarda ko'rsating."},{"@type":"HowToStep","position":2,"name":"Bo'y va vaznni kiriting","text":"Bo'yingizni santimetrlarda va vazningizni kilogrammlarda kiriting."},{"@type":"HowToStep","position":3,"name":"Jinsni tanlang","text":"Aniq hisoblash uchun jinsingizni ko'rsating."},{"@type":"HowToStep","position":4,"name":"Faollik darajasini tanlang","text":"Jismoniy faollik darajasini ko'rsating (kam harakatli, o'rtacha, faol)."},{"@type":"HowToStep","position":5,"name":"Kaloriya normasini oling","text":"«Hisoblash» tugmasini bosing — vaznni saqlash, kamaytirish va oshirish uchun kunlik kaloriya normasini oling."}]}]0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}],"$L3","$L4"]}],["$L5","$L6","$L7","$L8"],"$L9"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"ho_PLmB22Xt1IShblYwbi"}
