1a:T10f2,[{"@context":"https://schema.org","@type":"WebPage","name":"Xodim narxi","description":"Ish beruvchi uchun xodimni saqlashning to'liq narxini hisoblang. Ish haqi, soliqlar va ijtimoiy badal.","url":"https://calk.uz/uz/calculator/xodim-narxi","inLanguage":"uz","isPartOf":{"@type":"WebSite","name":"Calk.UZ","url":"https://calk.uz"},"breadcrumb":{"@id":"https://calk.uz/uz/calculator/xodim-narxi#breadcrumb"},"primaryImageOfPage":{"@type":"ImageObject","url":"https://calk.uz/uz/calculator/xodim-narxi/opengraph-image"},"dateModified":"2026-01-20"},{"@context":"https://schema.org","@type":"WebApplication","name":"Xodim narxi","description":"Ish beruvchi uchun xodimni saqlashning to'liq narxini hisoblang. Ish haqi, soliqlar va ijtimoiy badal.","url":"https://calk.uz/uz/calculator/xodim-narxi","applicationCategory":"FinanceApplication","operatingSystem":"All","offers":{"@type":"Offer","price":"0","priceCurrency":"UZS"},"inLanguage":"uz","publisher":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"}},{"@context":"https://schema.org","@type":"BreadcrumbList","@id":"https://calk.uz/uz/calculator/xodim-narxi#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Bosh sahifa","item":"https://calk.uz/uz"},{"@type":"ListItem","position":2,"name":"Biznes","item":"https://calk.uz/uz/category/business"},{"@type":"ListItem","position":3,"name":"Xodim narxi","item":"https://calk.uz/uz/calculator/xodim-narxi"}]},{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"O'zbekistonda ish beruvchi ish haqidan tashqari qancha to'laydi?","acceptedAnswer":{"@type":"Answer","text":"Hisoblangan ish haqidan 12% ijtimoiy soliq (byudjet uchun 25%). To'liq qiymat = qo'ldagi ish haqi × 1,274."}},{"@type":"Question","name":"Xodimning to'liq qiymatini qanday hisoblash mumkin?","acceptedAnswer":{"@type":"Answer","text":"Gross = Netto / 0,879. To'liq qiymat = Gross × 1,12. IT Park uchun: Gross = Netto / 0,924."}},{"@type":"Question","name":"Ish beruvchi yana qanday xarajatlarga duchor bo'ladi?","acceptedAnswer":{"@type":"Answer","text":"Kasallik varag'i (birinchi 10 kun), ta'til haqi, ishdan bo'shatish kompensatsiyasi, sug'urta, mehnat muhofazasi. IHFga qo'shimcha 10-20%."}},{"@type":"Question","name":"IT Park orqali yollash foydaliroqmi?","acceptedAnswer":{"@type":"Answer","text":"Ha, 10 mln so'm qo'ldagi ish haqili xodimga oyiga ~620 000 so'm tejash (umumiy xarajatlarning taxminan 5%)."}},{"@type":"Question","name":"Byudjet tashkilotlari uchun ijtimoiy soliq qancha?","acceptedAnswer":{"@type":"Answer","text":"Standart 12% o'rniga IHFdan 25%. To'liq qiymat = Gross × 1,25."}}]},{"@context":"https://schema.org","@type":"TechArticle","headline":"Xodim narxi","description":"Ish beruvchi uchun xodimni saqlashning to'liq narxini hisoblang. Ish haqi, soliqlar va ijtimoiy badal.","url":"https://calk.uz/uz/calculator/xodim-narxi","datePublished":"2025-05-17","dateModified":"2026-01-20","author":{"@type":"Person","@id":"https://calk.uz/#founder","name":"Konstantin Yakovlev","alternateName":"Константин Яковлев","url":"https://calk.uz/uz/author/konstantin-yakovlev","jobTitle":"Calk.UZ loyihasi asoschisi va rahbari","image":"https://calk.uz/og/author-konstantin.jpg"},"reviewedBy":{"@type":"Organization","name":"Calk.UZ","url":"https://calk.uz"},"publisher":{"@type":"Organization","@id":"https://calk.uz/#organization","name":"Calk.UZ","url":"https://calk.uz","logo":{"@type":"ImageObject","url":"https://calk.uz/favicon.svg"}},"inLanguage":"uz","mainEntityOfPage":"https://calk.uz/uz/calculator/xodim-narxi"},{"@context":"https://schema.org","@type":"HowTo","name":"Xodim narxidan qanday foydalanish","description":"Xodim narxidan foydalanish bo'yicha qadam-baqadam qo'llanma","totalTime":"PT2M","step":[{"@type":"HowToStep","position":1,"name":"Xodim ish haqini kiriting","text":"Xodimning hisoblangan ish haqini ko'rsating."},{"@type":"HowToStep","position":2,"name":"Xodimlar sonini ko'rsating","text":"Hisoblash uchun ishchilar sonini kiriting."},{"@type":"HowToStep","position":3,"name":"Imtiyozlarni tanlang","text":"Tegishli imtiyozlar va maxsus shartlarni belgilang."},{"@type":"HowToStep","position":4,"name":"Hisobni oling","text":"«Hisoblash» tugmasini bosing — ish beruvchi uchun xodimning to'liq qiymatini bilib oling."}]}]11:["$","div",null,{"className":"min-h-screen","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$1a"}}],"$L1b","$L1c"]}]
