{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/author/layout,_N_T_/[locale]/author/[slug]/layout,_N_T_/[locale]/author/[slug]/page,_N_T_/uz/author/konstantin-yakovlev"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/author/$d$slug/__PAGE__",
    "/$d$locale/author/$d$slug",
    "/$d$locale/author",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}