{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/methodology/layout,_N_T_/[locale]/methodology/page,_N_T_/uz/methodology"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/methodology/__PAGE__",
    "/$d$locale/methodology",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}