{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/updates/layout,_N_T_/[locale]/updates/page,_N_T_/uz/updates"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/updates/__PAGE__",
    "/$d$locale/updates",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}