4:["$","section",null,{"className":"rounded-2xl border border-border bg-card p-6 sm:p-8","children":[["$","h2",null,{"className":"text-xl font-semibold text-foreground mb-4","children":"6. Reklama"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed text-sm mb-3","children":"Sayt uchinchi tomon reklama tarmoqlaridan, jumladan Google AdSense xizmatidan reklama ko'rsatishi mumkin. Reklama kontenti Calk.UZ tomonidan emas, balki tashqi reklama beruvchilar tomonidan taqdim etiladi."}],["$","p",null,{"className":"text-muted-foreground leading-relaxed text-sm mb-3","children":"Calk.UZ reklama tovarlari, xizmatlari yoki reklama beruvchining saytiga o'tishdan keyin yuzaga keladigan munosabatlar uchun javobgarlikni o'z zimmasiga olmaydi. Reklamada taqdim etilgan takliflarning ishonchliligini foydalanuvchi mustaqil tekshirishi kerak."}],["$","p",null,{"className":"text-muted-foreground leading-relaxed text-sm","children":"Reklama cookie fayllari va shaxsiylashtirilgan reklamadan voz kechish tartibi bizning Maxfiylik siyosatida batafsil tavsiflangan."}]]}]
5:["$","section",null,{"className":"rounded-2xl border border-border bg-card p-6 sm:p-8","children":[["$","h2",null,{"className":"text-xl font-semibold text-foreground mb-4","children":"7. Tashqi havolalar"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed text-sm","children":"Saytda uchinchi tomon veb-saytlariga havolalar bo'lishi mumkin (rasmiy davlat organlari saytlari, Markaziy bank va boshqalar). Calk.UZ tashqi saytlarning kontenti, maxfiylik siyosati yoki xavfsizligi uchun javobgar emas. Tashqi havolalarga o'tish foydalanuvchining o'z xavfi va ixtiyoriga ko'ra amalga oshiriladi."}]]}]
6:["$","section",null,{"className":"rounded-2xl border border-border bg-card p-6 sm:p-8","children":[["$","h2",null,{"className":"text-xl font-semibold text-foreground mb-4","children":"8. Shartlarni o'zgartirish"}],["$","p",null,{"className":"text-muted-foreground leading-relaxed text-sm","children":"Calk.UZ ushbu foydalanish shartlarini istalgan vaqtda o'zgartirish huquqini o'zida saqlab qoladi. O'zgarishlar saytda e'lon qilingan paytdan kuchga kiradi. Saytdan davomiy foydalanish yangilangan shartlarga rozilikni anglatadi."}]]}]
