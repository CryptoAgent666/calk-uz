# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
**/.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel — not used, keeping rule for safety
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# JetBrains / VSCode IDE files
.idea/
.vscode/
*.iml

# Android — build artifacts and gradle cache
android/.gradle/
android/build/
android/app/build/
android/capacitor-cordova-android-plugins/build/

# OS / editor temp
*.swp
*.swo
*~
